{% extends 'base.html.twig' %}

{% block title %}Analyse Forum - GrowMind{% endblock %}

{% block body %}
{% include 'front/_main_nav.html.twig' with { active_page: 'forum' } %}

<main class="main">
  <section class="section" style="padding-top: 130px;">
    <div class="container">
      <div class="row g-4 align-items-start">
        <div class="col-lg-8">
          <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4 p-lg-5">
              <span class="badge text-bg-light text-success mb-3">Analyse</span>
              <h1 class="mb-3">Analyse du climat emotionnel du forum</h1>
              <p class="text-secondary mb-0">Cette vue reprend l analyse sentiment et les periodes sensibles du projet forum d origine, dans le meme univers GrowMind.</p>
            </div>
          </div>

          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-lg-5">
              <h2 class="h4 mb-4">Evolution des scores</h2>
              <canvas id="analyseChart" height="120"></canvas>
            </div>
          </div>
        </div>

        <div class="col-lg-4">
          <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
              <h3 class="h5 mb-3">Periodes suivies</h3>
              <div id="analysePeriods" class="d-grid gap-3"></div>
            </div>
          </div>

          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
              <h3 class="h5 mb-3">Acces rapides</h3>
              <div class="d-grid gap-2">
                <a href="{{ path('app_forum_index') }}" class="btn btn-outline-secondary">Retour forum</a>
                <a href="{{ path('app_urgence_index') }}" class="btn btn-outline-danger">Historique SOS</a>
                <a href="{{ path('app_carte_medecins') }}" class="btn btn-outline-primary">Carte des medecins</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', async () => {
      const response = await fetch('{{ path('api_analyse_sentiment') }}');
      const data = await response.json();

      const periods = document.getElementById('analysePeriods');
      periods.innerHTML = Object.values(data.periodes || {}).map((periode) => `
        <div class="border rounded-4 p-3 bg-light">
          <div class="fw-semibold">${periode.nom}</div>
          <div class="small text-secondary">${periode.debut} - ${periode.fin}</div>
        </div>
      `).join('');

      const ctx = document.getElementById('analyseChart');
      if (!ctx) {
        return;
      }

      new Chart(ctx, {
        type: 'line',
        data: {
          labels: data.dates || [],
          datasets: [{
            label: 'Score emotionnel',
            data: data.scores || [],
            borderColor: '#dc3545',
            backgroundColor: 'rgba(220,53,69,0.15)',
            tension: 0.35,
            fill: true
          }]
        },
        options: {
          responsive: true,
          scales: {
            y: {
              min: 0,
              max: 10
            }
          }
        }
      });
    });
  </script>
{% endblock %}
