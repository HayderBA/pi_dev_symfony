{% extends 'wellness/base.html.twig' %}

{% block title %}Humeurs{% endblock %}

{% block body %}
    <div class="container py-4">

        <!-- HEADER -->
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
            <div>
                <div class="page-kicker mb-2">Humeurs</div>
                <h1 class="h2 mb-1">Suivi des humeurs</h1>
                <p class="text-muted mb-0">Consulter et gérer les niveaux d’humeur enregistrés ainsi que les notes.</p>
            </div>

            <!-- ADD BUTTON -->
            <a class="btn"
               style="
                   background:#4CAF8E;
                   color:white;
                   border-radius:10px;
                   padding:8px 16px;
               "
               onmouseover="this.style.background='#2F7D6D';"
               onmouseout="this.style.background='#4CAF8E';"
               href="{{ path('app_humeurs_new') }}">
                <i class="bi bi-plus-lg me-1"></i>Ajouter une humeur
            </a>
        </div>

        <!-- CARD -->
        <div class="card content-card">

            <!-- CARD HEADER -->
            <div class="card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 py-3 px-4">
                <div>
                    <h2 class="h5 mb-1">Historique des humeurs</h2>
                    <p class="text-muted mb-0">Entrées créées via le module des humeurs.</p>
                </div>

                <span class="badge rounded-pill"
                      style="background: rgba(76,175,142,0.15); color:#2F7D6D;">
                    {{ humeurs|length }} éléments
                </span>
            </div>

            <!-- TABLE -->
            <div class="card-body p-0">
                <div class="table-responsive">

                    <table class="table table-hover align-middle mb-0">

                        <!-- HEADER -->
                        <thead style="background:#F5F7F6;">
                        <tr>
                            <th>Id</th>
                            <th>Niveau</th>
                            <th>Notes</th>
                            <th>Date de création</th>
                            <th>Actions</th>
                        </tr>
                        </thead>

                        <tbody>
                        {% for humeur in humeurs %}
                            <tr style="transition: all 0.2s ease;">
                                <td>{{ humeur.id }}</td>

                                <!-- LEVEL -->
                                <td>
                                    <span style="
                                        background: rgba(76,175,142,0.15);
                                        color:#2F7D6D;
                                        padding:4px 10px;
                                        border-radius:8px;
                                    ">
                                        {{ humeur.niveau }}
                                    </span>
                                </td>

                                <td>
                                    {{ humeur.notes|length > 110
                                    ? humeur.notes|slice(0, 110) ~ '...'
                                    : humeur.notes
                                    }}
                                </td>

                                <td>
                                    {{ humeur.dateCreation ? humeur.dateCreation|date('Y-m-d H:i') : '--' }}
                                </td>

                                <!-- ACTIONS -->
                                <td class="text-nowrap">
                                    <div class="d-flex flex-wrap gap-2">

                                        <!-- VIEW -->
                                        <a class="btn btn-sm"
                                           style="
                                               border:1px solid #4CAF8E;
                                               color:#4CAF8E;
                                               border-radius:8px;
                                           "
                                           onmouseover="this.style.background='#4CAF8E'; this.style.color='white';"
                                           onmouseout="this.style.background='transparent'; this.style.color='#4CAF8E';"
                                           href="{{ path('app_humeurs_show', {'id': humeur.id}) }}">
                                            <i class="bi bi-eye me-1"></i>Voir
                                        </a>

                                        <!-- EDIT -->
                                        <a class="btn btn-sm"
                                           style="
                                               border:1px solid #6B7280;
                                               color:#6B7280;
                                               border-radius:8px;
                                           "
                                           onmouseover="this.style.background='#6B7280'; this.style.color='white';"
                                           onmouseout="this.style.background='transparent'; this.style.color='#6B7280';"
                                           href="{{ path('app_humeurs_edit', {'id': humeur.id}) }}">
                                            <i class="bi bi-pencil-square me-1"></i>Modifier
                                        </a>

                                        <!-- DELETE -->
                                        {{ include('humeurs/_delete_form.html.twig', {
                                            humeur: humeur,
                                            button_class: 'btn btn-sm',
                                            button_label: 'Supprimer',
                                            form_class: 'd-inline-block',
                                            confirm_message: 'Supprimer cette entrée d’humeur ?'
                                        }) }}

                                    </div>
                                </td>
                            </tr>

                        {% else %}
                            <tr>
                                <td class="text-center py-4 empty-state" colspan="5">
                                    Aucune entrée d’humeur trouvée.
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>

                    </table>

                </div>
            </div>
        </div>
    </div>
{% endblock %}
