{% extends 'back/patient/base_patient.html.twig' %}

{% block title %}Mon Dashboard - GrowMind{% endblock %}

{% block patient_content %}
    <!-- Welcome Hero -->
    <div class="welcome-card">
      <div class="welcome-inner">
        <div class="streak-pill"><i class="bi bi-fire"></i> 5-day check-in streak! Keep it up.</div>
        <h2>Bonjour {{ app.user.firstName|default('Ami') }} 🌿</h2>
        <p>Votre voyage vers le bien-être continue. Aujourd'hui est un jour parfait pour prendre soin de vous.
          Vous avez 2 rendez-vous prévus cette semaine.</p>
        <div class="d-flex gap-3 flex-wrap align-items-center">
          <button class="btn-gm-primary" onclick="document.getElementById('bookSection').scrollIntoView({behavior:'smooth'})">
            <i class="bi bi-plus-circle-fill"></i> Prendre rendez-vous
          </button>
          <div class="next-appt-chip">
            <div class="chip-icon"><i class="bi bi-camera-video-fill" style="color:#fff;font-size:15px"></i></div>
            <div class="chip-text">
              <div class="label">Prochain RDV</div>
              <div class="value">Aujourd'hui · 09:00 avec Dr. Mansour</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats row -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3">
        <div class="gm-card p-0">
          <div class="mini-stat">
            <div class="val" style="color:var(--green)">12</div>
            <div class="lbl">Sessions Complétées</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="gm-card p-0">
          <div class="mini-stat">
            <div class="val" style="color:var(--blue)">2</div>
            <div class="lbl">Rendez-vous à venir</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="gm-card p-0">
          <div class="mini-stat">
            <div class="val" style="color:#f59e0b">5</div>
            <div class="lbl">Série de jours 🔥</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="gm-card p-0">
          <div class="mini-stat">
            <div class="val" style="color:#9333ea">78</div>
            <div class="lbl">Score Bien-être</div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3 mb-3">
      <!-- Upcoming Appointments -->
      <div class="col-lg-7">
        <div class="gm-card h-100">
          <div class="gm-card-header">
            <span class="gm-card-title"><i class="bi bi-calendar2-check-fill me-2" style="color:var(--green)"></i>Rendez-vous à venir</span>
          </div>
          <div class="gm-card-body">
            <div class="d-flex flex-column gap-3">
              <div class="appt-card">
                <div class="appt-date-box"><div class="day">07</div><div class="mon">Avr</div></div>
                <div class="appt-details">
                  <div class="doc-name">Dr. Layla Mansour</div>
                  <div class="specialty">Psychiatre & Thérapeute TCC</div>
                  <div class="appt-meta">
                    <span class="chip chip-blue"><i class="bi bi-camera-video-fill"></i> Appel Vidéo</span>
                    <span class="chip chip-gray"><i class="bi bi-clock"></i> 9:00 AM</span>
                  </div>
                </div>
                <div class="appt-actions">
                  <button class="btn-gm-blue" style="padding:7px 14px;font-size:12px;"><i class="bi bi-camera-video-fill"></i> Rejoindre</button>
                </div>
              </div>
              <div class="appt-card">
                <div class="appt-date-box"><div class="day">14</div><div class="mon">Avr</div></div>
                <div class="appt-details">
                  <div class="doc-name">Dr. Nadia Benali</div>
                  <div class="specialty">Psychologue clinicienne</div>
                  <div class="appt-meta">
                    <span class="chip chip-green"><i class="bi bi-building"></i> En présentiel</span>
                    <span class="chip chip-gray"><i class="bi bi-clock"></i> 10:30 AM</span>
                  </div>
                </div>
                <div class="appt-actions">
                  <button class="btn-gm-outline" style="padding:6px 12px;font-size:11.5px;">Gérer</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Wellbeing Score -->
      <div class="col-lg-5">
        <div class="gm-card h-100">
          <div class="gm-card-header">
            <span class="gm-card-title"><i class="bi bi-heart-pulse-fill me-2" style="color:#ef4444"></i>Score Bien-être</span>
          </div>
          <div class="gm-card-body">
            <div class="d-flex align-items-center gap-3 mb-3">
              <div class="score-ring-wrap">
                <svg width="110" height="110" viewBox="0 0 110 110">
                  <circle cx="55" cy="55" r="46" fill="none" stroke="#e2e8f0" stroke-width="9"/>
                  <circle cx="55" cy="55" r="46" fill="none" stroke="url(#ringGrad)" stroke-width="9"
                    stroke-dasharray="289" stroke-dashoffset="63" stroke-linecap="round"/>
                </svg>
                <div class="score-center">
                  <div class="num">78</div>
                  <div class="out">/100</div>
                </div>
              </div>
              <div>
                <div style="font-size:14px;font-weight:700;">Progression positive!</div>
                <div style="font-size:12px;color:var(--text-muted);line-height:1.4">+12 points depuis la semaine dernière.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mood Tracker + Book Appointment -->
    <div class="row g-3 mb-3">
      <!-- Mood Tracker -->
      <div class="col-lg-6">
        <div class="gm-card">
          <div class="gm-card-header">
            <span class="gm-card-title"><i class="bi bi-emoji-smile-fill me-2" style="color:#f59e0b"></i>Check-in de l'humeur</span>
          </div>
          <div class="gm-card-body">
            <div class="mood-grid">
              <div class="mood-btn"><div class="emoji">😣</div><div class="label">Triste</div></div>
              <div class="mood-btn"><div class="emoji">😔</div><div class="label">Bof</div></div>
              <div class="mood-btn"><div class="emoji">😐</div><div class="label">Neutre</div></div>
              <div class="mood-btn selected"><div class="emoji">😊</div><div class="label">Bien</div></div>
              <div class="mood-btn"><div class="emoji">🤩</div><div class="label">Génial!</div></div>
            </div>
            <div class="mood-history mt-4">
              <div class="mood-bar" style="background:#16c784;height:65%"></div>
              <div class="mood-bar" style="background:#1e88e5;height:45%"></div>
              <div class="mood-bar" style="background:#9333ea;height:80%"></div>
              <div class="mood-bar" style="background:#f59e0b;height:70%"></div>
              <div class="mood-bar" style="background:#16c784;height:90%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Book Appointment -->
      <div class="col-lg-6" id="bookSection">
        <div class="gm-card h-100">
           <div class="gm-card-header mb-3">
             <span class="gm-card-title"><i class="bi bi-calendar2-plus-fill me-2" style="color:var(--blue)"></i>Prendre rendez-vous</span>
           </div>
           <div class="gm-card-body">
             <div class="mb-3">
                <label class="gm-label">Médecin</label>
                <select class="gm-input">
                  <option>Dr. Layla Mansour</option>
                  <option>Dr. Nadia Benali</option>
                </select>
             </div>
             <button class="btn-gm-primary w-100" style="justify-content:center; padding: 12px;">
                <i class="bi bi-calendar-check-fill"></i> Rechercher une disponibilité
             </button>
           </div>
        </div>
      </div>
    </div>
{% endblock %}