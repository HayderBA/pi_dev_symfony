{% extends 'base.html.twig' %}

{% block title %}Patient Dashboard - GrowMind{% endblock %}

{% block stylesheets %}
{{ parent() }}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Fraunces:wght@600;700&display=swap" rel="stylesheet">

<style>
:root {
  --green: #16c784;
  --green-light: #e8faf3;
  --green-dark: #0fa36a;
  --blue: #1e88e5;
  --blue-light: #e3f2fd;
  --blue-dark: #1565c0;
  --sidebar-bg: #0d1b2a;
  --sidebar-text: #94a3b8;
  --body-bg: #f0f4f8;
  --card-bg: #ffffff;
  --text-primary: #1a2332;
  --text-muted: #64748b;
  --border: #e2e8f0;
  --shadow: 0 4px 24px rgba(0,0,0,0.07);
  --radius: 16px;
  --sidebar-width: 260px;
  --topbar-h: 68px;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'DM Sans', sans-serif; background: var(--body-bg); color: var(--text-primary); min-height: 100vh; overflow-x: hidden; }

.sidebar { position: fixed; top: 0; left: 0; width: var(--sidebar-width); height: 100vh; background: var(--sidebar-bg); display: flex; flex-direction: column; z-index: 1000; transition: transform .3s ease; }
.sidebar-brand { display: flex; align-items: center; gap: 10px; padding: 24px 24px 20px; border-bottom: 1px solid rgba(255,255,255,.06); }
.brand-icon { width: 38px; height: 38px; border-radius: 10px; background: linear-gradient(135deg, var(--green), var(--blue)); display: flex; align-items: center; justify-content: center; font-size: 18px; color: #fff; flex-shrink: 0; }
.brand-name { font-family: 'Fraunces', serif; font-size: 20px; font-weight: 700; color: #fff; line-height: 1; }
.brand-tag { font-size: 10px; color: var(--green); letter-spacing: .5px; font-weight: 500; }
.sidebar-nav { flex: 1; padding: 20px 16px; overflow-y: auto; }
.nav-label { font-size: 10px; font-weight: 600; letter-spacing: 1.2px; color: rgba(255,255,255,.25); text-transform: uppercase; padding: 16px 10px 8px; display: block; }
.sidebar-nav .nav-link { display: flex; align-items: center; gap: 12px; padding: 11px 14px; border-radius: 10px; color: var(--sidebar-text); font-size: 14px; font-weight: 500; transition: all .2s; margin-bottom: 2px; text-decoration: none; }
.sidebar-nav .nav-link i { font-size: 17px; flex-shrink: 0; }
.sidebar-nav .nav-link:hover { background: rgba(255,255,255,.06); color: #fff; }
.sidebar-nav .nav-link.active { background: linear-gradient(135deg, rgba(22,199,132,.2), rgba(30,136,229,.15)); color: #fff; border: 1px solid rgba(22,199,132,.25); }
.sidebar-nav .nav-link.active i { color: var(--green); }
.nav-badge { margin-left: auto; background: var(--green); color: #fff; font-size: 10px; font-weight: 700; padding: 1px 7px; border-radius: 20px; }
.sidebar-footer { padding: 16px; border-top: 1px solid rgba(255,255,255,.06); }
.sidebar-footer .nav-link { display: flex; align-items: center; gap: 10px; color: var(--sidebar-text); font-size: 13px; padding: 10px 14px; border-radius: 10px; text-decoration: none; transition: all .2s; }
.sidebar-footer .nav-link:hover { background: rgba(255,255,255,.06); color: #fff; }

.main-wrap { margin-left: var(--sidebar-width); min-height: 100vh; }

.topbar { position: sticky; top: 0; z-index: 900; height: var(--topbar-h); background: rgba(255,255,255,.92); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); display: flex; align-items: center; padding: 0 28px; gap: 16px; }
.topbar-title { font-size: 17px; font-weight: 600; flex: 1; }
.topbar-actions { display: flex; align-items: center; gap: 8px; }
.icon-btn { width: 38px; height: 38px; border-radius: 10px; background: var(--body-bg); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; color: var(--text-muted); cursor: pointer; font-size: 16px; transition: all .2s; position: relative; }
.icon-btn:hover { background: var(--green-light); color: var(--green); border-color: var(--green); }
.notif-dot { position: absolute; top: 7px; right: 7px; width: 7px; height: 7px; border-radius: 50%; background: #ef4444; border: 1px solid #fff; }
.avatar-sm { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, var(--green), var(--blue)); display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 13px; cursor: pointer; }
.role-badge { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; background: var(--green-light); color: var(--green-dark); }

.page-content { padding: 28px; }

/* Welcome card */
.welcome-card {
  background: linear-gradient(135deg, #0d1b2a 0%, #1a3a5c 60%, rgba(22,199,132,.3) 100%);
  border-radius: var(--radius); padding: 32px; margin-bottom: 24px; color: #fff; position: relative; overflow: hidden;
}
.welcome-card::before { content: ''; position: absolute; top: -50px; right: -50px; width: 220px; height: 220px; border-radius: 50%; background: rgba(22,199,132,.12); }
.welcome-card::after { content: ''; position: absolute; bottom: -20px; right: 100px; width: 110px; height: 110px; border-radius: 50%; background: rgba(30,136,229,.12); }
.welcome-inner { position: relative; z-index: 1; }
.welcome-inner h2 { font-family: 'Fraunces', serif; font-size: 24px; font-weight: 700; margin-bottom: 6px; }
.welcome-inner p { font-size: 13.5px; opacity: .75; max-width: 480px; line-height: 1.6; margin-bottom: 20px; }
.streak-pill { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.2); border-radius: 30px; padding: 8px 16px; font-size: 13px; font-weight: 600; margin-bottom: 20px; }
.streak-pill i { color: #f59e0b; }
.next-appt-chip { display: inline-flex; align-items: center; gap: 10px; background: rgba(22,199,132,.18); border: 1px solid rgba(22,199,132,.35); border-radius: 12px; padding: 12px 16px; }
.next-appt-chip .chip-icon { width: 36px; height: 36px; border-radius: 10px; background: var(--green); display: flex; align-items: center; justify-content: center; font-size: 16px; }
.next-appt-chip .chip-text .label { font-size: 10.5px; opacity: .7; font-weight: 500; }
.next-appt-chip .chip-text .value { font-size: 13.5px; font-weight: 700; }

.gm-card { background: var(--card-bg); border-radius: var(--radius); box-shadow: var(--shadow); border: 1px solid var(--border); overflow: hidden; }
.gm-card-header { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px 0; }
.gm-card-title { font-size: 15px; font-weight: 600; }
.gm-card-body { padding: 20px 24px 24px; }

/* Appointment cards */
.appt-card { border: 1.5px solid var(--border); border-radius: 14px; padding: 18px; transition: all .25s; display: flex; gap: 14px; align-items: flex-start; }
.appt-card:hover { border-color: var(--green); transform: translateY(-2px); box-shadow: 0 8px 30px rgba(22,199,132,.12); }
.appt-date-box { min-width: 54px; text-align: center; background: var(--body-bg); border-radius: 10px; padding: 10px 6px; }
.appt-date-box .day { font-size: 22px; font-weight: 700; color: var(--text-primary); line-height: 1; }
.appt-date-box .mon { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; }
.appt-details { flex: 1; }
.appt-details .doc-name { font-size: 14.5px; font-weight: 600; margin-bottom: 3px; }
.appt-details .specialty { font-size: 12.5px; color: var(--text-muted); margin-bottom: 8px; }
.appt-meta { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
.chip { display: inline-flex; align-items: center; gap: 5px; font-size: 11.5px; font-weight: 600; padding: 4px 10px; border-radius: 20px; }
.chip-green { background: var(--green-light); color: var(--green-dark); }
.chip-blue { background: var(--blue-light); color: var(--blue-dark); }
.chip-gray { background: var(--body-bg); color: var(--text-muted); border: 1px solid var(--border); }
.appt-actions { display: flex; flex-direction: column; gap: 6px; }

.btn-gm-primary { background: linear-gradient(135deg, var(--green), var(--green-dark)); color: #fff; border: none; border-radius: 10px; font-size: 13.5px; font-weight: 600; padding: 9px 20px; cursor: pointer; transition: all .2s; display: inline-flex; align-items: center; gap: 6px; font-family: 'DM Sans', sans-serif; }
.btn-gm-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(22,199,132,.35); }
.btn-gm-blue { background: linear-gradient(135deg, var(--blue), var(--blue-dark)); color: #fff; border: none; border-radius: 10px; font-size: 13.5px; font-weight: 600; padding: 9px 20px; cursor: pointer; transition: all .2s; display: inline-flex; align-items: center; gap: 6px; font-family: 'DM Sans', sans-serif; }
.btn-gm-blue:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(30,136,229,.35); }
.btn-gm-outline { background: transparent; border: 1.5px solid var(--border); color: var(--text-muted); border-radius: 10px; font-size: 13px; font-weight: 500; padding: 8px 16px; cursor: pointer; transition: all .2s; font-family: 'DM Sans', sans-serif; }
.btn-gm-outline:hover { border-color: var(--green); color: var(--green); }
.btn-icon-sm { width: 30px; height: 30px; border-radius: 8px; border: 1px solid var(--border); background: var(--body-bg); display: inline-flex; align-items: center; justify-content: center; color: var(--text-muted); font-size: 13px; cursor: pointer; transition: all .2s; }
.btn-icon-sm:hover { background: var(--green-light); color: var(--green); border-color: var(--green); }

/* Mood Tracker */
.mood-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; margin-bottom: 20px; }
.mood-btn { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 14px 8px; border-radius: 14px; border: 2px solid var(--border); cursor: pointer; transition: all .2s; background: var(--card-bg); }
.mood-btn:hover { border-color: var(--green); transform: translateY(-2px); }
.mood-btn.selected { border-color: var(--green); background: var(--green-light); }
.mood-btn .emoji { font-size: 26px; }
.mood-btn .label { font-size: 11px; font-weight: 600; color: var(--text-muted); }
.mood-btn.selected .label { color: var(--green-dark); }

.mood-history { display: flex; align-items: flex-end; gap: 4px; height: 60px; padding-top: 8px; }
.mood-bar { flex: 1; border-radius: 6px 6px 0 0; transition: height .5s ease; }
.mood-labels { display: flex; gap: 4px; }
.mood-label { flex: 1; text-align: center; font-size: 9.5px; color: var(--text-muted); font-weight: 500; }

/* Wellness Cards */
.wellness-card { border-radius: 14px; padding: 18px; border: 1.5px solid var(--border); transition: all .25s; cursor: pointer; background: var(--card-bg); display: flex; gap: 14px; align-items: flex-start; }
.wellness-card:hover { border-color: var(--green); transform: translateY(-2px); box-shadow: 0 8px 30px rgba(22,199,132,.1); }
.wellness-icon { width: 46px; height: 46px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
.wellness-title { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
.wellness-desc { font-size: 12.5px; color: var(--text-muted); line-height: 1.5; }
.wellness-badge { font-size: 10.5px; font-weight: 600; padding: 2px 8px; border-radius: 20px; margin-top: 8px; display: inline-block; }

/* Form */
.book-form { background: var(--body-bg); border-radius: 12px; padding: 20px; }
.gm-input { width: 100%; padding: 10px 14px; border: 1.5px solid var(--border); border-radius: 10px; font-size: 13.5px; font-family: 'DM Sans', sans-serif; outline: none; transition: border-color .2s; background: #fff; }
.gm-input:focus { border-color: var(--green); }
.gm-label { font-size: 12.5px; font-weight: 600; color: var(--text-muted); margin-bottom: 6px; display: block; }

/* Stats mini */
.mini-stat { text-align: center; padding: 14px; border-radius: 12px; background: var(--body-bg); }
.mini-stat .val { font-size: 22px; font-weight: 700; }
.mini-stat .lbl { font-size: 11px; color: var(--text-muted); font-weight: 500; margin-top: 2px; }

/* Wellbeing score ring */
.score-ring-wrap { position: relative; width: 110px; height: 110px; flex-shrink: 0; }
.score-ring-wrap svg { transform: rotate(-90deg); }
.score-center { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.score-center .num { font-size: 26px; font-weight: 700; font-family: 'Fraunces', serif; color: var(--text-primary); }
.score-center .out { font-size: 11px; color: var(--text-muted); }

.sidebar-toggle { display: none; background: none; border: none; font-size: 22px; color: var(--text-primary); cursor: pointer; }
::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }

@media (max-width: 991px) {
  .sidebar { transform: translateX(-100%); }
  .sidebar.open { transform: translateX(0); }
  .main-wrap { margin-left: 0; }
  .sidebar-toggle { display: block; }
  .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.4); z-index: 999; }
  .sidebar-overlay.open { display: block; }
}
@media (max-width: 575px) { .page-content { padding: 16px; } .mood-grid { grid-template-columns: repeat(5,1fr); } }
</style>
{% endblock %}

