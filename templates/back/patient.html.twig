                <div class="appt-actions">
                  <button class="btn-gm-primary" style="padding:7px 14px;font-size:12px;"><i class="bi bi-geo-alt-fill"></i> Directions</button>
                  <button class="btn-gm-outline" style="padding:6px 12px;font-size:11.5px;">Cancel</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Wellbeing Score -->
      <div class="col-lg-5">
        <div class="gm-card h-100">
          <div class="gm-card-header">
            <span class="gm-card-title"><i class="bi bi-heart-pulse-fill me-2" style="color:#ef4444"></i>Wellbeing Score</span>
            <span style="font-size:12px;color:var(--text-muted)">This week</span>
          </div>
          <div class="gm-card-body">
            <div class="d-flex align-items-center gap-3 mb-3">
              <div class="score-ring-wrap">
                <svg width="110" height="110" viewBox="0 0 110 110">
                  <circle cx="55" cy="55" r="46" fill="none" stroke="#e2e8f0" stroke-width="9"/>
                  <circle cx="55" cy="55" r="46" fill="none" stroke="url(#ringGrad)" stroke-width="9"
                    stroke-dasharray="289" stroke-dashoffset="{{ (100 - wellnessScore|default(78)) * 2.89 }}" stroke-linecap="round"/>
                  <defs>
                    <linearGradient id="ringGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                      <stop offset="0%" stop-color="#16c784"/>
                      <stop offset="100%" stop-color="#1e88e5"/>
                    </linearGradient>
                  </defs>
                </svg>
                <div class="score-center">
                  <div class="num">{{ wellnessScore|default('78') }}</div>
                  <div class="out">/100</div>
                </div>
              </div>
              <div style="flex:1">
                <div style="font-size:16px;font-weight:700;margin-bottom:4px;">Good Progress!</div>
                <div style="font-size:13px;color:var(--text-muted);line-height:1.5;margin-bottom:10px">Up 12 points from last week. Keep maintaining your routines.</div>
                <div class="d-flex gap-2 flex-wrap">
                  <span class="chip chip-green"><i class="bi bi-arrow-up-short"></i>+12 pts</span>
                  <span class="chip chip-gray">Rank: Good</span>
                </div>
              </div>
            </div>
            <div class="d-flex flex-column gap-2">
              <div>
                <div class="d-flex justify-content-between mb-1"><span style="font-size:12.5px;font-weight:500">Sleep Quality</span><span style="font-size:12px;color:var(--green);font-weight:700">{{ wellnessBreakdown.sleep|default('82') }}%</span></div>
                <div style="height:5px;background:var(--body-bg);border-radius:10px;overflow:hidden"><div style="height:100%;width:{{ wellnessBreakdown.sleep|default(82) }}%;background:linear-gradient(90deg,var(--green),#22d3ee);border-radius:10px;"></div></div>
              </div>
              <div>
                <div class="d-flex justify-content-between mb-1"><span style="font-size:12.5px;font-weight:500">Anxiety Level</span><span style="font-size:12px;color:var(--blue);font-weight:700">{{ wellnessBreakdown.anxiety|default('65') }}%</span></div>
                <div style="height:5px;background:var(--body-bg);border-radius:10px;overflow:hidden"><div style="height:100%;width:{{ wellnessBreakdown.anxiety|default(65) }}%;background:linear-gradient(90deg,var(--blue),#6366f1);border-radius:10px;"></div></div>
              </div>
              <div>
                <div class="d-flex justify-content-between mb-1"><span style="font-size:12.5px;font-weight:500">Social Connection</span><span style="font-size:12px;color:#9333ea;font-weight:700">{{ wellnessBreakdown.social|default('74') }}%</span></div>
                <div style="height:5px;background:var(--body-bg);border-radius:10px;overflow:hidden"><div style="height:100%;width:{{ wellnessBreakdown.social|default(74) }}%;background:linear-gradient(90deg,#9333ea,#e879f9);border-radius:10px;"></div></div>
              </div>
              <div>
                <div class="d-flex justify-content-between mb-1"><span style="font-size:12.5px;font-weight:500">Physical Activity</span><span style="font-size:12px;color:#f59e0b;font-weight:700">{{ wellnessBreakdown.activity|default('88') }}%</span></div>
                <div style="height:5px;background:var(--body-bg);border-radius:10px;overflow:hidden"><div style="height:100%;width:{{ wellnessBreakdown.activity|default(88) }}%;background:linear-gradient(90deg,#f59e0b,#f97316);border-radius:10px;"></div></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mood Tracker + Book Appointment -->
    <div class="row g-3 mb-3">
      <!-- Mood Tracker -->
      <div class="col-lg-6">
        <div class="gm-card">
          <div class="gm-card-header">
            <span class="gm-card-title"><i class="bi bi-emoji-smile-fill me-2" style="color:#f59e0b"></i>Today's Mood Check-In</span>
            <span style="font-size:11.5px;color:var(--text-muted);font-weight:600" id="moodDate"></span>
          </div>
          <div class="gm-card-body">
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px">How are you feeling right now? Be honest with yourself 💙</p>
            <div class="mood-grid">
              <div class="mood-btn" onclick="selectMood(this, 'Terrible')"><div class="emoji">😣</div><div class="label">Terrible</div></div>
              <div class="mood-btn" onclick="selectMood(this, 'Bad')"><div class="emoji">😔</div><div class="label">Bad</div></div>
              <div class="mood-btn" onclick="selectMood(this, 'Okay')"><div class="emoji">😐</div><div class="label">Okay</div></div>
              <div class="mood-btn selected" onclick="selectMood(this, 'Good')"><div class="emoji">😊</div><div class="label">Good</div></div>
              <div class="mood-btn" onclick="selectMood(this, 'Great')"><div class="emoji">🤩</div><div class="label">Great</div></div>
            </div>
            <div id="moodMsg" style="background:var(--green-light);border-left:3px solid var(--green);border-radius:8px;padding:10px 14px;font-size:13px;color:var(--green-dark);font-weight:500;margin-bottom:16px;">
              😊 Glad you're feeling good today! That's progress worth celebrating.
            </div>
            <textarea style="width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:13px;font-family:'DM Sans',sans-serif;outline:none;resize:vertical;background:var(--body-bg);" rows="2" placeholder="Any thoughts to capture? (optional)…"></textarea>
            <button class="btn-gm-primary mt-3 w-100" style="justify-content:center;"><i class="bi bi-check-circle-fill"></i> Log My Mood</button>

            <!-- Mood history -->
            <div style="margin-top:20px;">
              <div style="font-size:12.5px;font-weight:600;color:var(--text-muted);margin-bottom:10px">This Week's Mood History</div>
              <div class="mood-history">
                {% set moodData = moodHistory|default([45, 70, 35, 80, 90, 65, 75]) %}
                {% for pct in moodData %}
                <div class="mood-bar" style="background:linear-gradient(180deg,#16c784,#0fa36a);height:{{ pct }}%"></div>
                {% endfor %}
              </div>
              <div class="mood-labels mt-1">
                <span class="mood-label">Mon</span>
                <span class="mood-label">Tue</span>
                <span class="mood-label">Wed</span>
                <span class="mood-label">Thu</span>
                <span class="mood-label">Fri</span>
                <span class="mood-label">Sat</span>
                <span class="mood-label">Sun</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Book Appointment -->
      <div class="col-lg-6" id="bookSection">
        <div class="gm-card">
          <div class="gm-card-header">
            <span class="gm-card-title"><i class="bi bi-calendar2-plus-fill me-2" style="color:var(--blue)"></i>Book an Appointment</span>
          </div>
          <div class="gm-card-body">
            <div class="book-form">
              <div class="mb-3">
                <label class="gm-label">Select Doctor</label>
                <select class="gm-input">
                  <option value="""</option>
                  
                  <option>Dr. Layla Mansour – Psychiatrist</option>
                  <option>Dr. Nadia Benali – Psychologist</option>
                  <option>Dr. Karim Youssef – Therapist</option>
                  <option>Dr. Amira Soltani – CBT Specialist</option>
                  
                </select>
              </div>
              <div class="row g-2 mb-3">
                <div class="col-6">
                  <label class="gm-label">Date</label>
                  <input type="date" class="gm-input" value="">
                </div>
                <div class="col-6">
                  <label class="gm-label">Time</label>
                  <select class="gm-input">
                    <option>9:00 AM</option>
                    <option>10:00 AM</option>
                    <option>11:30 AM</option>
                    <option>2:00 PM</option>
                    <option>3:30 PM</option>
                    <option>5:00 PM</option>
                  </select>
                </div>
              </div>
              <div class="mb-3">
                <label class="gm-label">Session Type</label>
                <div class="d-flex gap-2">
                  <label style="flex:1;display:flex;align-items:center;gap:6px;padding:10px 12px;border:1.5px solid var(--green);border-radius:10px;cursor:pointer;font-size:13px;font-weight:500;background:var(--green-light);">
                    <input type="radio" name="stype" checked style="accent-color:var(--green)"> <i class="bi bi-camera-video" style="color:var(--green)"></i> Video
                  </label>
                  <label style="flex:1;display:flex;align-items:center;gap:6px;padding:10px 12px;border:1.5px solid var(--border);border-radius:10px;cursor:pointer;font-size:13px;font-weight:500;">
                    <input type="radio" name="stype" style="accent-color:var(--green)"> <i class="bi bi-building"></i> In-Person
                  </label>
                </div>
              </div>
              <div class="mb-3">
                <label class="gm-label">Reason for Visit</label>
                <select class="gm-input">
                  <option>Anxiety Management</option>
                  <option>Depression Support</option>
                  <option>Stress Counseling</option>
                  <option>Follow-up Session</option>
                  <option>Initial Consultation</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="gm-label">Additional Notes</label>
                <textarea class="gm-input" rows="2" placeholder="Any specific concerns or topics to discuss?"></textarea>
              </div>
              <div class="mb-3">
                <label class="gm-label">Session Duration</label>
                <div class="d-flex gap-2">
                  <button class="btn-gm-outline" style="flex:1;font-size:12px;padding:8px 6px;">30 min</button>
                  <button class="btn-gm-primary" style="flex:1;font-size:12px;padding:8px 6px;justify-content:center;">45 min</button>
                  <button class="btn-gm-outline" style="flex:1;font-size:12px;padding:8px 6px;">60 min</button>
                </div>
              </div>
              <button class="btn-gm-primary w-100" style="justify-content:center;padding:12px;font-size:14px;">
                <i class="bi bi-calendar-check-fill"></i> Confirm Booking
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Wellness Suggestions -->
    <div class="gm-card">
      <div class="gm-card-header">
        <span class="gm-card-title"><i class="bi bi-stars me-2" style="color:#f59e0b"></i>Wellness Suggestions For You</span>
        <button class="btn-gm-outline" style="font-size:12px;padding:7px 14px;">View All</button>
      </div>
      <div class="gm-card-body">
        <div class="row g-3">
          <div class="col-md-6 col-xl-3">
            <div class="wellness-card">
              <div class="wellness-icon" style="background:#fff7ed;color:#ea580c"><i class="bi bi-moon-stars-fill"></i></div>
              <div>
                <div class="wellness-title">Sleep Hygiene</div>
                <div class="wellness-desc">Establish a calming bedtime routine. Aim for 7–9 hours of quality sleep each night.</div>
                <span class="wellness-badge" style="background:#fff7ed;color:#c2410c">10 min read</span>
              </div>
            </div>
          </div>
          <div class="col-md-6 col-xl-3">
            <div class="wellness-card">
              <div class="wellness-icon" style="background:var(--green-light);color:var(--green-dark)"><i class="bi bi-wind"></i></div>
              <div>
                <div class="wellness-title">Breathing Exercise</div>
                <div class="wellness-desc">Try the 4-7-8 breathing technique to calm anxiety and promote relaxation instantly.</div>
                <span class="wellness-badge" style="background:var(--green-light);color:var(--green-dark)">5 min exercise</span>
              </div>
            </div>
          </div>
          <div class="col-md-6 col-xl-3">
            <div class="wellness-card">
              <div class="wellness-icon" style="background:var(--blue-light);color:var(--blue-dark)"><i class="bi bi-journal-heart"></i></div>
              <div>
                <div class="wellness-title">Gratitude Journaling</div>
                <div class="wellness-desc">Write 3 things you're grateful for each morning to shift your mindset toward positivity.</div>
                <span class="wellness-badge" style="background:var(--blue-light);color:var(--blue-dark)">Daily habit</span>
              </div>
            </div>
          </div>
          <div class="col-md-6 col-xl-3">
            <div class="wellness-card">
              <div class="wellness-icon" style="background:#f3e8ff;color:#9333ea"><i class="bi bi-flower1"></i></div>
              <div>
                <div class="wellness-title">Mindfulness Meditation</div>
                <div class="wellness-desc">A guided 10-minute body scan meditation to ground yourself and reduce stress levels.</div>
                <span class="wellness-badge" style="background:#f3e8ff;color:#7c3aed">10 min session</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </main>
</div>


{% endblock %}
{% block javascripts %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  document.getElementById('moodDate').textContent = new Date().toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric' });

  function toggleSidebar() {
    document.getElementById('sidebar').classList.toggle('open');
    document.getElementById('overlay').classList.toggle('open');
  }

  const moodMessages = {
    'Terrible': { msg: '😣 I\'m sorry you\'re feeling terrible. Remember, it\'s okay to have hard days. Your doctor is here to help.', bg: '#fef2f2', border: '#dc2626', color: '#991b1b' },
    'Bad':      { msg: '😔 Feeling down is hard. Be gentle with yourself today. Consider reaching out to Dr. Mansour.', bg: '#fff7ed', border: '#f97316', color: '#9a3412' },
    'Okay':     { msg: '😐 A neutral day is a stable day. Small steps forward still count as progress!', bg: '#fefce8', border: '#ca8a04', color: '#713f12' },
    'Good':     { msg: '😊 Glad you\'re feeling good today! That\'s progress worth celebrating.', bg: '#e8faf3', border: '#16c784', color: '#0fa36a' },
    'Great':    { msg: '🤩 Wonderful! You\'re thriving today. Keep building on this positive energy!', bg: '#e8faf3', border: '#16c784', color: '#0fa36a' },
  };

  function selectMood(el, mood) {
    document.querySelectorAll('.mood-btn').forEach(b => b.classList.remove('selected'));
    el.classList.add('selected');
    const m = moodMessages[mood];
    const box = document.getElementById('moodMsg');
    box.textContent = m.msg;
    box.style.background = m.bg;
    box.style.borderLeftColor = m.border;
    box.style.color = m.color;
  }
</script>
{% endblock %}