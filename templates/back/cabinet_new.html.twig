{% extends 'back/admin_layout.html.twig' %}

{% block admin_menu_active %}cabinet{% endblock %}

{% block admin_html_title %}Nouveau cabinet{% endblock %}
{% block admin_topbar_title %}Nouveau cabinet{% endblock %}

{% block admin_content %}
<div class="page-header-admin">
    <h1><i class="bi bi-plus-circle me-2"></i>Ajouter un cabinet</h1>
    <p>Renseignez les informations du cabinet. Les champs sont validés côté serveur (validation Symfony).</p>
</div>

<div class="gm-card admin-crud-card" style="max-width: 820px;">
    <div class="gm-card-body">
        {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
        {{ form_errors(form) }}
        {% for child in form %}
            {{ form_row(child) }}
        {% endfor %}
        <div class="mt-4 d-flex gap-2 flex-wrap">
            <button type="submit" class="btn-gm-primary"><i class="bi bi-check2"></i> Enregistrer</button>
            <a href="{{ path('admin_cabinet_index') }}" class="btn-gm-outline">Annuler</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
