{% extends 'back/admin_layout.html.twig' %}

{% block admin_menu_active %}cabinet{% endblock %}
{% block admin_html_title %}Détail du cabinet{% endblock %}
{% block admin_topbar_title %}{{ cabinet.nomcabinet }}{% endblock %}

{% block admin_content %}
<div class="page-header-admin">
    <h1><i class="bi bi-building me-2"></i>{{ cabinet.nomcabinet }}</h1>
    <p>Fiche détaillée</p>
</div>

<div class="gm-card admin-crud-card" style="max-width: 720px;">
    <div class="gm-card-body">
        <p><strong>Nom :</strong> {{ cabinet.nomcabinet }}</p>
        <p><strong>Adresse :</strong> {{ cabinet.adresse }}</p>
        <p><strong>Ville :</strong> {{ cabinet.ville }}</p>
        <p><strong>Téléphone :</strong> {{ cabinet.telephone }}</p>
        <p><strong>Email :</strong> {{ cabinet.email }}</p>
        <p><strong>Description :</strong> {{ cabinet.description }}</p>
        <p><strong>Statut :</strong> {{ cabinet.status }}</p>
        <div class="mt-4 d-flex gap-2 flex-wrap">
            <a href="{{ path('admin_cabinet_edit', {id: cabinet.idCabinet}) }}" class="btn-gm-primary"><i class="bi bi-pencil"></i> Modifier</a>
            <a href="{{ path('admin_cabinet_index') }}" class="btn-gm-outline">Retour à la liste</a>
        </div>
    </div>
</div>
{% endblock %}
