{% extends 'base.html.twig' %}

{% block title %}Modifier - {{ evenement.titre }}{% endblock %}

{% block body %}
<div class="admin-header">
    <div class="container">
        <div class="admin-header-content">
            <div class="admin-breadcrumb">
                <a href="{{ path('app_home') }}">Accueil</a>
                <i class="fas fa-chevron-right"></i>
                <a href="{{ path('app_evenement_admin') }}">Administration</a>
                <i class="fas fa-chevron-right"></i>
                <span>Modifier</span>
            </div>
            <div class="admin-title-section">
                <div class="admin-icon">
                    <i class="fas fa-pencil-alt"></i>
                </div>
                <div>
                    <h1>Modifier l'événement</h1>
                    <p>{{ evenement.titre }}</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="admin-container">
    <div class="container">
        <div class="form-card">
            {{ form_start(form, {'attr': {'class': 'modern-form'}}) }}
            
            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.titre, 'Titre de l\'événement *', {'label_attr': {'class': 'form-label'}}) }}
                    <div class="input-wrapper">
                        {{ form_widget(form.titre, {'attr': {'class': 'form-control-modern'}}) }}
                        <div class="error-message">Le titre est obligatoire</div>
                        <div class="status-icon"></div>
                    </div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.description, 'Description *', {'label_attr': {'class': 'form-label'}}) }}
                    <div class="input-wrapper">
                        {{ form_widget(form.description, {'attr': {'class': 'form-control-modern textarea', 'rows': 5}}) }}
                        <div class="error-message">La description est obligatoire</div>
                        <div class="status-icon"></div>
                    </div>
                </div>
            </div>

            <div class="form-row grid-2">
                <div class="form-group">
                    {{ form_label(form.date, 'Date et heure *', {'label_attr': {'class': 'form-label'}}) }}
                    <div class="input-wrapper">
                        {{ form_widget(form.date, {'attr': {'class': 'form-control-modern', 'id': 'date-input'}}) }}
                        <div class="error-message">La date est obligatoire et doit être aujourd'hui ou dans le futur</div>
                        <div class="status-icon"></div>
                    </div>
                </div>
                <div class="form-group">
                    {{ form_label(form.localisation, 'Lieu *', {'label_attr': {'class': 'form-label'}}) }}
                    <div class="input-wrapper">
                        {{ form_widget(form.localisation, {'attr': {'class': 'form-control-modern'}}) }}
                        <div class="error-message">Le lieu est obligatoire</div>
                        <div class="status-icon"></div>
                    </div>
                </div>
            </div>

            <div class="form-row grid-2">
                <div class="form-group">
                    {{ form_label(form.maxCapacity, 'Capacité maximale *', {'label_attr': {'class': 'form-label'}}) }}
                    <div class="input-wrapper">
                        {{ form_widget(form.maxCapacity, {'attr': {'class': 'form-control-modern', 'min': 1}}) }}
                        <div class="error-message">La capacité doit être positive</div>
                        <div class="status-icon"></div>
                    </div>
                </div>
                <div class="form-group">
                    {{ form_label(form.basePrice, 'Prix de base (€)', {'label_attr': {'class': 'form-label'}}) }}
                    <div class="input-wrapper">
                        {{ form_widget(form.basePrice, {'attr': {'class': 'form-control-modern', 'min': 0, 'step': 1}}) }}
                        <div class="status-icon"></div>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">
                    <i class="fas fa-save"></i> Enregistrer les modifications
                </button>
                <a href="{{ path('app_evenement_admin') }}" class="btn-cancel">
                    <i class="fas fa-times"></i> Annuler
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>

<style>
    .admin-header {
        background: linear-gradient(135deg, #0b3b3f 0%, #1a6d6b 50%, #2a9d8f 100%);
        padding: 40px 0;
        color: white;
    }
    .admin-breadcrumb {
        font-size: 0.85rem;
        margin-bottom: 20px;
    }
    .admin-breadcrumb a {
        color: rgba(255,255,255,0.7);
        text-decoration: none;
    }
    .admin-breadcrumb i {
        margin: 0 8px;
        font-size: 0.7rem;
    }
    .admin-title-section {
        display: flex;
        align-items: center;
        gap: 20px;
    }
    .admin-icon {
        width: 60px;
        height: 60px;
        background: rgba(255,255,255,0.2);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
    }
    .admin-title-section h1 {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 5px;
    }
    .admin-title-section p {
        opacity: 0.8;
        margin: 0;
    }
    .admin-container {
        padding: 40px 0 60px;
        background: #f5f7fc;
        min-height: calc(100vh - 250px);
    }
    .form-card {
        max-width: 800px;
        margin: 0 auto;
        background: white;
        border-radius: 28px;
        padding: 40px;
        box-shadow: 0 8px 28px rgba(0,0,0,0.05);
    }
    .modern-form .form-row {
        margin-bottom: 24px;
    }
    .modern-form .grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    .form-label {
        display: block;
        font-weight: 600;
        color: #0b3b3f;
        margin-bottom: 8px;
        font-size: 0.9rem;
    }
    .input-wrapper {
        position: relative;
    }
    .status-icon {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        width: 24px;
        height: 24px;
        opacity: 0;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
    }
    .input-wrapper .form-control-modern.valid ~ .status-icon {
        opacity: 1;
        color: #06d6a0;
    }
    .input-wrapper .form-control-modern.error ~ .status-icon {
        opacity: 1;
        color: #ef476f;
    }
    .error-message {
        color: #ef476f;
        font-size: 0.7rem;
        margin-top: 5px;
        margin-left: 10px;
        display: none;
    }
    .form-control-modern {
        width: 100%;
        padding: 14px 18px;
        padding-right: 50px;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        font-size: 0.95rem;
        transition: all 0.3s;
    }
    .form-control-modern:focus {
        border-color: #2a9d8f;
        outline: none;
        box-shadow: 0 0 0 3px rgba(42,157,143,0.1);
    }
    .form-control-modern.textarea {
        border-radius: 20px;
        resize: vertical;
    }
    .form-actions {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #e2e8f0;
    }
    .btn-submit {
        flex: 1;
        background: linear-gradient(135deg, #f59e0b, #d97706);
        border: none;
        padding: 14px;
        border-radius: 40px;
        color: white;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s;
    }
    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(245,158,11,0.3);
    }
    .btn-cancel {
        flex: 1;
        background: transparent;
        border: 2px solid #e2e8f0;
        padding: 12px;
        border-radius: 40px;
        text-align: center;
        text-decoration: none;
        color: #64748b;
        font-weight: 500;
        transition: all 0.3s;
    }
    .btn-cancel:hover {
        border-color: #ef476f;
        color: #ef476f;
    }
    @media (max-width: 768px) {
        .form-card { padding: 24px; }
        .modern-form .grid-2 { grid-template-columns: 1fr; gap: 0; }
        .form-actions { flex-direction: column; }
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Set minimum date to today
    const dateInput = document.getElementById('date-input');
    if (dateInput) {
        const today = new Date();
        const year = today.getFullYear();
        const month = String(today.getMonth() + 1).padStart(2, '0');
        const day = String(today.getDate()).padStart(2, '0');
        dateInput.min = `${year}-${month}-${day}`;
    }

    const form = document.querySelector('.modern-form');
    const inputs = document.querySelectorAll('.form-control-modern');

    inputs.forEach(input => {
        // Validation on input
        input.addEventListener('input', function() {
            validateField(this);
        });
        
        // Validation on blur
        input.addEventListener('blur', function() {
            validateField(this);
        });
    });

    // Form submit validation
    if (form) {
        form.addEventListener('submit', function(event) {
            let isFormValid = true;

            inputs.forEach(input => {
                if (!validateField(input)) {
                    isFormValid = false;
                }
            });

            if (!isFormValid) {
                event.preventDefault();
                // Show alert message
                alert('⚠️ Veuillez remplir correctement tous les champs obligatoires');
            }
        });
    }
    
    function validateField(field) {
        const wrapper = field.closest('.input-wrapper');
        const errorMsg = wrapper.querySelector('.error-message');
        
        let isValid = false;
        
        // Check if required and has value
        if (field.hasAttribute('required')) {
            if (field.value.trim() === '') {
                isValid = false;
            } else if (field.type === 'email') {
                // Email validation
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                isValid = emailRegex.test(field.value);
            } else if (field.type === 'tel') {
                // Phone validation (at least 9 digits)
                const phoneRegex = /^\d{9,}$/;
                isValid = phoneRegex.test(field.value.replace(/\D/g, ''));
            } else if (field.name.includes('maxCapacity')) {
                // Number validation - must be positive
                isValid = field.value && !isNaN(field.value) && Number(field.value) > 0;
            } else if (field.name.includes('date')) {
                // Date validation - must be today or future
                const selectedDate = new Date(field.value);
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                isValid = field.value.trim() !== '' && selectedDate >= today;
            } else {
                // Text validation - at least 2 characters
                isValid = field.value.trim().length >= 2;
            }
        } else {
            // Optional fields
            if (field.value.trim() === '') {
                isValid = true;
            } else if (field.type === 'email') {
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                isValid = emailRegex.test(field.value);
            } else {
                isValid = field.value.trim().length >= 2;
            }
        }
        
        // Update UI
        if (isValid) {
            field.classList.remove('error');
            field.classList.add('valid');
            if (errorMsg) errorMsg.style.display = 'none';
        } else if (field.value.trim() !== '') {
            field.classList.remove('valid');
            field.classList.add('error');
            if (errorMsg) errorMsg.style.display = 'block';
        } else {
            field.classList.remove('valid', 'error');
            if (errorMsg) errorMsg.style.display = 'none';
        }
        
        return isValid;
    }
});
</script>
{% endblock %}