{% extends 'back/base_back.html.twig' %}

{% block title %}Gestion des Rendez-vous{% endblock %}

{% block admin_content %}
  <div class="page-header">
    <div class="page-header-content">
      <h1>Rendez-vous</h1>
      <p>Suivi des reservations de cabinets et consultations avec les psychologues lies aux medecins.</p>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-3"><div class="stat-card"><div class="stat-value">{{ stats.total }}</div><div class="stat-label">Total</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-value">{{ stats.a_venir }}</div><div class="stat-label">A venir</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-value">{{ stats.aujourdhui }}</div><div class="stat-label">Aujourd hui</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-value">{{ stats.by_statut.confirme|default(0) }}</div><div class="stat-label">Confirmes</div></div></div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-lg-7">
      <div class="gm-card h-100">
        <div class="gm-card-header"><span class="gm-card-title">Workflow de rappel</span></div>
        <div class="gm-card-body">
          <div class="d-flex flex-wrap gap-2 mb-3">
            <span class="badge bg-primary">GET {{ workflow.api_url }}</span>
            <span class="badge bg-success">{{ workflow.pending_tomorrow }} rappel(s) a envoyer demain</span>
          </div>
          <p class="text-muted small">Cette API est prete pour n8n. Le workflow peut lire les rendez-vous de demain puis appeler l'endpoint de marquage ou d'envoi.</p>
          <div class="small text-muted mb-2">Prochains rendez-vous</div>
          {% for next in workflow.next_rendezvous %}
            <div class="d-flex justify-content-between border rounded-3 px-3 py-2 mb-2">
              <span>#{{ next.idRdv }} {{ next.prenomPatient }} {{ next.nomPatient }}</span>
              <strong>{{ next.dateRdv|date('d/m') }} {{ next.heure|date('H:i') }}</strong>
            </div>
          {% else %}
            <div class="text-muted">Aucun rendez-vous planifie.</div>
          {% endfor %}
        </div>
      </div>
    </div>
    <div class="col-lg-5">
      <div class="gm-card h-100">
        <div class="gm-card-header"><span class="gm-card-title">Canaux actifs</span></div>
        <div class="gm-card-body">
          <ul class="small text-muted mb-0">
            <li>mail automatique a la creation de demande</li>
            <li>mail de mise a jour sur confirmation/annulation</li>
            <li>rappel manuel depuis le back</li>
            <li>paiement Stripe a activer via `STRIPE_PUBLIC_KEY` et `STRIPE_SECRET_KEY`</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="gm-card mb-4">
    <div class="gm-card-header"><span class="gm-card-title">Filtres</span></div>
    <div class="gm-card-body">
      <form method="get" class="row g-3 align-items-end">
        <div class="col-md-4"><label class="form-label">Recherche</label><input type="text" name="q" value="{{ filters.q }}" class="form-control" placeholder="Patient, email, cabinet, psy"></div>
        <div class="col-md-2"><label class="form-label">Statut</label><select name="statut" class="form-select"><option value="">Tous</option><option value="en_attente" {{ filters.statut == 'en_attente' ? 'selected' }}>En attente</option><option value="confirme" {{ filters.statut == 'confirme' ? 'selected' }}>Confirme</option><option value="annule" {{ filters.statut == 'annule' ? 'selected' }}>Annule</option></select></div>
        <div class="col-md-2"><label class="form-label">Du</label><input type="date" name="date_from" value="{{ filters.date_from }}" class="form-control"></div>
        <div class="col-md-2"><label class="form-label">Au</label><input type="date" name="date_to" value="{{ filters.date_to }}" class="form-control"></div>
        <div class="col-md-1"><label class="form-label">Tri</label><select name="sort" class="form-select"><option value="date" {{ filters.sort == 'date' ? 'selected' }}>Date</option><option value="statut" {{ filters.sort == 'statut' ? 'selected' }}>Statut</option><option value="heure" {{ filters.sort == 'heure' ? 'selected' }}>Heure</option></select></div>
        <div class="col-md-1"><label class="form-label">Ordre</label><select name="dir" class="form-select"><option value="desc" {{ filters.dir == 'desc' ? 'selected' }}>Desc</option><option value="asc" {{ filters.dir == 'asc' ? 'selected' }}>Asc</option></select></div>
        <div class="col-12 d-flex gap-2"><button class="btn btn-primary">Appliquer</button><a href="{{ path('admin_rendezvous_index') }}" class="btn btn-outline-secondary">Reinitialiser</a></div>
      </form>
    </div>
  </div>

  <div class="gm-card">
    <div class="gm-card-header">
      <span class="gm-card-title">Liste des rendez-vous</span>
      <a href="{{ path('admin_rendezvous_new') }}" class="btn-gm-primary text-decoration-none">Nouveau rendez-vous</a>
    </div>
    <div class="gm-card-body">
      {% for message in app.flashes('success') %}<div class="alert alert-success">{{ message }}</div>{% endfor %}
      {% for message in app.flashes('error') %}<div class="alert alert-danger">{{ message }}</div>{% endfor %}
      <div class="table-responsive">
        <table class="table align-middle">
          <thead><tr><th>Patient</th><th>Psy / Cabinet</th><th>Date</th><th>Type</th><th>Statut</th><th>Paiement</th><th>Actions</th></tr></thead>
          <tbody>
            {% for rdv in rendezvous %}
              <tr>
                <td><strong>{{ rdv.prenomPatient }} {{ rdv.nomPatient }}</strong><br><small class="text-muted">{{ rdv.emailPatient }} - {{ rdv.telephonePatient }}</small></td>
                <td>{{ rdv.psychologue.displayName }}<br><small class="text-muted">{{ rdv.psychologue.cabinet ? rdv.psychologue.cabinet.nomcabinet : '-' }}</small></td>
                <td>{{ rdv.dateRdv ? rdv.dateRdv|date('d/m/Y') : '-' }}<br><small class="text-muted">{{ rdv.heure ? rdv.heure|date('H:i') : '-' }}</small></td>
                <td>{{ rdv.typeCons }}</td>
                <td><span class="badge {{ rdv.statut == 'confirme' ? 'bg-success' : (rdv.statut == 'annule' ? 'bg-danger' : 'bg-warning text-dark') }}">{{ rdv.statut }}</span></td>
                <td><span class="badge {{ rdv.estPaye ? 'bg-primary' : 'bg-secondary' }}">{{ rdv.estPaye ? 'Paye' : 'Non paye' }}</span>{% if rdv.tarifConsultation %}<br><small class="text-muted">{{ rdv.tarifConsultation }} TND</small>{% endif %}</td>
                <td class="d-flex gap-1 flex-wrap">
                  <a href="{{ path('admin_rendezvous_show', {id: rdv.idRdv}) }}" class="btn btn-outline-info btn-sm">Voir</a>
                  <a href="{{ path('admin_rendezvous_edit', {id: rdv.idRdv}) }}" class="btn btn-outline-warning btn-sm">Modifier</a>
                  <a href="{{ path('admin_rendezvous_confirm', {id: rdv.idRdv}) }}" class="btn btn-outline-success btn-sm">Confirmer</a>
                  <a href="{{ path('admin_rendezvous_cancel', {id: rdv.idRdv}) }}" class="btn btn-outline-danger btn-sm">Annuler</a>
                  <a href="{{ path('admin_rendezvous_reminder', {id: rdv.idRdv}) }}" class="btn btn-outline-primary btn-sm">Rappel</a>
                </td>
              </tr>
            {% else %}
              <tr><td colspan="7" class="text-muted">Aucun rendez-vous trouve.</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% if rendezvous.paginationData is defined %}
        <div class="mt-3">{{ knp_pagination_render(rendezvous) }}</div>
      {% endif %}
    </div>
  </div>
{% endblock %}
