{% extends 'back/admin_layout.html.twig' %}

{% block admin_menu_active %}rendezvous{% endblock %}

{% block admin_html_title %}Modifier le rendez-vous{% endblock %}
{% block admin_topbar_title %}Modifier le rendez-vous{% endblock %}

{% block admin_content %}
<div class="page-header-admin">
    <h1><i class="bi bi-pencil-square me-2"></i>Modifier le rendez-vous</h1>
    <p>{{ rdv.prenomPatient }} {{ rdv.nomPatient }} — {{ rdv.dateRdv|date('d/m/Y') }}</p>
</div>

<div class="gm-card admin-crud-card" style="max-width: 820px;">
    <div class="gm-card-body">
        <p class="text-muted small mb-3"><strong>Patient :</strong> {{ rdv.prenomPatient }} {{ rdv.nomPatient }} — {{ rdv.emailPatient }} — {{ rdv.telephonePatient }}</p>
        {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
        {{ form_errors(form) }}
        {% for child in form %}
            {{ form_row(child) }}
        {% endfor %}
        <div class="mt-4 d-flex gap-2 flex-wrap">
            <button type="submit" class="btn-gm-primary"><i class="bi bi-check2"></i> Enregistrer</button>
            <a href="{{ path('admin_rendezvous_index') }}" class="btn-gm-outline">Retour</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
