{% extends 'back/admin_layout.html.twig' %}

{% block title %}Administration - Événements{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="{{ asset('assets/css/voice-assistant.css') }}" rel="stylesheet">
{% endblock %}

{% block admin_topbar_title %}Gestion des evenements{% endblock %}
{% block admin_menu_active %}evenements{% endblock %}

{% block admin_content %}
<div class="admin-header">
    <div class="container">
        <div class="admin-header-content">
            <div class="admin-breadcrumb">
                <a href="{{ path('app_home') }}">Accueil</a>
                <i class="fas fa-chevron-right"></i>
                <span>Administration</span>
            </div>
            <div class="admin-title-section">
                <div class="admin-icon">
                    <i class="fas fa-calendar-alt"></i>
                </div>
                <div>
                    <h1>Gestion des événements</h1>
                    <p>Créez, modifiez et gérez tous vos ateliers et séances</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="admin-container">
    <div class="container">
        <section class="gm-voice-box mb-4" data-voice-event-admin>
            <div class="gm-voice-top">
                <div>
                    <h3>Commande vocale Evenements</h3>
                    <p>Dites une commande metier et GrowMind execute l action dans la gestion des evenements.</p>
                </div>
                <button type="button" class="gm-voice-toggle" data-voice-toggle aria-pressed="false" title="Activer la voix">
                    <i class="fas fa-microphone"></i>
                </button>
            </div>
            <p class="gm-voice-status" data-voice-status>Le micro reste actif jusqu a la commande stop. Essayez une commande simple ci-dessous.</p>
            <div class="gm-voice-help">
                <span class="gm-voice-chip">Nouvel evenement</span>
                <span class="gm-voice-chip">Voir statistiques</span>
                <span class="gm-voice-chip">Fais PDF</span>
                <span class="gm-voice-chip">Chercher atelier</span>
                <span class="gm-voice-chip">Reset</span>
                <span class="gm-voice-chip">Voir a venir</span>
                <span class="gm-voice-chip">Trier par popularite</span>
                <span class="gm-voice-chip">Voir front</span>
                <span class="gm-voice-chip">Ouvrir premier evenement</span>
                <span class="gm-voice-chip">Modifier premier evenement</span>
                <span class="gm-voice-chip">Stop</span>
            </div>
        </section>

        <!-- Statistiques Dashboard -->
        <div class="stats-grid">
            <div class="stat-card-mini">
                <div class="stat-icon-mini"><i class="fas fa-calendar-week"></i></div>
                <div class="stat-info">
                    <span class="stat-value-mini">{{ evenements|length }}</span>
                    <span class="stat-label-mini">Total événements</span>
                </div>
            </div>
            <div class="stat-card-mini">
                <div class="stat-icon-mini"><i class="fas fa-clock"></i></div>
                <div class="stat-info">
                    <span class="stat-value-mini">{{ evenements|filter(e => e.status == 'À venir')|length }}</span>
                    <span class="stat-label-mini">À venir</span>
                </div>
            </div>
            <div class="stat-card-mini">
                <div class="stat-icon-mini"><i class="fas fa-chart-line"></i></div>
                <div class="stat-info">
                    <span class="stat-value-mini">
                        {% set totalReservations = 0 %}
                        {% for e in evenements %}
                            {% set totalReservations = totalReservations + e.currentReservationsCount %}
                        {% endfor %}
                        {{ totalReservations }}
                    </span>
                    <span class="stat-label-mini">Total réservations</span>
                </div>
            </div>
            <div class="stat-card-mini">
                <div class="stat-icon-mini"><i class="fas fa-chart-pie"></i></div>
                <div class="stat-info">
                    <span class="stat-value-mini">
                        {% set taux = 0 %}
                        {% if evenements|length > 0 %}
                            {% set totalCap = 0 %}
                            {% set totalOcc = 0 %}
                            {% for e in evenements %}
                                {% set totalCap = totalCap + e.maxCapacity %}
                                {% set totalOcc = totalOcc + e.currentReservationsCount %}
                            {% endfor %}
                            {% set taux = (totalOcc / totalCap) * 100 %}
                        {% endif %}
                        {{ taux|round(1) }}%
                    </span>
                    <span class="stat-label-mini">Taux d'occupation</span>
                </div>
            </div>
        </div>

        <!-- Filtres et Actions -->
        <div class="filters-bar">
            <div class="filters-group">
                <div class="filter-item">
                    <i class="fas fa-search"></i>
                    <input type="text" id="searchInput" placeholder="Rechercher un événement...">
                </div>
                <div class="filter-item">
                    <i class="fas fa-filter"></i>
                    <select id="statusFilter">
                        <option value="all">Tous les statuts</option>
                        <option value="À venir">À venir</option>
                        <option value="Aujourd'hui">Aujourd'hui</option>
                        <option value="Passé">Passé</option>
                    </select>
                </div>
                <div class="filter-item">
                    <i class="fas fa-sort-amount-down"></i>
                    <select id="sortFilter">
                        <option value="date_asc">Date (plus récent)</option>
                        <option value="date_desc">Date (plus ancien)</option>
                        <option value="titre_asc">Titre (A-Z)</option>
                        <option value="titre_desc">Titre (Z-A)</option>
                        <option value="reservations">Popularité</option>
                    </select>
                </div>
            </div>
            <div class="actions-group">
                <a href="{{ path('app_evenement_stats') }}" class="btn-stats" id="eventVoiceStats">
                    <i class="fas fa-chart-pie"></i> Statistiques
                </a>
                <button class="btn-export" id="exportPdfBtn">
                    <i class="fas fa-file-pdf"></i> Export PDF
                </button>
                <a href="{{ path('app_evenement_new') }}" class="btn-new-event" id="eventVoiceNew">
                    <i class="fas fa-plus"></i> Nouvel événement
                </a>
            </div>
        </div>

        <!-- Tableau des événements -->
        <div class="admin-table-card">
            <div class="table-header">
                <div class="table-title">
                    <i class="fas fa-list"></i> Liste des événements
                </div>
                <div class="table-info">
                    <span id="resultCount">{{ evenements|length }}</span> événements affichés
                </div>
            </div>
            <div class="table-responsive">
                <table class="admin-table" id="eventsTable">
                    <thead>
                        <tr>
                            <th>Titre</th>
                            <th>Date</th>
                            <th>Lieu</th>
                            <th>Places</th>
                            <th>Réservations</th>
                            <th>Billet solidaire</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        {% for evenement in evenements %}
                        <tr class="event-row" data-title="{{ evenement.titre|lower }}" data-status="{{ evenement.status }}" data-date="{{ evenement.date|date('Y-m-d') }}" data-reservations="{{ evenement.currentReservationsCount }}">
                            <td class="event-title-cell">
                                <div class="event-title-wrapper">
                                    <div class="event-icon-small"><i class="fas fa-spa"></i></div>
                                    <span>{{ evenement.titre }}</span>
                                </div>
                            </td>
                            <td data-sort="{{ evenement.date|date('Y-m-d') }}">{{ evenement.date|date('d/m/Y') }}</td>
                            <td>{{ evenement.localisation|slice(0, 25) }}</td>
                            <td>
                                <div class="capacity-indicator">
                                    <div class="capacity-bar-small">
                                        <div class="capacity-fill-small" style="width: {{ (evenement.currentReservationsCount / evenement.maxCapacity) * 100 }}%"></div>
                                    </div>
                                    <span>{{ evenement.currentReservationsCount }}/{{ evenement.maxCapacity }}</span>
                                </div>
                            </td>
                            <td>
                                <span class="booking-count">{{ evenement.currentReservationsCount }}</span>
                            </td>
                            <td>
                                {% if evenement.solidarityReservationsCount > 0 %}
                                    <div class="solidarity-cell">
                                        <span class="solidarity-chip">{{ evenement.solidarityReservationsCount }} don{{ evenement.solidarityReservationsCount > 1 ? 's' : '' }}</span>
                                        <small>{{ evenement.solidarityAmountCollected|number_format(2, ',', ' ') }} TND</small>
                                    </div>
                                {% else %}
                                    <span class="solidarity-empty">Aucun</span>
                                {% endif %}
                            </td>
                            <td>
                                <span class="status-badge status-{{ evenement.status == 'À venir' ? 'upcoming' : (evenement.status == 'Aujourd\'hui' ? 'today' : 'past') }}">
                                    {{ evenement.status }}
                                </span>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a href="{{ path('app_evenement_show_admin', {'id': evenement.id}) }}" class="action-btn view-btn" title="Voir" data-event-show>
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_evenement_edit', {'id': evenement.id}) }}" class="action-btn edit-btn" title="Modifier" data-event-edit>
                                        <i class="fas fa-pencil-alt"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_evenement_delete', {'id': evenement.id}) }}" style="display: inline-block;" onsubmit="return confirm('⚠️ Supprimer cet événement ? Toutes les réservations seront également supprimées.')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evenement.id) }}">
                                        <button type="submit" class="action-btn delete-btn" title="Supprimer" data-event-delete>
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="8" class="empty-table">
                                <i class="fas fa-calendar-times"></i>
                                <p>Aucun événement trouvé</p>
                                <a href="{{ path('app_evenement_new') }}" class="btn-new-small">Créer le premier événement</a>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="admin-footer-links">
            <a href="{{ path('app_evenement_list') }}" class="footer-link">
                <i class="fas fa-arrow-left"></i> Retour au site
            </a>
        </div>
    </div>
</div>

