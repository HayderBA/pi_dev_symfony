{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard - GrowMind{% endblock %}

{% block stylesheets %}
{{ parent() }}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Fraunces:wght@600;700&display=swap" rel="stylesheet">

<style>
:root {
  --green: #16c784;
  --green-light: #e8faf3;
  --green-dark: #0fa36a;
  --blue: #1e88e5;
  --blue-light: #e3f2fd;
  --blue-dark: #1565c0;
  --sidebar-bg: #0d1b2a;
  --sidebar-text: #94a3b8;
  --sidebar-active: #ffffff;
  --body-bg: #f0f4f8;
  --card-bg: #ffffff;
  --text-primary: #1a2332;
  --text-muted: #64748b;
  --border: #e2e8f0;
  --shadow: 0 4px 24px rgba(0,0,0,0.07);
  --radius: 16px;
  --sidebar-width: 260px;
  --topbar-h: 68px;
  --gm-control-height: 3.25rem;
  --gm-control-radius: 1rem;
  --gm-control-padding-y: 0.85rem;
  --gm-control-padding-x: 1rem;
  --gm-control-bg: rgba(255,255,255,.96);
  --gm-control-bg-focus: #fff;
  --gm-control-border: rgba(148,163,184,.28);
  --gm-control-focus: var(--green);
  --gm-control-ring: rgba(22,199,132,.18);
  --gm-control-text: var(--text-primary);
  --gm-control-placeholder: var(--text-muted);
  --gm-control-label: var(--text-muted);
  --gm-control-shadow: inset 0 1px 1px rgba(255,255,255,.72);
  --gm-control-transition: border-color .18s ease, box-shadow .18s ease, background-color .18s ease, transform .18s ease;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--body-bg);
  color: var(--text-primary);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── SIDEBAR ── */
.sidebar {
  position: fixed; top: 0; left: 0;
  width: var(--sidebar-width);
  height: 100vh;
  background: var(--sidebar-bg);
  display: flex; flex-direction: column;
  z-index: 1000;
  transition: transform .3s ease;
}
.sidebar-brand {
  display: flex; align-items: center; gap: 10px;
  padding: 24px 24px 20px;
  border-bottom: 1px solid rgba(255,255,255,.06);
}
.brand-icon {
  width: 38px; height: 38px; border-radius: 10px;
  background: linear-gradient(135deg, var(--green), var(--blue));
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; color: #fff; flex-shrink: 0;
}
.brand-name {
  font-family: 'Fraunces', serif;
  font-size: 20px; font-weight: 700; color: #fff; line-height: 1;
}
.brand-tag { font-size: 10px; color: var(--green); letter-spacing: .5px; font-weight: 500; }

.sidebar-nav { flex: 1; padding: 20px 16px; overflow-y: auto; }
.nav-label {
  font-size: 10px; font-weight: 600; letter-spacing: 1.2px;
  color: rgba(255,255,255,.25); text-transform: uppercase;
  padding: 16px 10px 8px; display: block;
}
.sidebar-nav .nav-link {
  display: flex; align-items: center; gap: 12px;
  padding: 11px 14px; border-radius: 10px;
  color: var(--sidebar-text); font-size: 14px; font-weight: 500;
  transition: all .2s; margin-bottom: 2px; text-decoration: none;
}
.sidebar-nav .nav-link i { font-size: 17px; flex-shrink: 0; }
.sidebar-nav .nav-link:hover { background: rgba(255,255,255,.06); color: #fff; }
.sidebar-nav .nav-link.active {
  background: linear-gradient(135deg, rgba(22,199,132,.2), rgba(30,136,229,.15));
  color: #fff; border: 1px solid rgba(22,199,132,.25);
}
.sidebar-nav .nav-link.active i { color: var(--green); }
.nav-badge {
  margin-left: auto; background: var(--green);
  color: #fff; font-size: 10px; font-weight: 700;
  padding: 1px 7px; border-radius: 20px;
}
.sidebar-footer {
  padding: 16px; border-top: 1px solid rgba(255,255,255,.06);
}
.sidebar-footer .nav-link {
  display: flex; align-items: center; gap: 10px;
  color: var(--sidebar-text); font-size: 13px; padding: 10px 14px;
  border-radius: 10px; text-decoration: none; transition: all .2s;
}
.sidebar-footer .nav-link:hover { background: rgba(255,255,255,.06); color: #fff; }

/* ── MAIN ── */
.main-wrap {
  margin-left: var(--sidebar-width);
  min-height: 100vh;
  transition: margin .3s ease;
}

/* ── TOPBAR ── */
.topbar {
  position: sticky; top: 0; z-index: 900;
  height: var(--topbar-h);
  background: rgba(255,255,255,.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center;
  padding: 0 28px; gap: 16px;
}
.topbar-title { font-size: 17px; font-weight: 600; flex: 1; }
.topbar-search { position: relative; width: 280px; }
.topbar-search input {
  width: 100%;
  min-height: 2.9rem;
  padding: .72rem 1rem .72rem 2.6rem;
  background: var(--gm-control-bg);
  border: 1px solid var(--gm-control-border);
  border-radius: .95rem;
  font-size: .92rem;
  font-family: 'DM Sans', sans-serif;
  color: var(--gm-control-text);
  outline: none;
  box-shadow: var(--gm-control-shadow);
  transition: var(--gm-control-transition);
}
.topbar-search input:focus {
  border-color: var(--gm-control-focus);
  box-shadow: 0 0 0 .25rem var(--gm-control-ring);
  background: var(--gm-control-bg-focus);
}
.topbar-search i { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); color: var(--text-muted); }

.gm-input {
  width: 100%;
  min-height: var(--gm-control-height);
  padding: var(--gm-control-padding-y) var(--gm-control-padding-x);
  border: 1px solid var(--gm-control-border);
  border-radius: var(--gm-control-radius);
  background: var(--gm-control-bg);
  color: var(--gm-control-text);
  font-size: .98rem;
  font-family: 'DM Sans', sans-serif;
  outline: none;
  box-shadow: var(--gm-control-shadow);
  transition: var(--gm-control-transition);
}
.gm-input:focus {
  border-color: var(--gm-control-focus);
  box-shadow: 0 0 0 .25rem var(--gm-control-ring);
  background: var(--gm-control-bg-focus);
}
.gm-input-compact {
  min-height: 2.9rem;
  padding: .72rem .95rem;
  border-radius: .95rem;
  font-size: .92rem;
}

.topbar-actions { display: flex; align-items: center; gap: 8px; }
.icon-btn {
  width: 38px; height: 38px; border-radius: 10px;
  background: var(--body-bg); border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  color: var(--text-muted); cursor: pointer; font-size: 16px;
  transition: all .2s; text-decoration: none; position: relative;
}
.icon-btn:hover { background: var(--green-light); color: var(--green); border-color: var(--green); }
.notif-dot {
  position: absolute; top: 7px; right: 7px;
  width: 7px; height: 7px; border-radius: 50%; background: #ef4444;
  border: 1px solid #fff;
}
.avatar-sm {
  width: 36px; height: 36px; border-radius: 50%;
  background: linear-gradient(135deg, var(--green), var(--blue));
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-weight: 700; font-size: 13px; cursor: pointer;
  flex-shrink: 0;
}
.role-badge {
  font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px;
  background: linear-gradient(135deg, var(--green-light), var(--blue-light));
  color: var(--blue-dark);
}

/* ── PAGE CONTENT ── */
.page-content { padding: 28px; }

/* ── STATS CARDS ── */
.stat-card {
  background: var(--card-bg);
  border-radius: var(--radius); padding: 22px 24px;
  box-shadow: var(--shadow); border: 1px solid var(--border);
  transition: transform .25s, box-shadow .25s;
}
.stat-card:hover { transform: translateY(-3px); box-shadow: 0 10px 40px rgba(0,0,0,.1); }
.stat-icon {
  width: 48px; height: 48px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; margin-bottom: 16px;
}
.stat-icon.green { background: var(--green-light); color: var(--green); }
.stat-icon.blue  { background: var(--blue-light);  color: var(--blue);  }
.stat-icon.purple{ background: #f3e8ff; color: #9333ea; }
.stat-icon.orange{ background: #fff7ed; color: #ea580c; }
.stat-value { font-size: 30px; font-weight: 700; line-height: 1; margin-bottom: 4px; }
.stat-label { font-size: 13px; color: var(--text-muted); font-weight: 500; }
.stat-change {
  display: inline-flex; align-items: center; gap: 3px;
  font-size: 12px; font-weight: 600; margin-top: 10px;
  padding: 3px 8px; border-radius: 20px;
}
.stat-change.up { background: var(--green-light); color: var(--green-dark); }
.stat-change.down { background: #fef2f2; color: #dc2626; }

/* ── CARDS ── */
.gm-card {
  background: var(--card-bg); border-radius: var(--radius);
  box-shadow: var(--shadow); border: 1px solid var(--border); overflow: hidden;
}
.gm-card-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20px 24px 0;
}
.gm-card-title { font-size: 15px; font-weight: 600; }
.gm-card-body { padding: 20px 24px 24px; }

/* ── TABLE ── */
.gm-table { width: 100%; border-collapse: collapse; }
.gm-table th {
  font-size: 11px; font-weight: 700; text-transform: uppercase;
  letter-spacing: .8px; color: var(--text-muted);
  padding: 12px 16px; border-bottom: 1px solid var(--border);
  white-space: nowrap;
}
.gm-table td {
  padding: 14px 16px; font-size: 13.5px;
  border-bottom: 1px solid var(--border); vertical-align: middle;
}
.gm-table tr:last-child td { border-bottom: none; }
.gm-table tbody tr { transition: background .15s; }
.gm-table tbody tr:hover { background: var(--body-bg); }
.user-cell { display: flex; align-items: center; gap: 10px; }
.avatar-xs {
  width: 32px; height: 32px; border-radius: 50%; font-size: 12px; font-weight: 700;
  display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0;
}
.tag { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; }
.tag-doctor  { background: var(--blue-light); color: var(--blue-dark); }
.tag-patient { background: var(--green-light); color: var(--green-dark); }
.tag-admin   { background: #f3e8ff; color: #7c3aed; }
.tag-active  { background: #dcfce7; color: #15803d; }
.tag-inactive{ background: #fef2f2; color: #dc2626; }
.tag-pending { background: #fff7ed; color: #c2410c; }

/* ── CHART BARS ── */
.chart-wrap { position: relative; height: 200px; display: flex; align-items: flex-end; gap: 6px; padding-top: 20px; }
.bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6px; height: 100%; justify-content: flex-end; }
.bar-track { flex: 1; width: 100%; background: var(--body-bg); border-radius: 8px; display: flex; align-items: flex-end; overflow: hidden; }
.bar-fill {
  width: 100%; border-radius: 8px;
  background: linear-gradient(180deg, var(--green), var(--blue));
  transition: height .6s cubic-bezier(.22,1,.36,1);
}
.bar-label { font-size: 11px; color: var(--text-muted); font-weight: 500; }

/* ── APPT TABLE STATUS ── */
.appt-status {
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 20px;
}
.appt-status::before { content: ''; width: 6px; height: 6px; border-radius: 50%; }
.appt-status.confirmed { background: #dcfce7; color: #15803d; }
.appt-status.confirmed::before { background: #15803d; }
.appt-status.pending { background: #fff7ed; color: #c2410c; }
.appt-status.pending::before { background: #ea580c; }
.appt-status.cancelled { background: #fef2f2; color: #dc2626; }
.appt-status.cancelled::before { background: #dc2626; }

/* ── BUTTONS ── */
.btn-gm-primary {
  background: linear-gradient(135deg, var(--green), var(--green-dark));
  color: #fff; border: none; border-radius: 10px;
  font-size: 13.5px; font-weight: 600; padding: 9px 20px;
  cursor: pointer; transition: all .2s; display: inline-flex; align-items: center; gap: 6px;
  font-family: 'DM Sans', sans-serif;
}
.btn-gm-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(22,199,132,.35); }
.btn-gm-outline {
  background: transparent; border: 1.5px solid var(--border); color: var(--text-muted);
  border-radius: 10px; font-size: 13px; font-weight: 500; padding: 8px 16px;
  cursor: pointer; transition: all .2s; font-family: 'DM Sans', sans-serif;
}
.btn-gm-outline:hover { border-color: var(--green); color: var(--green); }
.btn-icon-sm {
  width: 30px; height: 30px; border-radius: 8px; border: 1px solid var(--border);
  background: var(--body-bg); display: inline-flex; align-items: center; justify-content: center;
  color: var(--text-muted); font-size: 13px; cursor: pointer; transition: all .2s;
}
.btn-icon-sm:hover { background: var(--green-light); color: var(--green); border-color: var(--green); }

/* ── GRADIENT HEADER ── */
.page-header {
  background: linear-gradient(135deg, var(--sidebar-bg) 0%, #1a2d45 100%);
  border-radius: var(--radius); padding: 28px 32px; margin-bottom: 24px;
  position: relative; overflow: hidden; color: #fff;
}
.page-header::before {
  content: ''; position: absolute; top: -40px; right: -40px;
  width: 180px; height: 180px; border-radius: 50%;
  background: linear-gradient(135deg, rgba(22,199,132,.25), rgba(30,136,229,.15));
}
.page-header::after {
  content: ''; position: absolute; bottom: -20px; right: 80px;
  width: 100px; height: 100px; border-radius: 50%;
  background: rgba(22,199,132,.1);
}
.page-header-content { position: relative; z-index: 1; }
.page-header h1 { font-family: 'Fraunces', serif; font-size: 24px; font-weight: 700; margin-bottom: 4px; }
.page-header p { font-size: 13.5px; color: rgba(255,255,255,.65); }
.header-time { font-size: 12px; color: rgba(255,255,255,.5); margin-top: 8px; }

/* ── SECTION TITLE ── */
.section-title {
  font-size: 16px; font-weight: 700; margin-bottom: 16px;
  display: flex; align-items: center; gap: 8px;
}
.section-title::before {
  content: ''; display: block; width: 4px; height: 18px;
  border-radius: 4px; background: linear-gradient(var(--green), var(--blue));
}

/* ── MOBILE TOGGLE ── */
.sidebar-toggle {
  display: none; background: none; border: none;
  font-size: 22px; color: var(--text-primary); cursor: pointer;
}

/* ── SCROLLBAR ── */
::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }

/* ── RESPONSIVE ── */
@media (max-width: 991px) {
  .sidebar { transform: translateX(-100%); }
  .sidebar.open { transform: translateX(0); }
  .main-wrap { margin-left: 0; }
  .sidebar-toggle { display: block; }
  .topbar-search { width: 200px; }
  .sidebar-overlay {
    display: none; position: fixed; inset: 0; background: rgba(0,0,0,.4); z-index: 999;
  }
  .sidebar-overlay.open { display: block; }
}
@media (max-width: 575px) {
  .page-content { padding: 16px; }
  .topbar-search { display: none; }
}
</style>
{% endblock %}

{% block body %}

<div class="sidebar-overlay" id="overlay" onclick="toggleSidebar()"></div>

<!-- ── SIDEBAR ── -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-brand">
    <div class="brand-icon"><i class="bi bi-heart-pulse-fill"></i></div>
    <div>
      <div class="brand-name">GrowMind</div>
      <div class="brand-tag">Mental Health Platform</div>
    </div>
  </div>

  <nav class="sidebar-nav">
    <span class="nav-label">Main Menu</span>
    <a href="{{ path('app_admin_dashboard') }}" class="nav-link active"><i class="bi bi-grid-1x2-fill"></i> Dashboard <span class="nav-badge">4</span></a>
    <a href="#" class="nav-link"><i class="bi bi-people-fill"></i> Users</a>
    <a href="#" class="nav-link"><i class="bi bi-person-badge-fill"></i> Doctors</a>
    <a href="#" class="nav-link"><i class="bi bi-calendar2-check-fill"></i> Appointments</a>
    <a href="#" class="nav-link"><i class="bi bi-bar-chart-fill"></i> Analytics</a>
    <span class="nav-label">System</span>
    <a href="#" class="nav-link"><i class="bi bi-bell-fill"></i> Notifications</a>
    <a href="#" class="nav-link"><i class="bi bi-shield-lock-fill"></i> Security</a>
    <a href="#" class="nav-link"><i class="bi bi-gear-fill"></i> Settings</a>
    <span class="nav-label">Role Dashboards</span>
    <a href="{{ path('app_doctor_dashboard') }}" class="nav-link"><i class="bi bi-clipboard2-pulse-fill"></i> Doctor View</a>
    <a href="{{ path('app_patient_dashboard') }}" class="nav-link"><i class="bi bi-person-heart"></i> Patient View</a>
  </nav>

  <div class="sidebar-footer">
    <a href="#" class="nav-link"><i class="bi bi-box-arrow-left"></i> Sign Out</a>
  </div>
</aside>

<!-- ── MAIN ── -->
<div class="main-wrap">

  <!-- Topbar -->
  <header class="topbar">
    <button class="sidebar-toggle" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
    <span class="topbar-title">Admin Dashboard</span>
    <div class="topbar-search">
      <i class="bi bi-search"></i>
      <input type="text" class="gm-input gm-input-compact" placeholder="Search users, appointments..."/>
    </div>
    <div class="topbar-actions">
      <div class="icon-btn" title="Notifications"><i class="bi bi-bell"></i><span class="notif-dot"></span></div>
      <div class="icon-btn" title="Messages"><i class="bi bi-chat-dots"></i></div>
      <span class="role-badge">Admin</span>
      <div class="dropdown">
        <div class="avatar-sm" data-bs-toggle="dropdown">{{ app.user.initials|default('SA') }}</div>
        <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="border-radius:12px; margin-top:8px;">
          <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i>My Profile</a></li>
          <li><a class="dropdown-item" href="#"><i class="bi bi-gear me-2"></i>Settings</a></li>
          <li><hr class="dropdown-divider"></li>
          <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-box-arrow-left me-2"></i>Sign Out</a></li>
        </ul>
      </div>
    </div>
  </header>

  <!-- Content -->
  <main class="page-content">

    <!-- Page Header -->
    <div class="page-header">
      <div class="page-header-content">
        <h1>Welcome back, {{ app.user.firstName|default('Super Admin') }} 👋</h1>
        <p>Here's what's happening across GrowMind today.</p>
        <div class="header-time" id="headerTime"></div>
      </div>
    </div>

    <!-- Stat Cards -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-xl-3">
        <div class="stat-card">
          <div class="stat-icon blue"><i class="bi bi-people-fill"></i></div>
          <div class="stat-value">{{ stats.totalUsers|default('4,821') }}</div>
          <div class="stat-label">Total Users</div>
          <div class="stat-change up"><i class="bi bi-arrow-up-short"></i>12.4% this month</div>
        </div>
      </div>
      <div class="col-6 col-xl-3">
        <div class="stat-card">
          <div class="stat-icon green"><i class="bi bi-person-badge-fill"></i></div>
          <div class="stat-value">{{ stats.activeDoctors|default('138') }}</div>
          <div class="stat-label">Active Doctors</div>
          <div class="stat-change up"><i class="bi bi-arrow-up-short"></i>5 new this week</div>
        </div>
      </div>
      <div class="col-6 col-xl-3">
        <div class="stat-card">
          <div class="stat-icon purple"><i class="bi bi-person-heart"></i></div>
          <div class="stat-value">{{ stats.registeredPatients|default('3,490') }}</div>
          <div class="stat-label">Registered Patients</div>
          <div class="stat-change up"><i class="bi bi-arrow-up-short"></i>8.1% this month</div>
        </div>
      </div>
      <div class="col-6 col-xl-3">
        <div class="stat-card">
          <div class="stat-icon orange"><i class="bi bi-calendar2-check-fill"></i></div>
          <div class="stat-value">{{ stats.appointmentsToday|default('247') }}</div>
          <div class="stat-label">Appointments Today</div>
          <div class="stat-change down"><i class="bi bi-arrow-down-short"></i>3.2% vs yesterday</div>
        </div>
      </div>
    </div>

    <!-- Charts + Quick Stats -->
    <div class="row g-3 mb-4">
      <div class="col-lg-8">
        <div class="gm-card h-100">
          <div class="gm-card-header">
            <span class="gm-card-title">Appointments Overview – Apr 2026</span>
            <div class="d-flex gap-2">
              <button class="btn-gm-outline">Weekly</button>
              <button class="btn-gm-primary">Monthly</button>
            </div>
          </div>
          <div class="gm-card-body">
            <div class="chart-wrap" id="chartWrap"></div>
          </div>
        </div>
      </div>
      <div class="col-lg-4">
        <div class="gm-card h-100">
          <div class="gm-card-header">
            <span class="gm-card-title">Quick Stats</span>
          </div>
          <div class="gm-card-body">
            <div class="mb-3 pb-3 border-bottom">
              <div class="d-flex justify-content-between mb-1">
                <span style="font-size:13px;font-weight:500;">Session Completion Rate</span>
                <span style="font-size:13px;font-weight:700;color:var(--green)">84%</span>
