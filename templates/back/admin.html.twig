{% extends 'back/base_back.html.twig' %}
{% block title %}Admin Dashboard{% endblock %}
{% block admin_content %}


    <!-- Page Header -->
    <div class="page-header">
      <div class="page-header-content">
        <h1>Welcome back, {{ app.user.firstName|default('Super Admin') }} 👋</h1>
        <p>Here's what's happening across GrowMind today.</p>
        <div class="header-time" id="headerTime"></div>
      </div>
    </div>

    <!-- Stat Cards -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-xl-3">
        <div class="stat-card">
          <div class="stat-icon blue"><i class="bi bi-people-fill"></i></div>
          <div class="stat-value">{{ stats.totalUsers|default('4,821') }}</div>
          <div class="stat-label">Total Users</div>
          <div class="stat-change up"><i class="bi bi-arrow-up-short"></i>12.4% this month</div>
        </div>
      </div>
      <div class="col-6 col-xl-3">
        <div class="stat-card">
          <div class="stat-icon green"><i class="bi bi-person-badge-fill"></i></div>
          <div class="stat-value">{{ stats.activeDoctors|default('138') }}</div>
          <div class="stat-label">Active Doctors</div>
          <div class="stat-change up"><i class="bi bi-arrow-up-short"></i>5 new this week</div>
        </div>
      </div>
      <div class="col-6 col-xl-3">
        <div class="stat-card">
          <div class="stat-icon purple"><i class="bi bi-person-heart"></i></div>
          <div class="stat-value">{{ stats.registeredPatients|default('3,490') }}</div>
          <div class="stat-label">Registered Patients</div>
          <div class="stat-change up"><i class="bi bi-arrow-up-short"></i>8.1% this month</div>
        </div>
      </div>
      <div class="col-6 col-xl-3">
        <div class="stat-card">
          <div class="stat-icon orange"><i class="bi bi-calendar2-check-fill"></i></div>
          <div class="stat-value">{{ stats.appointmentsToday|default('247') }}</div>
          <div class="stat-label">Appointments Today</div>
          <div class="stat-change down"><i class="bi bi-arrow-down-short"></i>3.2% vs yesterday</div>
        </div>
      </div>
    </div>

    <!-- Charts + Quick Stats -->
    <div class="row g-3 mb-4">
      <div class="col-lg-8">
        <div class="gm-card h-100">
          <div class="gm-card-header">
            <span class="gm-card-title">Appointments Overview – Apr 2026</span>
            <div class="d-flex gap-2">
              <button class="btn-gm-outline">Weekly</button>
              <button class="btn-gm-primary">Monthly</button>
            </div>
          </div>
          <div class="gm-card-body">
            <div class="chart-wrap" id="chartWrap"></div>
          </div>
        </div>
      </div>
      <div class="col-lg-4">
        <div class="gm-card h-100">
          <div class="gm-card-header">
            <span class="gm-card-title">Quick Stats</span>
          </div>
          <div class="gm-card-body">
            <div class="mb-3 pb-3 border-bottom">
              <div class="d-flex justify-content-between mb-1">
                <span style="font-size:13px;font-weight:500;">Session Completion Rate</span>
                <span style="font-size:13px;font-weight:700;color:var(--green)">84%</span>
              </div>
              <div style="height:6px;background:var(--body-bg);border-radius:10px;overflow:hidden;">
                <div style="height:100%;width:84%;background:linear-gradient(90deg,var(--green),var(--blue));border-radius:10px;"></div>
              </div>
            </div>
            <div class="mb-3 pb-3 border-bottom">
              <div class="d-flex justify-content-between mb-1">
                <span style="font-size:13px;font-weight:500;">Patient Satisfaction</span>
                <span style="font-size:13px;font-weight:700;color:var(--blue)">91%</span>
              </div>
              <div style="height:6px;background:var(--body-bg);border-radius:10px;overflow:hidden;">
                <div style="height:100%;width:91%;background:linear-gradient(90deg,var(--blue),#6366f1);border-radius:10px;"></div>
              </div>
            </div>
            <div class="mb-3 pb-3 border-bottom">
              <div class="d-flex justify-content-between mb-1">
                <span style="font-size:13px;font-weight:500;">Doctor Availability</span>
                <span style="font-size:13px;font-weight:700;color:#9333ea">67%</span>
              </div>
              <div style="height:6px;background:var(--body-bg);border-radius:10px;overflow:hidden;">
                <div style="height:100%;width:67%;background:linear-gradient(90deg,#9333ea,#e879f9);border-radius:10px;"></div>
              </div>
            </div>
            <div class="mb-0">
              <div class="d-flex justify-content-between mb-1">
                <span style="font-size:13px;font-weight:500;">Platform Uptime</span>
                <span style="font-size:13px;font-weight:700;color:#ea580c">99.9%</span>
              </div>
              <div style="height:6px;background:var(--body-bg);border-radius:10px;overflow:hidden;">
                <div style="height:100%;width:99.9%;background:linear-gradient(90deg,#ea580c,#f97316);border-radius:10px;"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Users Table -->
    <div class="row g-3 mb-4">
      <div class="col-12">
        <div class="gm-card">
          <div class="gm-card-header">
            <span class="gm-card-title">User Management</span>
            <div class="d-flex gap-2 align-items-center">
              <input type="text" placeholder="Filter users…" style="padding:7px 14px;border-radius:9px;border:1px solid var(--border);font-size:12.5px;outline:none;font-family:'DM Sans',sans-serif;background:var(--body-bg);">
              <button class="btn-gm-primary"><i class="bi bi-plus-lg"></i> Add User</button>
            </div>
          </div>
          <div class="gm-card-body p-0" style="padding:0!important;">
            <div style="overflow-x:auto;">
              <table class="gm-table">
                <thead>
                  <tr>
                    <th><input type="checkbox" style="width:14px;height:14px;accent-color:var(--green);cursor:pointer;"></th>
                    <th>User</th>
                    <th>Role</th>
                    <th>Email</th>
                    <th>Joined</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  
                  <tr>
                    <td><input type="checkbox" style="width:14px;height:14px;accent-color:var(--green);cursor:pointer;"></td>
                    <td>
                      <div class="user-cell">
                        <div class="avatar-xs" </div>
                        <div>
                          <div style="font-weight:600;font-size:13.5px"></div>
                          <div style="font-size:11.5px;color:var(--text-muted)">ID </div>
                        </div>
                      </div>
                    </td>
                    <td><span class="tag"></span></td>
                    <td style="color:var(--text-muted);font-size:13px"></td>
                    <td style="color:var(--text-muted);font-size:13px"></td>
                    <td><span class="tag"></span></td>
                    <td>
                      <div class="d-flex gap-1">
                        <button class="btn-icon-sm" title="Edit"><i class="bi bi-pencil"></i></button>
                        <button class="btn-icon-sm" title="View"><i class="bi bi-eye"></i></button>
                        <button class="btn-icon-sm" title="Delete" style="color:#ef4444;"><i class="bi bi-trash"></i></button>
                      </div>
                    </td>
                  </tr>
                  {# Fallback static rows when no Twig data is passed #}
                  <tr>
                    <td><input type="checkbox" style="width:14px;height:14px;accent-color:var(--green);cursor:pointer;"></td>
                    <td><div class="user-cell"><div class="avatar-xs" style="background:linear-gradient(135deg,#16c784,#1e88e5)">LM</div><div><div style="font-weight:600;font-size:13.5px">Layla Mansour</div><div style="font-size:11.5px;color:var(--text-muted)">ID #00142</div></div></div></td>
                    <td><span class="tag tag-doctor">Doctor</span></td>
                    <td style="color:var(--text-muted);font-size:13px">layla@growmind.com</td>
                    <td style="color:var(--text-muted);font-size:13px">Jan 12, 2025</td>
                    <td><span class="tag tag-active">Active</span></td>
                    <td><div class="d-flex gap-1"><button class="btn-icon-sm" title="Edit"><i class="bi bi-pencil"></i></button><button class="btn-icon-sm" title="View"><i class="bi bi-eye"></i></button><button class="btn-icon-sm" title="Delete" style="color:#ef4444;"><i class="bi bi-trash"></i></button></div></td>
                  </tr>
                  <tr>
                    <td><input type="checkbox" style="width:14px;height:14px;accent-color:var(--green);cursor:pointer;"></td>
                    <td><div class="user-cell"><div class="avatar-xs" style="background:linear-gradient(135deg,#9333ea,#e879f9)">AK</div><div><div style="font-weight:600;font-size:13.5px">Adam Khalil</div><div style="font-size:11.5px;color:var(--text-muted)">ID #00891</div></div></div></td>
                    <td><span class="tag tag-patient">Patient</span></td>
                    <td style="color:var(--text-muted);font-size:13px">adam@email.com</td>
                    <td style="color:var(--text-muted);font-size:13px">Mar 5, 2025</td>
                    <td><span class="tag tag-active">Active</span></td>
                    <td><div class="d-flex gap-1"><button class="btn-icon-sm"><i class="bi bi-pencil"></i></button><button class="btn-icon-sm"><i class="bi bi-eye"></i></button><button class="btn-icon-sm" style="color:#ef4444;"><i class="bi bi-trash"></i></button></div></td>
                  </tr>
                  <tr>
                    <td><input type="checkbox" style="width:14px;height:14px;accent-color:var(--green);cursor:pointer;"></td>
                    <td><div class="user-cell"><div class="avatar-xs" style="background:linear-gradient(135deg,#ea580c,#f97316)">SR</div><div><div style="font-weight:600;font-size:13.5px">Sara Rahman</div><div style="font-size:11.5px;color:var(--text-muted)">ID #00220</div></div></div></td>
                    <td><span class="tag tag-admin">Admin</span></td>
                    <td style="color:var(--text-muted);font-size:13px">sara@growmind.com</td>
                    <td style="color:var(--text-muted);font-size:13px">Nov 20, 2024</td>
                    <td><span class="tag tag-active">Active</span></td>
                    <td><div class="d-flex gap-1"><button class="btn-icon-sm"><i class="bi bi-pencil"></i></button><button class="btn-icon-sm"><i class="bi bi-eye"></i></button><button class="btn-icon-sm" style="color:#ef4444;"><i class="bi bi-trash"></i></button></div></td>
                  </tr>
                  <tr>
                    <td><input type="checkbox" style="width:14px;height:14px;accent-color:var(--green);cursor:pointer;"></td>
                    <td><div class="user-cell"><div class="avatar-xs" style="background:linear-gradient(135deg,#0891b2,#06b6d4)">JT</div><div><div style="font-weight:600;font-size:13.5px">James Tran</div><div style="font-size:11.5px;color:var(--text-muted)">ID #01034</div></div></div></td>
                    <td><span class="tag tag-patient">Patient</span></td>
                    <td style="color:var(--text-muted);font-size:13px">james@email.com</td>
                    <td style="color:var(--text-muted);font-size:13px">Apr 1, 2026</td>
                    <td><span class="tag tag-pending">Pending</span></td>
                    <td><div class="d-flex gap-1"><button class="btn-icon-sm"><i class="bi bi-pencil"></i></button><button class="btn-icon-sm"><i class="bi bi-eye"></i></button><button class="btn-icon-sm" style="color:#ef4444;"><i class="bi bi-trash"></i></button></div></td>
                  </tr>
                  <tr>
                    <td><input type="checkbox" style="width:14px;height:14px;accent-color:var(--green);cursor:pointer;"></td>
                    <td><div class="user-cell"><div class="avatar-xs" style="background:linear-gradient(135deg,#dc2626,#f87171)">NB</div><div><div style="font-weight:600;font-size:13.5px">Nadia Benali</div><div style="font-size:11.5px;color:var(--text-muted)">ID #00556</div></div></div></td>
                    <td><span class="tag tag-doctor">Doctor</span></td>
                    <td style="color:var(--text-muted);font-size:13px">nadia@growmind.com</td>
                    <td style="color:var(--text-muted);font-size:13px">Feb 14, 2025</td>
                    <td><span class="tag tag-inactive">Inactive</span></td>
                    <td><div class="d-flex gap-1"><button class="btn-icon-sm"><i class="bi bi-pencil"></i></button><button class="btn-icon-sm"><i class="bi bi-eye"></i></button><button class="btn-icon-sm" style="color:#ef4444;"><i class="bi bi-trash"></i></button></div></td>
                  </tr>
                </tbody>
              </table>
            </div>
            <!-- Pagination -->
            <div class="d-flex align-items-center justify-content-between px-4 py-3 border-top">
              <span style="font-size:12.5px;color:var(--text-muted)">Showing 1–5 of {{ stats.totalUsers|default('4,821') }} users</span>
              <div class="d-flex gap-1">
                <button class="btn-icon-sm"><i class="bi bi-chevron-left"></i></button>
                <button class="btn-icon-sm" style="background:var(--green);color:#fff;border-color:var(--green);">1</button>
                <button class="btn-icon-sm">2</button>
                <button class="btn-icon-sm">3</button>
                <span style="font-size:13px;color:var(--text-muted);padding:4px 6px;">…</span>
                <button class="btn-icon-sm">482</button>
                <button class="btn-icon-sm"><i class="bi bi-chevron-right"></i></button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Appointment Management -->
    <div class="row g-3">
      <div class="col-12">
        <div class="gm-card">
          <div class="gm-card-header">
            <span class="gm-card-title">Recent Appointments</span>
            <button class="btn-gm-primary"><i class="bi bi-plus-lg"></i> New Appointment</button>
          </div>
          <div class="gm-card-body p-0" style="padding:0!important;">
            <div style="overflow-x:auto;">
              <table class="gm-table">
                <thead>
                  <tr>
                    <th>Appointment ID</th>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Date & Time</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td style="font-size:12px;color:var(--text-muted);font-weight:600;">#APT-</td>
                    <td><div class="user-cell"><div class="avatar-xs" style="background:linear-gradient(135deg,#9333ea,#e879f9);width:28px;height:28px;font-size:11px"></div></div></td>
                    <td><div class="user-cell"><div class="avatar-xs" style="background:linear-gradient(135deg,#16c784,#1e88e5);width:28px;height:28px;font-size:11px"></div>Dr. </div></td>
                    <td style="font-size:13px"></td>
                    <td><span class="tag" style="background:#e0f2fe;color:#0369a1;font-size:11px"></span></td>
                    <td><span class="appt-status"></span></td>
                    <td><div class="d-flex gap-1"><button class="btn-icon-sm"><i class="bi bi-pencil"></i></button><button class="btn-icon-sm" style="color:#ef4444;"><i class="bi bi-x-lg"></i></button></div></td>
                  </tr>
                  <tr>
                    <td style="font-size:12px;color:var(--text-muted);font-weight:600;">#APT-2642</td>
                    <td><div class="user-cell"><div class="avatar-xs" style="background:linear-gradient(135deg,#9333ea,#e879f9);width:28px;height:28px;font-size:11px">AK</div>Adam Khalil</div></td>
                    <td><div class="user-cell"><div class="avatar-xs" style="background:linear-gradient(135deg,#16c784,#1e88e5);width:28px;height:28px;font-size:11px">LM</div>Dr. Layla Mansour</div></td>
                    <td style="font-size:13px">Apr 7, 2026 · 10:00 AM</td>
                    <td><span class="tag" style="background:#e0f2fe;color:#0369a1;font-size:11px">Video Call</span></td>
                    <td><span class="appt-status confirmed">Confirmed</span></td>
                    <td><div class="d-flex gap-1"><button class="btn-icon-sm"><i class="bi bi-pencil"></i></button><button class="btn-icon-sm" style="color:#ef4444;"><i class="bi bi-x-lg"></i></button></div></td>
                  </tr>
                  <tr>
                    <td style="font-size:12px;color:var(--text-muted);font-weight:600;">#APT-2641</td>
                    <td><div class="user-cell"><div class="avatar-xs" style="background:linear-gradient(135deg,#0891b2,#06b6d4);width:28px;height:28px;font-size:11px">JT</div>James Tran</div></td>
                    <td><div class="user-cell"><div class="avatar-xs" style="background:linear-gradient(135deg,#ea580c,#f97316);width:28px;height:28px;font-size:11px">NB</div>Dr. Nadia Benali</div></td>
                    <td style="font-size:13px">Apr 7, 2026 · 11:30 AM</td>
                    <td><span class="tag" style="background:#f0fdf4;color:#15803d;font-size:11px">In-Person</span></td>
                    <td><span class="appt-status pending">Pending</span></td>
                    <td><div class="d-flex gap-1"><button class="btn-icon-sm"><i class="bi bi-pencil"></i></button><button class="btn-icon-sm" style="color:#ef4444;"><i class="bi bi-x-lg"></i></button></div></td>
                  </tr>
                  <tr>
                    <td style="font-size:12px;color:var(--text-muted);font-weight:600;">#APT-2639</td>
                    <td><div class="user-cell"><div class="avatar-xs" style="background:linear-gradient(135deg,#16c784,#0fa36a);width:28px;height:28px;font-size:11px">SE</div>Sara El-Amin</div></td>
                    <td><div class="user-cell"><div class="avatar-xs" style="background:linear-gradient(135deg,#16c784,#1e88e5);width:28px;height:28px;font-size:11px">LM</div>Dr. Layla Mansour</div></td>
                    <td style="font-size:13px">Apr 6, 2026 · 2:00 PM</td>
                    <td><span class="tag" style="background:#e0f2fe;color:#0369a1;font-size:11px">Video Call</span></td>
