      <div class="col-12">
        <div class="gm-card">
          <div class="gm-card-header">
            <span class="gm-card-title">User Management</span>
            <div class="d-flex gap-2 align-items-center">
              <input type="text" placeholder="Filter users…" style="padding:7px 14px;border-radius:9px;border:1px solid var(--border);font-size:12.5px;outline:none;font-family:'DM Sans',sans-serif;background:var(--body-bg);">
              <a href="{{ path('admin_add_users') }}" class="btn-gm-primary">
                <i class="bi bi-plus-lg"></i> Ajouter
              </a>
              </div>
          </div>
          <div class="gm-card-body p-0" style="padding:0!important">
            <div style="overflow-x:auto">
              <table class="gm-table">
                <thead>
                  <tr >
                    <th><input type="checkbox" style="accent-color:var(--green)"></th>
                    <th>Utilisateur</th>
                    <th>Rôle</th>
                    <th>Email</th>
                    <th>Date de naissance</th>
                    <th>Statut</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {% for user in users %}
                  {%- set initials = (user.name|slice(0,1) ~ user.second_name|slice(0,1))|upper -%}
                  {%- set role = user.role|lower -%}
                  {%- set bgColors = {'doctor':'linear-gradient(135deg,#16c784,#1e88e5)','patient':'linear-gradient(135deg,#9333ea,#e879f9)','admin':'linear-gradient(135deg,#ea580c,#f97316)'} -%}
                  {%- set bg = bgColors[role]|default('linear-gradient(135deg,#64748b,#94a3b8)') -%}

                  <tr class="user-row"
                      data-name="{{ user.name|lower }}"
                      data-fullname="{{ (user.name ~ ' ' ~ user.second_name)|lower }}"
                      data-role="{{ role }}">

                    <td><input type="checkbox" style="accent-color:var(--green)"></td>

                    {# ✅ FIX: user.second_name (camelCase) pas user.second_name #}
                    <td>
                      <div class="user-cell">
                        <div class="avatar-xs" style="background:{{ bg }}">{{ initials }}</div>
                        <div>
                          <div style="font-weight:600;font-size:13.5px">{{ user.name }} {{ user.second_name }}</div>
                          <div style="font-size:11px;color:var(--text-muted)">ID #{{ user.id }}</div>
                        </div>
                      </div>
                    </td>

                    <td><span class="tag tag-{{ role }}">{{ user.role|capitalize }}</span></td>

                    <td style="color:var(--text-muted);font-size:13px">{{ user.email }}</td>

                    <td style="color:var(--text-muted);font-size:13px">
                      {{ user.birthDate ? user.birthDate : 'N/A' }}
                    </td>

                    <td>
                      <span class="tag {{ user.isBlocked ? 'tag-inactive' : 'tag-active' }}">
                        {{ user.isBlocked ? 'Bloqué' : 'Actif' }}
                      </span>
                    </td>

                    <td>
                      <div class="d-flex gap-1">
                        <a href="{{ path('admin_edit_user', {id: user.id}) }}" class="btn-icon-sm" title="Modifier">
                          <i class="bi bi-pencil"></i>
                        </a>
                        <a href="{{ path('admin_toggle_block', {id: user.id}) }}" class="btn-icon-sm"
                           title="{{ user.isBlocked ? 'Débloquer' : 'Bloquer' }}"
                           onclick="return confirm('{{ user.isBlocked ? 'Débloquer' : 'Bloquer' }} cet utilisateur ?')">
                          <i class="bi bi-{{ user.isBlocked ? 'unlock' : 'lock' }}-fill"
                             style="color:{{ user.isBlocked ? '#15803d' : '#f97316' }}"></i>
                        </a>
                        <a href="{{ path('admin_rm_users', {id: user.id}) }}" class="btn-icon-sm"
                           title="Supprimer"
                           onclick="return confirm('Supprimer {{ user.name }} {{ user.second_name }} ?')"
                           style="color:#ef4444">
                          <i class="bi bi-trash-fill"></i>
                        </a>
                      </div>
                    </td>
                  </tr>
                  {% else %}
                  <tr>
                    <td colspan="7" style="text-align:center;padding:40px;color:var(--text-muted)">
                      <i class="bi bi-people" style="font-size:32px;display:block;margin-bottom:8px;opacity:.4"></i>
                      Aucun utilisateur. <a href="{{ path('admin_add_users') }}" style="color:var(--green)">Ajouter le premier</a>.
                    </td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>

            {% if users|length > 0 %}
            <div class="d-flex align-items-center justify-content-between px-4 py-3 border-top flex-wrap gap-2">
              <span style="font-size:12.5px;color:var(--text-muted)">
                {{ users|length }} utilisateurs ·
                <strong style="color:var(--green)">{{ stats.activeuser }}</strong> actifs ·
                <strong style="color:#dc2626">{{ stats.blockeduser }}</strong> bloqués
              </span>
              <div class="d-flex gap-2">
                <span class="tag tag-doctor">{{ stats.totalDoctors }} Médecins</span>
                <span class="tag tag-patient">{{ stats.totalPatients }} Patients</span>
                <span class="tag tag-admin">{{ stats.totalAdmins }} Admins</span>
              </div>
            </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

  </main>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// ── Clock ────────────────────────────────────────────────────────────────────
function updateTime() {
  const el = document.getElementById('headerTime');
  if (el) el.textContent = new Date().toLocaleString('fr-FR', {
    weekday:'long', year:'numeric', month:'long', day:'numeric',
    hour:'2-digit', minute:'2-digit'
  });
}
updateTime(); setInterval(updateTime, 1000);

// ── Sidebar ──────────────────────────────────────────────────────────────────
function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('overlay').classList.toggle('open');
}

// ── Chart.js — données réelles depuis PHP ────────────────────────────────────
const chartData = {{ chartData|json_encode|raw }};
const ctx = document.getElementById('usersChart');
if (ctx && chartData) {
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: ['Médecins', 'Patients', 'Admins', 'Actifs', 'Bloqués'],
      datasets: [{
        label: 'Utilisateurs',
        data: [
          chartData.doctors  || 0,
          chartData.patients || 0,
          chartData.admins   || 0,
          chartData.active   || 0,
          chartData.blocked  || 0
        ],
        backgroundColor: ['#1e88e5','#9333ea','#ea580c','#16c784','#ef4444'],
        borderRadius: 8
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
    }
  });
}

// ── Filtre tableau ───────────────────────────────────────────────────────────
const searchInput = document.getElementById('searchInput');
const roleFilter  = document.getElementById('roleFilter');
const rows        = document.querySelectorAll('.user-row');

function filterUsers() {
  const search = (searchInput ? searchInput.value : '').toLowerCase();
  const role   = (roleFilter  ? roleFilter.value  : '').toLowerCase();

  rows.forEach(row => {
    const text = row.innerText.toLowerCase(); // 🔥 lire tout le contenu
    const userRole = (row.dataset.role || '').toLowerCase();

    const matchName = text.includes(search); // 🔥 simple et efficace
    const matchRole = !role || userRole === role;

    row.style.display = (matchName && matchRole) ? '' : 'none';
  });
}

if (searchInput) searchInput.addEventListener('input', filterUsers);
if (roleFilter)  roleFilter.addEventListener('change', filterUsers);
</script>
{% endblock %}