<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Ressource {{ ressource.title }}</title>
    <style>
        body {
            font-family: DejaVu Sans, sans-serif;
            font-size: 12px;
            color: #1f2937;
            margin: 24px;
            line-height: 1.6;
        }
        .header {
            border-bottom: 2px solid #16c784;
            padding-bottom: 10px;
            margin-bottom: 18px;
        }
        .title {
            margin: 0;
            font-size: 22px;
            color: #0f172a;
        }
        .subtitle {
            margin-top: 4px;
            color: #64748b;
            font-size: 11px;
        }
        .meta {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 18px;
        }
        .meta td {
            border: 1px solid #e2e8f0;
            padding: 8px 10px;
            vertical-align: top;
        }
        .meta .label {
            background: #f8fafc;
            width: 28%;
            font-weight: bold;
            color: #334155;
        }
        .content-box {
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            background: #ffffff;
            padding: 14px;
            white-space: pre-wrap;
        }
        .badge {
            display: inline-block;
            padding: 3px 8px;
            font-size: 10px;
            border-radius: 999px;
            color: #fff;
            background: #16c784;
        }
        .footer {
            margin-top: 20px;
            color: #94a3b8;
            font-size: 10px;
            text-align: right;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1 class="title">{{ ressource.title }}</h1>
        <div class="subtitle">Export PDF genere le {{ generatedAt|date('d/m/Y H:i') }}</div>
    </div>

    <table class="meta">
        <tr>
            <td class="label">Auteur</td>
            <td>{{ ressource.author }}</td>
            <td class="label">Type</td>
            <td>{{ ressource.type }}</td>
        </tr>
        <tr>
            <td class="label">Categorie</td>
            <td>{{ ressource.category }}</td>
            <td class="label">Statut</td>
            <td>
                {% if ressource.status == 'PUBLISHED' %}
                    <span class="badge">Publie</span>
                {% else %}
                    <span class="badge" style="background:#f59e0b;">Brouillon</span>
                {% endif %}
            </td>
        </tr>
        <tr>
            <td class="label">Date creation</td>
            <td colspan="3">{{ ressource.dateCreation ? ressource.dateCreation|date('d/m/Y') : '-' }}</td>
        </tr>
    </table>

    <h3>Description</h3>
    <div class="content-box">{{ ressource.description }}</div>

    <h3 style="margin-top:16px;">Contenu</h3>
    {% if isCloudinaryPdf %}
        <div class="content-box">
            Cette ressource contient un fichier PDF televerse sur Cloudinary.
            {% if cloudinaryUrl %}
                URL du fichier : {{ cloudinaryUrl }}
            {% endif %}
        </div>
    {% else %}
        <div class="content-box">{{ ressource.content }}</div>
    {% endif %}

    <div class="footer">GrowMind - Ressource #{{ ressource.id }}</div>
</body>
</html>
