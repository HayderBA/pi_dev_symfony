{% extends 'back/base_back.html.twig' %}

{% block title %}Modifier la Ressource{% endblock %}

{% block admin_content %}
<div class="page-header mb-4">
  <div class="page-header-content">
    <h1>Modifier la Ressource</h1>
    <p>Mettre à jour les informations de la ressource.</p>
  </div>
</div>

<div class="row g-3">
  <div class="col-lg-10 offset-lg-1">
    <div class="gm-card">
      <div class="gm-card-header mb-3 pb-3" style="border-bottom: 1px solid var(--border);">
        <span class="gm-card-title"><i class="bi bi-pencil-square"></i> Modifier Ressource</span>
      </div>
      <div class="gm-card-body p-4">
        {{ include('ressource/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
      </div>
      <div class="gm-card-body p-3 d-flex justify-content-between align-items-center" style="background:var(--body-bg);border-top:1px solid var(--border);">
        <a href="{{ path('app_ressource_index') }}" class="btn-gm-outline text-decoration-none"><i class="bi bi-arrow-left"></i> Retour</a>
        {{ include('ressource/_delete_form.html.twig') }}
      </div>
    </div>
  </div>
</div>
{% endblock %}
