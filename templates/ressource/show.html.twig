{% extends 'back/base_back.html.twig' %}

{% block title %}Détails de la Ressource{% endblock %}

{% block admin_content %}
<div class="container mt-5">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-info text-white rounded-top-4">
            <h2 class="mb-0"><i class="bi bi-card-text"></i> {{ ressource.title }}</h2>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped m-0">
                <tbody>
                    <tr>
                        <th class="ps-4 w-25">Type</th>
                        <td>{{ ressource.type }}</td>
                    </tr>
                    <tr>
                        <th class="ps-4">Catégorie</th>
                        <td>{{ ressource.category }}</td>
                    </tr>
                    <tr>
                        <th class="ps-4">Description</th>
                        <td>{{ ressource.description }}</td>
                    </tr>
                    <tr>
                        <th class="ps-4">Contenu</th>
                        <td>
                            {% if ressource.content starts with 'PDF::' %}
                                <a href="{{ path('app_ressource_download', {'id': ressource.id}) }}" class="btn btn-danger btn-sm">
                                    <i class="bi bi-file-earmark-pdf-fill"></i> Télécharger le PDF
                                </a>
                            {% else %}
                                {{ ressource.content | nl2br }}
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th class="ps-4">Auteur</th>
                        <td>{{ ressource.author }}</td>
                    </tr>
                    <tr>
                        <th class="ps-4">Date de création</th>
                        <td>{{ ressource.dateCreation ? ressource.dateCreation|date('d/m/Y') : '' }}</td>
                    </tr>
                    <tr>
                        <th class="ps-4 border-0">Statut</th>
                        <td class="border-0">
                            {% if ressource.status == 'PUBLISHED' %}
                                <span class="badge bg-success bg-opacity-75 rounded-pill">Publié</span>
                            {% else %}
                                <span class="badge bg-warning bg-opacity-75 text-dark rounded-pill">Brouillon</span>
                            {% endif %}
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-light p-3 d-flex gap-2 flex-wrap">
            <a href="{{ path('app_ressource_index') }}" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
            <a href="{{ path('app_ressource_edit', {'id': ressource.id}) }}" class="btn btn-warning text-white"><i class="bi bi-pencil"></i> Modifier</a>
            {% if ressource.content starts with 'PDF::' %}
                <a href="{{ path('app_ressource_download', {'id': ressource.id}) }}" class="btn btn-danger">
                    <i class="bi bi-download"></i> Télécharger PDF
                </a>
            {% endif %}
            <div class="ms-auto">
                {{ include('ressource/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

