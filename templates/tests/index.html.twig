{% extends 'wellness/base.html.twig' %}

{% block title %}Tests{% endblock %}

{% block body %}
    <div class="container py-4">

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <div class="page-kicker mb-1">TESTS</div>
                <h1 class="h3">Suivi des tests psychologiques</h1>
            </div>

            <!-- ADD BUTTON -->
            <a href="{{ path('app_tests_new') }}"
               class="btn"
               style="
                   background:#4CAF8E;
                   color:white;
                   border-radius:10px;
                   padding:8px 16px;
               "
               onmouseover="this.style.background='#2F7D6D';"
               onmouseout="this.style.background='#4CAF8E';">
                <i class="bi bi-plus-lg me-1"></i>Ajouter un test
            </a>
        </div>

        <!-- CARD -->
        <div class="card content-card">
            <div class="card-body p-0">

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">

                        <!-- HEADER -->
                        <thead style="background:#F5F7F6;">
                        <tr>
                            <th>ID</th>
                            <th>Type</th>
                            <th>Score</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                        </thead>

                        <tbody>
                        {% for test in tests %}
                            <tr style="transition: all 0.2s ease;">

                                <td>{{ test.id }}</td>

                                <td>{{ test.typeTest }}</td>

                                <td>
                                    <span style="
                                        background: rgba(76,175,142,0.15);
                                        color:#2F7D6D;
                                        padding:4px 10px;
                                        border-radius:8px;
                                    ">
                                        {{ test.score }}
                                    </span>
                                </td>

                                <td>
                                    {{ test.dateTest ? test.dateTest|date('Y-m-d') : '' }}
                                </td>

                                <!-- ACTIONS -->
                                <td class="d-flex gap-2 flex-wrap">

                                    <!-- VIEW -->
                                    <a href="{{ path('app_tests_show', {'id': test.id}) }}"
                                       class="btn btn-sm"
                                       style="
                                           border:1px solid #4CAF8E;
                                           color:#4CAF8E;
                                           border-radius:8px;
                                       "
                                       onmouseover="this.style.background='#4CAF8E'; this.style.color='white';"
                                       onmouseout="this.style.background='transparent'; this.style.color='#4CAF8E';">
                                        <i class="bi bi-eye me-1"></i>Voir
                                    </a>

                                    <!-- EDIT -->
                                    <a href="{{ path('app_tests_edit', {'id': test.id}) }}"
                                       class="btn btn-sm"
                                       style="
                                           border:1px solid #6B7280;
                                           color:#6B7280;
                                           border-radius:8px;
                                       "
                                       onmouseover="this.style.background='#6B7280'; this.style.color='white';"
                                       onmouseout="this.style.background='transparent'; this.style.color='#6B7280';">
                                        <i class="bi bi-pencil-square me-1"></i>Modifier
                                    </a>

                                    <!-- DELETE -->
                                    <form method="post"
                                          action="{{ path('app_tests_delete', {'id': test.id}) }}"
                                          onsubmit="return confirm('Supprimer ce test ?');">

                                        <input type="hidden" name="_token"
                                               value="{{ csrf_token('delete' ~ test.id) }}">

                                        <button
                                                class="btn btn-sm"
                                                style="
                                                border:1px solid #EF4444;
                                                color:#EF4444;
                                                border-radius:8px;
                                                background:transparent;
                                            "
                                                onmouseover="this.style.background='#EF4444'; this.style.color='white';"
                                                onmouseout="this.style.background='transparent'; this.style.color='#EF4444';">
                                            <i class="bi bi-trash me-1"></i>Supprimer
                                        </button>
                                    </form>

                                </td>
                            </tr>

                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-4">
                                    Aucun test trouvé
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>

                    </table>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
