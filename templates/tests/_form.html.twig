{% form_theme form 'bootstrap_5_layout.html.twig' %}

{{ form_start(form, {'attr': {'class': 'wellness-form'}}) }}

{% if not form.vars.valid %}
    <div class="wellness-alert">
        Merci de verifier les champs du formulaire avant de continuer.
    </div>
{% endif %}

<div class="row g-4">
    <div class="col-lg-4">
        {{ form_row(form.typeTest) }}
    </div>
    <div class="col-lg-3">
        {{ form_row(form.score) }}
    </div>
    <div class="col-lg-5">
        {{ form_row(form.dateTest) }}
    </div>

    <div class="col-lg-6">
        {{ form_row(form.utilisateur) }}
    </div>
</div>

<div class="wellness-form-actions">
    <button class="{{ button_class|default('btn-shell btn-shell-primary') }}">
        <i class="bi bi-{{ button_icon|default('check2-circle') }}"></i>
        {{ button_label|default('Enregistrer') }}
    </button>
</div>

{{ form_end(form) }}
