<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}GrowMind - Bien-être & Développement Personnel{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #0b3b3f, #1a6d6b, #2a9d8f);
            --secondary-gradient: linear-gradient(135deg, #e0f2f1, #b2dfdb);
            --success-gradient: linear-gradient(135deg, #2ecc71, #27ae60);
            --danger-gradient: linear-gradient(135deg, #e74c3c, #c0392b);
        }
        body {
            background: linear-gradient(120deg, #eef2f3 0%, #d4e2e8 100%);
            font-family: 'Poppins', 'Segoe UI', sans-serif;
            min-height: 100vh;
        }
        /* Header original */
        .header {
            background: var(--primary-gradient);
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            padding: 1rem 2rem;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
        }
        .sitename {
            font-weight: 700;
            font-size: 1.5rem;
            letter-spacing: 1px;
            color: white !important;
            margin: 0;
        }
        .navmenu ul {
            display: flex;
            list-style: none;
            margin: 0;
            padding: 0;
        }
        .navmenu ul li {
            position: relative;
        }
        .navmenu ul li a {
            color: rgba(255,255,255,0.9) !important;
            transition: 0.3s;
            margin: 0 10px;
            font-weight: 500;
            text-decoration: none;
            display: inline-block;
            padding: 8px 0;
        }
        .navmenu ul li a:hover {
            transform: translateY(-2px);
            color: #ffeb3b !important;
        }
        .navmenu .dropdown ul {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            background: white;
            border-radius: 10px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            min-width: 200px;
            z-index: 1000;
        }
        .navmenu .dropdown:hover ul {
            display: block;
        }
        .navmenu .dropdown ul li a {
            color: #333 !important;
            padding: 10px 20px;
            display: block;
        }
        .navmenu .dropdown ul li a:hover {
            background: #f0f0f0;
            color: #2a9d8f !important;
        }
        .card-modern {
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(2px);
            border-radius: 28px;
            box-shadow: 0 20px 35px -12px rgba(0,0,0,0.2);
            border: none;
            transition: 0.3s;
        }
        .card-modern:hover {
            transform: translateY(-5px);
        }
        .btn-primary-custom {
            background: var(--primary-gradient);
            border: none;
            border-radius: 40px;
            padding: 10px 25px;
            font-weight: 600;
            transition: 0.3s;
            color: white;
        }
        .btn-primary-custom:hover {
            transform: scale(1.03);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }
        .form-control-modern {
            border-radius: 50px;
            padding: 12px 20px;
            border: 1px solid #cbd5e1;
            transition: 0.2s;
        }
        .form-control-modern:focus {
            border-color: #2a9d8f;
            box-shadow: 0 0 0 4px rgba(42,157,143,0.2);
        }
        .input-wrapper {
            position: relative;
            margin-bottom: 1.5rem;
        }
        .form-control-modern {
            border-radius: 50px;
            padding: 12px 45px 12px 20px;
            border: 2px solid #cbd5e1;
            transition: 0.2s;
            width: 100%;
        }
        .form-control-modern.error {
            border-color: #e74c3c;
            background: #fff5f5;
        }
        .form-control-modern.valid {
            border-color: #2ecc71;
            background: #f0fff4;
        }
        .status-icon {
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.2rem;
            pointer-events: none;
        }
        .status-icon .fa-times-circle { color: #e74c3c; }
        .status-icon .fa-check-circle { color: #2ecc71; }
        .error-message {
            color: #e74c3c;
            font-size: 0.75rem;
            margin-top: 5px;
            margin-left: 15px;
            display: none;
        }
        .badge-upcoming { background: #2a9d8f; color: white; padding: 5px 12px; border-radius: 30px; font-size: 0.75rem; }
        .badge-today { background: #2ecc71; color: white; padding: 5px 12px; border-radius: 30px; font-size: 0.75rem; }
        .badge-past { background: #95a5a6; color: white; padding: 5px 12px; border-radius: 30px; font-size: 0.75rem; }
        .alert-modern {
            border-radius: 20px;
            border: none;
            padding: 15px 20px;
            animation: slideIn 0.4s ease;
        }
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(-20px);}
            to { opacity: 1; transform: translateY(0);}
        }
        footer {
            background: #0b3b3f;
            color: white;
            text-align: center;
            padding: 1.5rem;
            margin-top: 3rem;
        }
        .main {
            margin-top: 80px;
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

<header id="header" class="header fixed-top">
    <div class="container position-relative d-flex align-items-center justify-content-between">
        <a href="{{ path('app_home') }}" class="logo d-flex align-items-center text-decoration-none">
            <h1 class="sitename">GrowMind</h1>
        </a>
        <nav id="navmenu" class="navmenu">
            <ul>
                <li><a href="{{ path('app_home') }}">Accueil</a></li>
                <li><a href="{{ path('app_doctors') }}">Medecin</a></li>
                <li><a href="{{ path('app_evenement_list') }}">Événements</a></li>
                <li><a href="{{ path('app_evenement_admin') }}">Admin</a></li>
                <li class="dropdown">
                    <a href="#"><span>Plus</span> <i class="bi bi-chevron-down toggle-dropdown"></i></a>
                    <ul>
                        <li><a href="#">Cabinet</a></li>
                        <li><a href="{{ path('app_appointment') }}">Rendez-vous</a></li>
                        <li><a href="#">Santé et bien-être</a></li>
                        <li><a href="#">Ressources et bibliothèque</a></li>
                        <li><a href="#">Confidentialité</a></li>
                    </ul>
                </li>
                <li><a href="{{ path('app_contact') }}">Contact</a></li>
            </ul>
            <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
        </nav>
    </div>
</header>

<div style="height: 80px;"></div>

<!-- Flash Messages -->
<div class="container mt-3">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-modern alert-{{ type == 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
                <i class="fas fa-{{ type == 'success' ? 'check-circle' : 'exclamation-circle' }} me-2"></i>
                {{ message|raw }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}
</div>

<main class="main">
    {% block body %}{% endblock %}
</main>

<footer>
    <div class="container">
        <p>&copy; 2026 GrowMind - Prenez soin de votre bien-être mental</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    function validateField(input, regex, errorMsgElement) {
        const value = input.value.trim();
        const wrapper = input.closest('.input-wrapper');
        const icon = wrapper ? wrapper.querySelector('.status-icon') : null;
        if (value === '') {
            input.classList.remove('valid', 'error');
            if (icon) icon.innerHTML = '';
            if (errorMsgElement) errorMsgElement.style.display = 'none';
            return false;
        }
        if (regex.test(value)) {
            input.classList.add('valid');
            input.classList.remove('error');
            if (icon) icon.innerHTML = '<i class="fas fa-check-circle"></i>';
            if (errorMsgElement) errorMsgElement.style.display = 'none';
            return true;
        } else {
            input.classList.add('error');
            input.classList.remove('valid');
            if (icon) icon.innerHTML = '<i class="fas fa-times-circle"></i>';
            if (errorMsgElement) errorMsgElement.style.display = 'block';
            return false;
        }
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.input-wrapper').forEach(wrapper => {
            const input = wrapper.querySelector('input, select, textarea');
            const errorMsg = wrapper.querySelector('.error-message');
            const icon = document.createElement('div');
            icon.className = 'status-icon';
            if (input && errorMsg && !wrapper.querySelector('.status-icon')) {
                wrapper.appendChild(icon);
                let regex = null;
                if (input.type === 'email') regex = /^[^\s@]+@([^\s@.,]+\.)+[^\s@.,]{2,}$/;
                else if (input.type === 'tel') regex = /^[0-9]{10}$/;
                else if (input.id === 'nom' || input.id === 'nomComplet') regex = /^.{2,}$/;
                else if (input.type === 'number') regex = /^[1-9][0-9]*$/;
                else if (input.hasAttribute('required')) regex = /^.{1,}$/;
                if (regex) {
                    input.addEventListener('input', function() { validateField(this, regex, errorMsg); });
                    input.addEventListener('blur', function() { validateField(this, regex, errorMsg); });
                }
            }
        });
    });
</script>
{% block javascripts %}{% endblock %}
</body>
</html>