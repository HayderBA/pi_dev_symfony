{% extends 'base.html.twig' %}

{% block title %}Vérification 2FA{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Fraunces:wght@600;700&display=swap" rel="stylesheet">
<style>
:root {
    --green: #16c784;
    --green-dark: #0fa36a;
    --blue: #1e88e5;
    --blue-dark: #1565c0;
    --border: #e2e8f0;
    --muted: #64748b;
    --text: #1a2332;
    --body-bg: #f0f4f8;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
    font-family: 'DM Sans', sans-serif;
    background: var(--body-bg);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

body::before {
    content: '';
    position: fixed;
    width: 500px; height: 500px;
    background: var(--green);
    border-radius: 50%;
    filter: blur(90px);
    opacity: .12;
    top: -150px; left: -150px;
    pointer-events: none;
}
body::after {
    content: '';
    position: fixed;
    width: 400px; height: 400px;
    background: var(--blue);
    border-radius: 50%;
    filter: blur(90px);
    opacity: .12;
    bottom: -100px; right: -100px;
    pointer-events: none;
}

.card-2fa {
    background: #fff;
    border-radius: 28px;
    box-shadow: 0 24px 64px rgba(0,0,0,.10);
    width: 100%;
    max-width: 420px;
    overflow: hidden;
    position: relative;
    z-index: 1;
    animation: slideUp .5s cubic-bezier(.16,1,.3,1) both;
}

@keyframes slideUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
}

.card-header-2fa {
    background: linear-gradient(135deg, #0d1b2a, #1a2d45);
    padding: 36px 40px 32px;
    text-align: center;
}

.shield-icon {
    width: 64px; height: 64px;
    background: linear-gradient(135deg, var(--green), var(--blue));
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    font-size: 28px;
    box-shadow: 0 8px 24px rgba(22,199,132,.3);
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0%, 100% { box-shadow: 0 8px 24px rgba(22,199,132,.3); }
    50%       { box-shadow: 0 8px 32px rgba(22,199,132,.5); }
}

.card-header-2fa h1 {
    font-family: 'Fraunces', serif;
    color: #fff;
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 6px;
}

.card-header-2fa p {
    color: rgba(255,255,255,.55);
    font-size: 13px;
}

.card-body-2fa {
    padding: 36px 40px 40px;
}

.code-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .8px;
    margin-bottom: 12px;
    display: block;
}

.code-input {
    width: 100%;
    padding: 18px 20px;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 14px;
    text-align: center;
    border: 2px solid var(--border);
    border-radius: 16px;
    background: var(--body-bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    outline: none;
    transition: border-color .2s, box-shadow .2s, background .2s;
}

.code-input:focus {
    border-color: var(--green);
    background: #fff;
    box-shadow: 0 0 0 4px rgba(22,199,132,.12);
}

.timer-bar {
    height: 3px;
    background: var(--border);
    border-radius: 99px;
    margin: 12px 0 24px;
    overflow: hidden;
}

.timer-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--green), var(--blue));
    border-radius: 99px;
    animation: timer 30s linear infinite;
    transform-origin: left;
}

@keyframes timer {
    from { width: 100%; }
    to   { width: 0%; }
}

.btn-validate {
    width: 100%;
    padding: 15px;
    background: linear-gradient(135deg, var(--green), var(--green-dark));
    border: none;
    border-radius: 14px;
    color: #fff;
    font-size: 15px;
    font-weight: 700;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    transition: all .25s;
    letter-spacing: .3px;
}

.btn-validate:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(22,199,132,.4);
}

.hint {
    text-align: center;
    margin-top: 20px;
    font-size: 12.5px;
    color: var(--muted);
}

.hint a {
    color: var(--blue);
    font-weight: 600;
    text-decoration: none;
}
</style>
{% endblock %}

{% block body %}
<div class="card-2fa">

    <div class="card-header-2fa">
        <div class="shield-icon">🔐</div>
        <h1>Vérification 2FA</h1>
        <p>Ouvre Google Authenticator et entre le code</p>
    </div>

    <div class="card-body-2fa">
        <form action="{{ path('2fa_login_check') }}" method="post">

            <label class="code-label">Code à 6 chiffres</label>
            <input
                type="text"
                name="_auth_code"
                class="code-input"
                placeholder="• • • • • •"
                maxlength="6"
                autofocus
                autocomplete="off"
            />

            <div class="timer-bar">
                <div class="timer-fill"></div>
            </div>

            <button type="submit" class="btn-validate">
                ✅ Valider le code
            </button>
        </form>

        <p class="hint">
            Code expiré ? Il se renouvelle toutes les 30s.<br>
            <a href="{{ path('app_login') }}">← Retour au login</a>
        </p>
    </div>

</div>
{% endblock %}