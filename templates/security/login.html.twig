{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}
{% block stylesheets %}
{{ parent() }}
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Fraunces:wght@600;700&display=swap" rel="stylesheet">
<style>
:root {
  --green:       #16c784;
  --green-dark:  #0fa36a;
  --green-light: #e8faf3;
  --blue:        #1e88e5;
  --blue-dark:   #1565c0;
  --border:      #e2e8f0;
  --muted:       #64748b;
  --text:        #1a2332;
  --body-bg:     #f0f4f8;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--body-bg);
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* Blobs décoratifs */
body::before {
  content: '';
  position: fixed;
  width: 500px; height: 500px;
  background: var(--green);
  border-radius: 50%;
  filter: blur(90px);
  opacity: .15;
  top: -150px; left: -150px;
  pointer-events: none;
  z-index: 0;
}
body::after {
  content: '';
  position: fixed;
  width: 400px; height: 400px;
  background: var(--blue);
  border-radius: 50%;
  filter: blur(90px);
  opacity: .15;
  bottom: -100px; right: -100px;
  pointer-events: none;
  z-index: 0;
}

form {
  position: relative; z-index: 1;
  background: #fff;
  border-radius: 24px;
  box-shadow: 0 20px 60px rgba(0,0,0,.10);
  width: 100%; max-width: 440px;
  overflow: hidden;
  padding: 0;
}

/* Header vert/bleu */
form::before {
  content: 'GrowMind';
  display: block;
  background: linear-gradient(135deg, #0d1b2a, #1a2d45);
  color: #fff;
  font-family: 'Fraunces', serif;
  font-size: 22px;
  font-weight: 700;
  text-align: center;
  padding: 32px 40px 40px;
  letter-spacing: .3px;
}

/* Tous les éléments internes */
form > *:not(:first-child) { display: block; padding: 0 36px; }
form > label:first-of-type { padding-top: 28px; }
form > button { padding-bottom: 32px; }

.alert { margin: 0 36px 16px; padding: 0 36px; border-radius: 10px; }
.alert-danger {
  background: #fef2f2;
  border: 1px solid #fecaca;
  color: #dc2626;
  font-size: 13.5px;
  padding: 12px 16px !important;
  margin: 16px 36px !important;
  border-radius: 10px;
}

h1.h3 {
  font-size: 18px !important;
  font-weight: 700 !important;
  color: var(--text);
  text-align: center;
  margin-bottom: 6px !important;
  padding-top: 10px;
}

label {
  font-size: 12px !important;
  font-weight: 600 !important;
  color: var(--muted) !important;
  text-transform: uppercase;
  letter-spacing: .4px;
  margin-top: 16px !important;
  margin-bottom: 6px !important;
}

.form-control {
  width: calc(100% - 72px) !important;
  margin: 0 36px !important;
  padding: 11px 14px !important;
  border: 1.5px solid var(--border) !important;
  border-radius: 12px !important;
  font-size: 14px !important;
  font-family: 'DM Sans', sans-serif !important;
  background: var(--body-bg) !important;
  color: var(--text) !important;
  outline: none !important;
  transition: border-color .2s, box-shadow .2s !important;
  display: block !important;
}
.form-control:focus {
  border-color: var(--green) !important;
  background: #fff !important;
  box-shadow: 0 0 0 3px rgba(22,199,132,.12) !important;
}

.btn-primary {
  width: calc(100% - 72px) !important;
  margin: 20px 36px 32px !important;
  padding: 13px !important;
  background: linear-gradient(135deg, var(--green), var(--green-dark)) !important;
  border: none !important;
  border-radius: 12px !important;
  color: #fff !important;
  font-size: 15px !important;
  font-weight: 700 !important;
  font-family: 'DM Sans', sans-serif !important;
  cursor: pointer;
  transition: all .25s !important;
  display: block !important;
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(22,199,132,.4) !important;
}
</style>
{% endblock%}

{% block body %}
    <form method="post">
        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        {% if app.user %}
            <div class="mb-3">
                You are logged in as {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Logout</a>
            </div>
        {% endif %}

        <h1 class="h3 mb-3 font-weight-normal">Please sign in</h1>
        <label for="username">Email</label>
        <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email"  autofocus>
        <label for="password">Password</label>
        <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" >
        <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

        {#
            Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
            See https://symfony.com/doc/current/security/remember_me.html

            <div class="checkbox mb-3">
                <input type="checkbox" name="_remember_me" id="_remember_me">
                <label for="_remember_me">Remember me</label>
            </div>
        #}
        {# ligne 188 - remplace l'ancien lien #}
        <a href="{{ path('forgot_password') }}" 
          style="display:block; text-align:center; margin: 8px 36px 0; font-size:13px; color:var(--muted); text-decoration:none;">
            Mot de passe oublié ?
        </a>
        <button class="btn btn-lg btn-primary" type="submit">
            Sign in
        </button>
        <div style="margin-top:15px; text-align:center;">
    <span>Vous n'avez pas de compte ?</span>
    <a href="{{ path('app_register') }}" style="color:#0d6efd; font-weight:500;">
        S'inscrire
    </a>
</div>
    </form>
{% endblock %}
