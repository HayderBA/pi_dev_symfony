{% extends 'back/base_back.html.twig' %}

{% block title %}Détails du Favori{% endblock %}

{% block admin_content %}
<div class="container mt-5">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-info text-white rounded-top-4">
            <h2 class="mb-0"><i class="bi bi-heart"></i> Détails du favori</h2>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped m-0">
                <tbody>
                    <tr>
                        <th class="ps-4 w-25">Ressource</th>
                        <td>{{ favori.ressource ? favori.ressource.title : '' }}</td>
                    </tr>
                    <tr>
                        <th class="ps-4 border-0">Date d'ajout</th>
                        <td class="border-0">{{ favori.dateAjout ? favori.dateAjout|date('d/m/Y') : '' }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-light p-3">
            <a href="{{ path('app_favori_index') }}" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Retour à la liste</a>
        </div>
    </div>
</div>
{% endblock %}

