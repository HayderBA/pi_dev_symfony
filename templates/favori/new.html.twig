{% extends 'back/base_back.html.twig' %}

{% block title %}Nouveau Favori{% endblock %}

{% block admin_content %}
<div class="container mt-5">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-primary text-white rounded-top-4">
            <h2 class="mb-0"><i class="bi bi-heart-fill"></i> Ajouter aux favoris</h2>
        </div>
        <div class="card-body p-4">
            {{ include('favori/_form.html.twig') }}
        </div>
        <div class="card-footer bg-light p-3">
            <a href="{{ path('app_favori_index') }}" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Retour à la liste</a>
        </div>
    </div>
</div>
{% endblock %}

