<!DOCTYPE html>
<html>
<body style="font-family:'DM Sans',Arial,sans-serif; background:#f0f4f8; padding:40px 20px; margin:0;">
    <div style="max-width:480px; margin:auto; background:#fff; border-radius:20px; overflow:hidden; box-shadow:0 10px 40px rgba(0,0,0,.08);">
