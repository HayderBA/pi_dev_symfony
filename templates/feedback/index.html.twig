{% extends 'base.html.twig' %}

{% block body %}
{% include 'front/_main_nav.html.twig' with { active_page: 'forum' } %}
<main class="main">
  <section class="section" style="padding-top: 120px;">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-6">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
              <h3 class="mb-3">Feedback consultation</h3>
              <p class="text-secondary">Patient cible: {{ user.fullName }}</p>

              {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
              {% endfor %}
              {% for message in app.flashes('error') %}
                <div class="alert alert-danger">{{ message }}</div>
              {% endfor %}

              <form method="post">
                <div class="mb-3">
                  <label class="form-label">Note</label>
                  <div class="d-flex gap-3 flex-wrap">
                    {% for i in 1..5 %}
                      <label class="d-flex align-items-center gap-1">
                        <input type="radio" name="note" value="{{ i }}" required>
                        {% for j in 1..i %}<span>★</span>{% endfor %}
                      </label>
                    {% endfor %}
                  </div>
                </div>
                <div class="mb-3">
                  <label class="form-label">Votre message</label>
                  <textarea name="message" class="form-control" rows="4" placeholder="Partagez votre experience..."></textarea>
                </div>
                <button type="submit" class="btn btn-primary w-100">Envoyer</button>
              </form>

              <div class="mt-3 text-center">
                <a href="{{ path('app_forum_index') }}" class="btn btn-outline-secondary rounded-pill px-4">Retour forum</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>
{% endblock %}
