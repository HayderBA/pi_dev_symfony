{% extends 'base.html.twig' %}

{% block title %}Carte des medecins{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <style>
    #map { height: 520px; border-radius: 20px; }
  </style>
{% endblock %}

{% block body %}
<main class="main">
  <section class="section" style="padding-top: 100px;">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
          <h2>Carte des medecins</h2>
          <p class="text-secondary mb-0">Reperez rapidement les medecins disponibles autour de vous.</p>
        </div>
        <a href="{{ path('app_forum_index') }}" class="btn btn-outline-secondary">Retour forum</a>
      </div>

      <div class="row g-4">
        <div class="col-lg-8">
          <div id="map"></div>
        </div>
        <div class="col-lg-4">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
              <h4 class="mb-3">Medecins a proximite</h4>
              <div class="list-group">
                {% for medecin in medecins %}
                  <a href="{{ path('messages_new', {'userId': medecin.id}) }}" class="list-group-item list-group-item-action">
                    <strong>{{ medecin.nom }}</strong>
                    <div class="small text-secondary">{{ medecin.adresse }}</div>
                  </a>
                {% else %}
                  <div class="text-secondary">Aucun medecin disponible.</div>
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  const medecins = {{ medecins|json_encode|raw }};
  const zonesAlerte = {{ zonesAlerte|json_encode|raw }};
  const map = L.map('map').setView([36.8065, 10.1815], 12);

  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
    attribution: '&copy; OpenStreetMap',
    subdomains: 'abcd',
    maxZoom: 19
  }).addTo(map);

  medecins.forEach((medecin) => {
    L.marker([medecin.latitude, medecin.longitude]).addTo(map)
      .bindPopup(`<strong>${medecin.nom}</strong><br>${medecin.adresse}`);
  });

  zonesAlerte.forEach((zone) => {
    L.circle([zone.latitude, zone.longitude], {
      color: 'red',
      fillColor: '#f03',
      fillOpacity: 0.15,
      radius: zone.rayon
    }).addTo(map).bindPopup(`Zone d'alerte: ${zone.niveau}`);
  });
</script>
{% endblock %}
