<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Urgence GrowMind</title>
</head>
<body style="font-family: Arial, sans-serif; background: #f4f6f8; padding: 24px; color: #17324d;">
    <div style="max-width: 640px; margin: 0 auto; background: #ffffff; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 35px rgba(0,0,0,0.08);">
        <div style="background: linear-gradient(135deg, #dc3545, #8b1e2d); padding: 24px; text-align: center;">
            <h1 style="color: #ffffff; margin: 0; font-size: 28px;">Alerte Urgence</h1>
        </div>
        <div style="padding: 24px;">
            <p style="margin-top: 0;">Un patient GrowMind a declenche une alerte SOS.</p>

            <h3 style="margin-bottom: 10px;">Patient</h3>
            <p style="margin: 0 0 8px;"><strong>Nom :</strong> {{ patient.name }} {{ patient.secondName }}</p>
            <p style="margin: 0 0 8px;"><strong>Email :</strong> {{ patient.email }}</p>
            <p style="margin: 0 0 8px;"><strong>Distance :</strong> {{ distance }} km</p>
            <p style="margin: 0 0 20px;">
                <strong>Localisation :</strong>
                <a href="https://www.google.com/maps?q={{ latitude }},{{ longitude }}" style="color: #1a73e8;">Voir sur Google Maps</a>
            </p>

            <h3 style="margin-bottom: 10px;">Medecin contacte</h3>
            <p style="margin: 0 0 8px;"><strong>Nom :</strong> {{ medecin.name }} {{ medecin.secondName }}</p>
            <p style="margin: 0 0 8px;"><strong>Email :</strong> {{ medecin.email }}</p>
            <p style="margin: 0 0 20px;"><strong>Telephone :</strong> {{ medecin.phone ?: 'Non renseigne' }}</p>

            <hr style="border: none; border-top: 1px solid #e8edf3; margin: 20px 0;">
            <p style="margin-bottom: 0; color: #607080;">GrowMind - Plateforme de sante mentale</p>
        </div>
    </div>
</body>
</html>
