{% extends 'wellness/base.html.twig' %}

{% block title %}Nouvel enregistrement de santé{% endblock %}

{% block body %}
    <div class="container wellness-page py-4 py-xl-5">
        <div class="wellness-page-header">
            <div class="wellness-page-copy">
                <div class="page-kicker mb-2">Santé</div>
                <h1 class="wellness-title">Créer un enregistrement de santé</h1>
                <p class="wellness-lead">
                    Ajouter un nouveau suivi pour le stress, la qualité du sommeil et les recommandations.
                </p>
            </div>

            <div class="wellness-actions">
                <a class="btn-shell btn-shell-outline" href="{{ path('app_sante_bien_etre_index') }}">
                    <i class="bi bi-arrow-left"></i>Retour à la liste
                </a>
            </div>
        </div>

        <div class="card content-card wellness-form-card">
            <div class="card-body">
                {{ include('sante_bien_etre/_form.html.twig', {
                    button_label: 'Créer un enregistrement',
                    button_icon: 'plus-lg',
                    button_class: 'btn-shell btn-shell-primary'
                }) }}
            </div>
        </div>
    </div>
{% endblock %}
