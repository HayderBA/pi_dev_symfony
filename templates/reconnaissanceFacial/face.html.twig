{% extends 'base.html.twig' %}

{% block body %}

<style>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap');

    :root {
        --bg:       #f0f7ff;
        --surface:  #ffffff;
        --border:   #daeaf7;
        --green:    #16c784;
        --green-dk: #0fa36a;
        --blue:     #1e88e5;
        --blue-dk:  #1565c0;
        --danger:   #e53935;
        --text:     #0d1b2a;
        --muted:    #5a7a94;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        min-height: 100vh;
    }

    .face-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        background:
            radial-gradient(ellipse 70% 60% at 10% 10%, rgba(22,199,132,0.18) 0%, transparent 55%),
            radial-gradient(ellipse 60% 50% at 90% 90%, rgba(30,136,229,0.18) 0%, transparent 55%),
            radial-gradient(ellipse 50% 40% at 50% 50%, rgba(255,255,255,0.9) 0%, transparent 80%),
            var(--bg);
    }

    .face-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 28px;
        padding: 2.5rem;
        width: 100%;
        max-width: 440px;
        box-shadow:
            0 4px 24px rgba(30,136,229,0.10),
            0 20px 60px rgba(22,199,132,0.08);
    }

    .face-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .face-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, var(--green), var(--blue));
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.7rem;
        margin: 0 auto 1rem;
        box-shadow: 0 8px 24px rgba(22,199,132,0.30);
    }

    .face-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.7rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        background: linear-gradient(135deg, var(--green-dk), var(--blue));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .face-subtitle {
        color: var(--muted);
        font-size: 0.875rem;
        margin-top: 0.4rem;
        font-weight: 400;
    }

    .video-container {
        position: relative;
        border-radius: 18px;
        overflow: hidden;
        background: #0d1b2a;
        aspect-ratio: 4/3;
        margin-bottom: 1.5rem;
        border: 2px solid var(--border);
        box-shadow: 0 4px 20px rgba(30,136,229,0.12);
    }

    #video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transform: scaleX(-1);
    }

    .scan-line {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, var(--green), var(--blue), transparent);
        animation: scanDown 2.5s ease-in-out infinite;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .scanning .scan-line { opacity: 1; }

    @keyframes scanDown {
        0%   { top: 0%; }
        100% { top: 100%; }
    }

    .corner {
        position: absolute;
        width: 26px;
        height: 26px;
        border-style: solid;
        border-color: var(--green);
        opacity: 0.9;
    }
    .corner-tl { top: 12px; left: 12px;   border-width: 2px 0 0 2px; border-radius: 4px 0 0 0; }
    .corner-tr { top: 12px; right: 12px;  border-width: 2px 2px 0 0; border-radius: 0 4px 0 0; }
    .corner-bl { bottom: 12px; left: 12px;  border-width: 0 0 2px 2px; border-radius: 0 0 0 4px; }
    .corner-br { bottom: 12px; right: 12px; border-width: 0 2px 2px 0; border-radius: 0 0 4px 0; }

    .status-badge {
        position: absolute;
        bottom: 12px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(13,27,42,0.75);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 20px;
        padding: 5px 16px;
        font-size: 0.75rem;
        font-weight: 500;
        color: #fff;
        white-space: nowrap;
        transition: all 0.3s;
    }

    .btn-group {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .btn {
        padding: 0.85rem 1rem;
        border: none;
        border-radius: 14px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .btn:disabled {
        opacity: 0.45;
        cursor: not-allowed;
        transform: none !important;
        box-shadow: none !important;
    }

    .btn-register {
        background: linear-gradient(135deg, rgba(22,199,132,0.12), rgba(22,199,132,0.05));
        color: var(--green-dk);
        border: 1.5px solid rgba(22,199,132,0.4);
    }

    .btn-register:hover:not(:disabled) {
        background: linear-gradient(135deg, rgba(22,199,132,0.2), rgba(22,199,132,0.1));
        border-color: var(--green);
        transform: translateY(-2px);
        box-shadow: 0 6px 18px rgba(22,199,132,0.2);
    }

    .btn-scan {
        background: linear-gradient(135deg, var(--green), var(--blue));
        color: #fff;
        box-shadow: 0 4px 16px rgba(22,199,132,0.35);
    }

    .btn-scan:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(30,136,229,0.35);
    }

    .btn-scan:active:not(:disabled) { transform: translateY(0); }

    .result-box {
        border-radius: 14px;
        padding: 1rem 1.2rem;
        font-size: 0.875rem;
        display: none;
        animation: fadeIn 0.3s ease;
        border: 1.5px solid transparent;
    }

    .result-box.success {
        background: linear-gradient(135deg, rgba(22,199,132,0.08), rgba(22,199,132,0.04));
        border-color: rgba(22,199,132,0.35);
        color: var(--green-dk);
        display: block;
    }

    .result-box.error {
        background: rgba(229,57,53,0.07);
        border-color: rgba(229,57,53,0.3);
        color: var(--danger);
        display: block;
    }

    .result-box.info {
        background: linear-gradient(135deg, rgba(30,136,229,0.08), rgba(30,136,229,0.04));
        border-color: rgba(30,136,229,0.3);
        color: var(--blue-dk);
        display: block;
    }

    .result-title {
        font-weight: 700;
        font-size: 1rem;
        margin-bottom: 0.25rem;
        font-family: 'Syne', sans-serif;
    }

    .confidence-bar-wrap {
        margin-top: 0.6rem;
        background: rgba(0,0,0,0.07);
        border-radius: 99px;
        height: 7px;
        overflow: hidden;
    }

    .confidence-bar-fill {
        height: 100%;
        border-radius: 99px;
        transition: width 0.8s ease;
        background: linear-gradient(90deg, var(--green), var(--blue));
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    canvas { display: none; }
</style>

<div class="face-wrapper">
    <div class="face-card">

        <div class="face-header">
            <div class="face-icon">🔐</div>
            <h1 class="face-title">Face ID Admin</h1>
            <p class="face-subtitle">Vérification biométrique sécurisée</p>
        </div>

        <div class="video-container" id="videoContainer">
            <video id="video" autoplay playsinline></video>
            <div class="scan-line"></div>
            <div class="corner corner-tl"></div>
            <div class="corner corner-tr"></div>
            <div class="corner corner-bl"></div>
            <div class="corner corner-br"></div>
            <div class="status-badge" id="statusBadge">Initialisation caméra...</div>
        </div>

        <canvas id="canvas"></canvas>

        <div class="btn-group">
            {% if not has_face %}
                <button class="btn btn-register" id="btnRegister" onclick="registerFace()" disabled style="grid-column: span 2;">
                    📸 Enregistrer mon visage
                </button>
            {% else %}
                <button class="btn btn-scan" id="btnScan" onclick="capture()" disabled style="grid-column: span 2;">
                    🔍 Scanner mon visage
                </button>
            {% endif %}
        </div>

        <div class="result-box" id="resultBox">
            <div class="result-title" id="resultTitle"></div>
            <div id="resultMsg"></div>
            <div class="confidence-bar-wrap" id="barWrap" style="display:none">
                <div class="confidence-bar-fill" id="barFill" style="width:0%"></div>
            </div>
        </div>

    </div>
</div>

<script>
const video          = document.getElementById('video');
const canvas         = document.getElementById('canvas');
const statusBadge    = document.getElementById('statusBadge');
const btnRegister    = document.getElementById('btnRegister');
const btnScan        = document.getElementById('btnScan');
const videoContainer = document.getElementById('videoContainer');

// ✅ Démarrer la webcam
document.addEventListener("DOMContentLoaded", function () {
    navigator.mediaDevices.getUserMedia({ video: true })
        .then(stream => {
            video.srcObject = stream;
            statusBadge.textContent = '🟢 Caméra active';
            statusBadge.style.color = '#16c784';
            // ✅ Vérifier si le bouton existe avant (évite "Cannot set properties of null")
            if (btnRegister) btnRegister.disabled = false;
            if (btnScan)     btnScan.disabled     = false;
        })
        .catch(err => {
            statusBadge.textContent = '❌ Caméra inaccessible';
            statusBadge.style.color = '#e53935';
            showResult('error', 'Erreur caméra', err.message);
        });
});

function getSnapshot() {
    canvas.width  = video.videoWidth;
    canvas.height = video.videoHeight;
    canvas.getContext('2d').drawImage(video, 0, 0);
    return canvas.toDataURL('image/jpeg', 0.9);
}

function showResult(type, title, msg, confidence = null) {
    const box     = document.getElementById('resultBox');
    const tit     = document.getElementById('resultTitle');
    const msgEl   = document.getElementById('resultMsg');
    const barWrap = document.getElementById('barWrap');
    const barFill = document.getElementById('barFill');

    box.className     = 'result-box ' + type;
    tit.textContent   = title;
    msgEl.textContent = msg;

    if (confidence !== null) {
        barWrap.style.display = 'block';
        setTimeout(() => { barFill.style.width = Math.min(confidence, 100) + '%'; }, 100);
    } else {
        barWrap.style.display = 'none';
    }
}

// 📸 Enregistrer le visage
function registerFace() {
    if (!video.videoWidth) { showResult('error', 'Erreur', 'Webcam non prête !'); return; }

    if (btnRegister) { btnRegister.disabled = true; btnRegister.textContent = '⏳ Enregistrement...'; }
    showResult('info', 'En cours...', 'Enregistrement de votre visage de référence.');

    fetch("{{ path('face_upload') }}", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ image: getSnapshot() })
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) {
            showResult('success', '✅ Visage enregistré !', 'Redirection vers la vérification...');
            setTimeout(() => { window.location.reload(); }, 1500);
        } else {
            if (btnRegister) { btnRegister.disabled = false; btnRegister.innerHTML = '📸 Enregistrer mon visage'; }
            showResult('error', '❌ Échec', data.error || 'Erreur inconnue');
        }
    })
    .catch(() => {
        if (btnRegister) { btnRegister.disabled = false; btnRegister.innerHTML = '📸 Enregistrer mon visage'; }
        showResult('error', '❌ Erreur', 'Impossible de contacter le serveur.');
    });
}

// 🔍 Scanner le visage
function capture() {
    if (!video.videoWidth) { showResult('error', 'Erreur', 'Webcam non prête !'); return; }

    if (btnScan) { btnScan.disabled = true; btnScan.textContent = '⏳ Analyse...'; }
    videoContainer.classList.add('scanning');
    showResult('info', 'Analyse en cours...', 'Comparaison avec votre visage de référence.');

    fetch("{{ path('face_test') }}", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ image: getSnapshot() })
    })
    .then(r => r.json())
    .then(data => {
        if (btnScan) { btnScan.disabled = false; btnScan.innerHTML = '🔍 Scanner mon visage'; }
        videoContainer.classList.remove('scanning');

        if (data.error) { showResult('error', '❌ Erreur', data.error); return; }

        const score = parseFloat(data.confidence).toFixed(1);

        if (data.success) {
            showResult('success', '✅ Accès autorisé', 'Score : ' + score + '% — Redirection...', data.confidence);
            setTimeout(() => { window.location.href = "{{ path('app_home') }}"; }, 2000);
        } else {
            showResult('error', '❌ Accès refusé', 'Score : ' + score + '% (minimum requis : 80%)', data.confidence);
        }
    })
    .catch(() => {
        if (btnScan) { btnScan.disabled = false; btnScan.innerHTML = '🔍 Scanner mon visage'; }
        videoContainer.classList.remove('scanning');
        showResult('error', '❌ Erreur', 'Impossible de contacter le serveur.');
    });
}
</script>

{% endblock %}
