{% extends 'base.html.twig' %}

{% block body %}

<style>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap');

    :root {
        --bg: #0a0a0f;
        --surface: #13131a;
        --border: #1e1e2e;
        --accent: #6c63ff;
        --accent2: #00d4aa;
        --danger: #ff4d6d;
        --text: #e8e8f0;
        --muted: #6b6b80;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: 'DM Sans', sans-serif;
        min-height: 100vh;
    }

    .face-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        background:
            radial-gradient(ellipse 60% 50% at 20% 20%, rgba(108,99,255,0.12) 0%, transparent 60%),
            radial-gradient(ellipse 40% 40% at 80% 80%, rgba(0,212,170,0.08) 0%, transparent 60%),
            var(--bg);
    }

    .face-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 2.5rem;
        width: 100%;
        max-width: 440px;
        box-shadow: 0 40px 80px rgba(0,0,0,0.5);
    }

    .face-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .face-icon {
        width: 56px;
        height: 56px;
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        margin: 0 auto 1rem;
        box-shadow: 0 8px 24px rgba(108,99,255,0.35);
    }

    .face-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.6rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--text);
    }

    .face-subtitle {
        color: var(--muted);
        font-size: 0.875rem;
        margin-top: 0.4rem;
        font-weight: 300;
    }

    /* Webcam container */
    .video-container {
        position: relative;
        border-radius: 16px;
        overflow: hidden;
        background: #000;
        aspect-ratio: 4/3;
        margin-bottom: 1.5rem;
        border: 1px solid var(--border);
    }

    #video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transform: scaleX(-1); /* miroir */
    }

    /* Overlay scan effect */
    .scan-line {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--accent), transparent);
        animation: scanDown 2.5s ease-in-out infinite;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .scanning .scan-line {
        opacity: 1;
    }

    @keyframes scanDown {
        0%   { top: 0%; }
        100% { top: 100%; }
    }

    /* Corner brackets */
    .corner {
        position: absolute;
        width: 24px;
        height: 24px;
        border-color: var(--accent2);
        border-style: solid;
        opacity: 0.7;
    }
    .corner-tl { top: 12px; left: 12px; border-width: 2px 0 0 2px; border-radius: 4px 0 0 0; }
    .corner-tr { top: 12px; right: 12px; border-width: 2px 2px 0 0; border-radius: 0 4px 0 0; }
    .corner-bl { bottom: 12px; left: 12px; border-width: 0 0 2px 2px; border-radius: 0 0 0 4px; }
    .corner-br { bottom: 12px; right: 12px; border-width: 0 2px 2px 0; border-radius: 0 0 4px 0; }

    /* Status badge */
    .status-badge {
        position: absolute;
        bottom: 12px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(0,0,0,0.7);
        backdrop-filter: blur(8px);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 4px 14px;
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--muted);
        white-space: nowrap;
        transition: all 0.3s;
    }

    /* Buttons */
    .btn-group {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .btn {
        padding: 0.8rem 1rem;
        border: none;
        border-radius: 12px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .btn-register {
        background: rgba(108,99,255,0.15);
        color: var(--accent);
        border: 1px solid rgba(108,99,255,0.3);
    }

    .btn-register:hover:not(:disabled) {
        background: rgba(108,99,255,0.25);
        border-color: var(--accent);
        transform: translateY(-1px);
    }

    .btn-scan {
        background: linear-gradient(135deg, var(--accent), #8b85ff);
        color: #fff;
        box-shadow: 0 4px 16px rgba(108,99,255,0.4);
    }

    .btn-scan:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(108,99,255,0.5);
    }

    .btn-scan:active:not(:disabled) {
        transform: translateY(0);
    }

    /* Result box */
    .result-box {
        border-radius: 12px;
        padding: 1rem 1.2rem;
        font-size: 0.875rem;
        display: none;
        animation: fadeIn 0.3s ease;
        border: 1px solid transparent;
    }

    .result-box.success {
        background: rgba(0,212,170,0.1);
        border-color: rgba(0,212,170,0.3);
        color: var(--accent2);
        display: block;
    }

    .result-box.error {
        background: rgba(255,77,109,0.1);
        border-color: rgba(255,77,109,0.3);
        color: var(--danger);
        display: block;
    }

    .result-box.info {
        background: rgba(108,99,255,0.1);
        border-color: rgba(108,99,255,0.3);
        color: var(--accent);
        display: block;
    }

    .result-title {
        font-weight: 700;
        font-size: 1rem;
        margin-bottom: 0.25rem;
        font-family: 'Syne', sans-serif;
    }

    /* Confidence bar */
    .confidence-bar-wrap {
        margin-top: 0.6rem;
        background: rgba(255,255,255,0.08);
        border-radius: 99px;
        height: 6px;
        overflow: hidden;
    }

    .confidence-bar-fill {
        height: 100%;
        border-radius: 99px;
        transition: width 0.8s ease;
        background: linear-gradient(90deg, var(--accent2), #00ffcc);
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    canvas { display: none; }
</style>

<div class="face-wrapper">
    <div class="face-card">

        <div class="face-header">
            <div class="face-icon">🔐</div>
            <h1 class="face-title">Face ID Admin</h1>
            <p class="face-subtitle">Vérification biométrique sécurisée</p>
        </div>

        <!-- Webcam -->
        <div class="video-container" id="videoContainer">
            <video id="video" autoplay playsinline></video>
            <div class="scan-line"></div>
            <div class="corner corner-tl"></div>
            <div class="corner corner-tr"></div>
            <div class="corner corner-bl"></div>
            <div class="corner corner-br"></div>
            <div class="status-badge" id="statusBadge">Initialisation caméra...</div>
        </div>

        <canvas id="canvas"></canvas>

        <!-- Boutons -->
        <div class="btn-group">
            <button class="btn btn-register" id="btnRegister" onclick="registerFace()" disabled>
                📸 Enregistrer
            </button>
            <button class="btn btn-scan" id="btnScan" onclick="capture()" disabled>
                🔍 Scanner
            </button>
        </div>

        <!-- Résultat -->
        <div class="result-box" id="resultBox">
            <div class="result-title" id="resultTitle"></div>
            <div id="resultMsg"></div>
            <div class="confidence-bar-wrap" id="barWrap" style="display:none">
                <div class="confidence-bar-fill" id="barFill" style="width:0%"></div>
            </div>
        </div>

    </div>
</div>

<script>
const video       = document.getElementById('video');
const canvas      = document.getElementById('canvas');
const statusBadge = document.getElementById('statusBadge');
const btnRegister = document.getElementById('btnRegister');
const btnScan     = document.getElementById('btnScan');
const videoContainer = document.getElementById('videoContainer');

// ✅ Démarrer la webcam
document.addEventListener("DOMContentLoaded", function () {
    navigator.mediaDevices.getUserMedia({ video: true })
        .then(stream => {
            video.srcObject = stream;
            statusBadge.textContent = '🟢 Caméra active';
            statusBadge.style.color = '#00d4aa';
            btnRegister.disabled = false;
            btnScan.disabled = false;
        })
        .catch(err => {
            statusBadge.textContent = '❌ Caméra inaccessible';
            statusBadge.style.color = '#ff4d6d';
            showResult('error', 'Erreur caméra', err.message);
        });
});

// 📸 Capturer une image depuis la webcam
function getSnapshot() {
    canvas.width  = video.videoWidth;
    canvas.height = video.videoHeight;
    canvas.getContext('2d').drawImage(video, 0, 0);
    return canvas.toDataURL('image/jpeg', 0.9);
}

// 🔄 Afficher le résultat
function showResult(type, title, msg, confidence = null) {
    const box   = document.getElementById('resultBox');
    const tit   = document.getElementById('resultTitle');
    const msgEl = document.getElementById('resultMsg');
    const barWrap = document.getElementById('barWrap');
    const barFill = document.getElementById('barFill');

    box.className = 'result-box ' + type;
    tit.textContent = title;
    msgEl.textContent = msg;

    if (confidence !== null) {
        barWrap.style.display = 'block';
        setTimeout(() => { barFill.style.width = Math.min(confidence, 100) + '%'; }, 100);
    } else {
        barWrap.style.display = 'none';
    }
}

// 📸 Enregistrer le visage de l'admin
function registerFace() {
    if (!video.videoWidth) { showResult('error', 'Erreur', 'Webcam non prête !'); return; }

    btnRegister.disabled = true;
    btnRegister.textContent = '⏳ Enregistrement...';
    showResult('info', 'En cours...', 'Enregistrement de votre visage de référence.');

    const image = getSnapshot();

    fetch("{{ path('face_upload') }}", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ image })
    })
    .then(r => r.json())
    .then(data => {
        btnRegister.disabled = false;
        btnRegister.innerHTML = '📸 Enregistrer';

        if (data.success) {
            showResult('success', '✅ Visage enregistré !', 'Vous pouvez maintenant scanner votre visage pour vous authentifier.');
        } else {
            showResult('error', '❌ Échec', data.error || 'Erreur inconnue');
        }
    })
    .catch(() => {
        btnRegister.disabled = false;
        btnRegister.innerHTML = '📸 Enregistrer';
        showResult('error', '❌ Erreur', 'Impossible de contacter le serveur.');
    });
}

// 🔍 Scanner et comparer le visage
function capture() {
    if (!video.videoWidth) { showResult('error', 'Erreur', 'Webcam non prête !'); return; }

    btnScan.disabled = true;
    btnScan.textContent = '⏳ Analyse...';
    videoContainer.classList.add('scanning');
    showResult('info', 'Analyse en cours...', 'Comparaison avec votre visage de référence.');

    const image = getSnapshot();

    fetch("{{ path('face_test') }}", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ image })
    })
    .then(r => r.json())
    .then(data => {
        btnScan.disabled = false;
        btnScan.innerHTML = '🔍 Scanner';
        videoContainer.classList.remove('scanning');

        if (data.error) {
            showResult('error', '❌ Erreur', data.error);
            return;
        }

        const score = parseFloat(data.confidence).toFixed(1);

        if (data.success) {
            showResult('success', '✅ Accès autorisé', 'Score de confiance : ' + score + '%', data.confidence);
            // Redirection vers le dashboard admin après 2 secondes
            setTimeout(() => { window.location.href = "{{ path('app_home') }}"; }, 2000);
        } else {
            showResult('error', '❌ Accès refusé', 'Score de confiance : ' + score + '% (minimum requis : 80%)', data.confidence);
        }
    })
    .catch(() => {
        btnScan.disabled = false;
        btnScan.innerHTML = '🔍 Scanner';
        videoContainer.classList.remove('scanning');
        showResult('error', '❌ Erreur', 'Impossible de contacter le serveur.');
    });
}
</script>

{% endblock %}
