{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Fraunces:wght@600;700&display=swap" rel="stylesheet">
<style>
:root {
  --green: #16c784; --green-dark: #0fa36a;
  --border: #e2e8f0; --muted: #64748b;
  --text: #1a2332; --body-bg: #f0f4f8;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'DM Sans', sans-serif;
  background: var(--body-bg);
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
}
body::before {
  content: ''; position: fixed;
  width: 500px; height: 500px;
  background: var(--green); border-radius: 50%;
  filter: blur(90px); opacity: .15;
  top: -150px; left: -150px; pointer-events: none; z-index: 0;
}
body::after {
  content: ''; position: fixed;
  width: 400px; height: 400px;
  background: #1e88e5; border-radius: 50%;
  filter: blur(90px); opacity: .15;
  bottom: -100px; right: -100px; pointer-events: none; z-index: 0;
}
.card {
  position: relative; z-index: 1;
  background: #fff; border-radius: 24px;
  box-shadow: 0 20px 60px rgba(0,0,0,.10);
  width: 100%; max-width: 440px;
  overflow: hidden; border: none;
}
.card-header {
  background: linear-gradient(135deg, #0d1b2a, #1a2d45);
  color: #fff;
  font-family: 'Fraunces', serif;
  font-size: 22px; font-weight: 700;
  text-align: center; padding: 32px 40px;
  letter-spacing: .3px;
}
.card-body { padding: 28px 36px 36px; }
label {
  font-size: 12px !important; font-weight: 600 !important;
  color: var(--muted) !important; text-transform: uppercase;
  letter-spacing: .4px; margin-bottom: 6px !important;
  display: block; margin-top: 16px;
}
.form-control {
  width: 100%; padding: 11px 14px;
  border: 1.5px solid var(--border); border-radius: 12px;
  font-size: 14px; font-family: 'DM Sans', sans-serif;
  background: var(--body-bg); color: var(--text);
  outline: none; transition: border-color .2s, box-shadow .2s;
}
.form-control:focus {
  border-color: var(--green); background: #fff;
  box-shadow: 0 0 0 3px rgba(22,199,132,.12);
}
.btn-primary {
  width: 100%; margin-top: 20px; padding: 13px;
  background: linear-gradient(135deg, var(--green), var(--green-dark));
  border: none; border-radius: 12px;
  color: #fff; font-size: 15px; font-weight: 700;
  font-family: 'DM Sans', sans-serif;
  cursor: pointer; transition: all .25s; display: block;
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(22,199,132,.4);
}
.alert { border-radius: 10px; padding: 12px 16px; font-size: 13.5px; margin-bottom: 16px; }
.alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #16a34a; }
.alert-danger  { background: #fef2f2; border: 1px solid #fecaca; color: #dc2626; }
.back-link { text-align: center; margin-top: 20px; }
.back-link a { font-size: 13px; color: var(--muted); text-decoration: none; }
.back-link a:hover { color: var(--green); }
</style>
{% endblock %}

{% block body %}
<div class="card">
    <div class="card-header">
        <i class="bi bi-lock"></i> Mot de passe oublié
    </div>
    <div class="card-body">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div>
                {{ form_label(form.email) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.email) }}
            </div>
            {{ form_widget(form.submit, {'attr': {'class': 'btn-primary'}}) }}
        {{ form_end(form) }}

        <div class="back-link">
            <a href="{{ path('app_login') }}">← Retour à la connexion</a>
        </div>
    </div>
</div>
{% endblock %}