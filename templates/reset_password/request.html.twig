{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublie{% endblock %}

{% block body %}
  <div class="container py-5" style="max-width:560px;">
    <div class="card border-0 shadow rounded-4 mt-5">
      <div class="card-body p-4 p-md-5">
        <h1 class="h3 mb-3">Mot de passe oublie</h1>
        <p class="text-muted">Entrez votre email pour recevoir un lien de reinitialisation.</p>
        {{ form_start(form) }}
          {{ form_row(form.email) }}
          <button class="btn btn-primary rounded-pill px-4 mt-2">Envoyer</button>
        {{ form_end(form) }}
      </div>
    </div>
  </div>
{% endblock %}
