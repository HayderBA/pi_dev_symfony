{% extends 'wellness/base.html.twig' %}

{% block title %}Programmes sportifs{% endblock %}

{% block body %}
    <div class="container wellness-page py-4 py-xl-5">
        <div class="wellness-page-header">
            <div class="wellness-page-copy">
                <div class="page-kicker mb-2">Programme sportif</div>
                <h1 class="wellness-title">Programmes personnalises</h1>
                <p class="wellness-lead">
                    Historique des programmes generes a partir du stress, du sommeil, de l IMC et des estimations caloriques.
                </p>
            </div>

            <div class="wellness-actions">
                <a class="btn-shell btn-shell-primary" href="{{ path('app_programme_sportif_new') }}">
                    <i class="bi bi-plus-lg"></i>Generer un programme
                </a>
            </div>
        </div>

        {% if programmes is empty %}
            <div class="card content-card">
                <div class="card-body p-4 p-xl-5 text-center">
                    <h2 class="h4 mb-3">Aucun programme genere</h2>
                    <p class="text-muted mb-4">
                        Lancez une premiere analyse pour produire un plan sportif adapte au profil d un utilisateur.
                    </p>
                    <a class="btn-shell btn-shell-primary" href="{{ path('app_programme_sportif_new') }}">
                        <i class="bi bi-stars"></i>Commencer
                    </a>
                </div>
            </div>
        {% else %}
            <div class="row g-4">
                {% for programme in programmes %}
                    <div class="col-xl-4 col-md-6">
                        <div class="card content-card h-100">
                            <div class="card-body d-flex flex-column p-4">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                    <div>
                                        <div class="page-kicker mb-2">{{ programme.user.nom }}</div>
                                        <h2 class="h5 mb-1">{{ programme.typeProgramme }}</h2>
                                        <p class="text-muted mb-0">{{ programme.createdAt|date('d/m/Y H:i') }}</p>
                                    </div>
                                    <span class="badge rounded-pill text-bg-light">{{ programme.intensite }}</span>
                                </div>

                                <div class="row g-3 mb-3">
                                    <div class="col-6">
                                        <div class="border rounded-4 p-3 h-100">
                                            <div class="page-kicker mb-1">IMC</div>
                                            <strong>{{ programme.imc|number_format(1, '.', ' ') }}</strong>
                                            <div class="text-muted small">{{ programme.categorieImc }}</div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="border rounded-4 p-3 h-100">
                                            <div class="page-kicker mb-1">Calories</div>
                                            <strong>{{ programme.besoinCalorique }}</strong>
                                            <div class="text-muted small">kcal / jour</div>
                                        </div>
                                    </div>
                                </div>

                                <p class="text-muted flex-grow-1">
                                    {{ programme.resume|slice(0, 180) }}{% if programme.resume|length > 180 %}...{% endif %}
                                </p>

                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <small class="text-muted">{{ programme.seances|length }} seances planifiees</small>
                                    <a class="btn-shell btn-shell-outline btn-sm" href="{{ path('app_programme_sportif_show', {id: programme.id}) }}">
                                        Voir le detail
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
