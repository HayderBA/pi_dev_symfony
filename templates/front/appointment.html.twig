{% extends 'base.html.twig' %}

{% block body %}

<!-- ================= HEADER ================= -->
<header id="header" class="header fixed-top">

 

  <!-- MAIN NAV -->
  <div class="branding d-flex align-items-center">

    <div class="container position-relative d-flex align-items-center justify-content-between">

      <!-- LOGO -->
      <a href="{{ path('app_home') }}" class="logo d-flex align-items-center">
        <img src="{{ asset('assets/img/logoGrowmind.png') }}" alt="">
      </a>

      <!-- NAV MENU -->
      <nav id="navmenu" class="navmenu">
        <ul>
          <li><a href="{{ path('app_home') }}">Accueil</a></li>
          <li><a href="{{ path('app_doctors') }}">Medecin</a></li>
          <li><a href="{{ path('app_appointment') }}" >Evenement</a></li>

          <li class="dropdown">
            <a href="#">
              <span>Plus</span>
              <i class="bi bi-chevron-down toggle-dropdown"></i>
            </a>
            <ul>
              <li><a href="#">Cabinet</a></li>
              <li><a href="{{ path('app_appointment') }}">Rendez-vous</a></li>
              <li><a href="{{ path('app_wellness_home') }}">Sant&eacute; &amp; bien-&ecirc;tre</a></li>
              <li><a href="#">Forum</a></li>
              <li><a href="#">Ressources</a></li>
            </ul>
          </li>

          <li><a href="{{ path('app_contact') }}">Contact</a></li>
        </ul>

        <!-- MOBILE MENU -->
        <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
      </nav>

    </div>

  </div>

</header>

<!-- ================= MAIN ================= -->
<main class="main">

  <!-- Title -->
  <div class="page-title text-center">
    <h1>Appointment</h1>
    <p>Book your appointment easily</p>
  </div>

  <!-- FORM -->
  <section class="section">

    <div class="container">
      <div class="row">
        <div class="col-lg-8 mx-auto">

          <h2 class="text-center mb-4">Schedule Your Appointment</h2>

          <form class="row g-3 gm-form-shell">

            <div class="col-md-6">
              <input type="text" class="form-control" placeholder="Full Name">
            </div>

            <div class="col-md-6">
              <input type="email" class="form-control" placeholder="Email">
            </div>

            <div class="col-md-6">
              <input type="tel" class="form-control" placeholder="Phone">
            </div>

            <div class="col-md-6">
              <select class="form-select">
                <option>Select Department</option>
                <option>Cardiology</option>
                <option>Neurology</option>
                <option>Pediatrics</option>
              </select>
            </div>

            <div class="col-md-6">
              <input type="date" class="form-control">
            </div>

            <div class="col-md-6">
              <select class="form-select">
                <option>Select Doctor</option>
                <option>Dr. Sarah</option>
                <option>Dr. Michael</option>
              </select>
            </div>

            <div class="col-12">
              <textarea class="form-control" rows="4" placeholder="Message"></textarea>
            </div>

            <div class="col-12 text-center">
              <button class="btn btn-primary">Book Appointment</button>
            </div>

          </form>

        </div>
      </div>
    </div>

  </section>

</main>

<!-- ================= FOOTER ================= -->
<footer class="text-center p-4">
  <p>© Clinic - All rights reserved</p>
</footer>

{% endblock %}
