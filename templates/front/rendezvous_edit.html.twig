{% extends 'front/front_layout.html.twig' %}

{% block front_html_title %}Modifier rendez-vous{% endblock %}
{% block front_heading %}Modifier le rendez-vous{% endblock %}
{% block front_subheading %}Mettez à jour les informations du rendez-vous.{% endblock %}

{% block front_content %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="front-panel-card">
            <div class="card-header-theme">
                <h2 class="h5 mb-0"><i class="bi bi-pencil-square me-2"></i>Édition</h2>
            </div>
            <div class="card-body">
                {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
                {{ form_errors(form) }}
                {% for child in form %}
                    {{ form_row(child) }}
                {% endfor %}
                <div class="mt-4 d-flex flex-wrap gap-2">
                    <button class="btn btn-primary" type="submit"><i class="bi bi-check2 me-1"></i> Sauvegarder</button>
                    <a href="{{ path('front_rendezvous_index') }}" class="btn btn-outline-secondary">Retour</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
