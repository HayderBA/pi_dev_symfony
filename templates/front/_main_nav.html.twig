<header id="header" class="header fixed-top">
  <div class="branding d-flex align-items-center">
    <div class="container position-relative d-flex align-items-center justify-content-between">
      <a href="{{ path('app_home') }}" class="logo d-flex align-items-center">
        <img src="{{ asset('assets/img/logoGrowmind.png') }}" alt="GrowMind" style="max-height: 42px;">
        <h1 class="sitename mb-0 ms-2">GrowMind</h1>
      </a>

      <nav id="navmenu" class="navmenu">
        <ul>
          <li><a href="{{ path('app_home') }}" class="{{ active_page|default('') == 'home' ? 'active' : '' }}">Accueil</a></li>
          <li class="dropdown">
            <a href="#" class="{{ active_page|default('') in ['doctors', 'cabinet'] ? 'active' : '' }}">
              <span>Cabinet</span>
              <i class="bi bi-chevron-down toggle-dropdown"></i>
            </a>
            <ul>
              <li><a href="{{ path('front_cabinet_index') }}">Cabinets</a></li>
              <li><a href="{{ path('front_psychologue_index') }}">Medecins</a></li>
              <li><a href="{{ path('front_rendezvous_index') }}">Rendez-vous</a></li>
              <li><a href="{{ path('front_rendezvous_new') }}">Prendre rendez-vous</a></li>
            </ul>
          </li>
          <li><a href="{{ path('app_evenement_list') }}" class="{{ active_page|default('') == 'events' ? 'active' : '' }}">Evenements</a></li>
          <li><a href="{{ path('app_forum_index') }}" class="{{ active_page|default('') == 'forum' ? 'active' : '' }}">Forum</a></li>
          <li><a href="{{ path('front_resources') }}" class="{{ active_page|default('') == 'resources' ? 'active' : '' }}">Bibliotheque</a></li>
          <li><a href="{{ path('app_wellness_dashboard') }}" class="{{ active_page|default('') == 'wellness' ? 'active' : '' }}">Bien-etre</a></li>
          <li><a href="{{ path('app_contact') }}" class="{{ active_page|default('') == 'contact' ? 'active' : '' }}">Contact</a></li>
          {% if app.user %}
            <li class="dropdown">
              <a href="#">
                <span>Mon espace</span>
                <i class="bi bi-chevron-down toggle-dropdown"></i>
              </a>
              <ul>
                <li><a href="{{ path('app_profile') }}">Profil</a></li>
                {% if is_granted('ROLE_ADMIN') %}
                  <li><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
                {% endif %}
                <li><a href="{{ path('app_logout') }}">Deconnexion</a></li>
              </ul>
            </li>
          {% else %}
            <li><a href="{{ path('app_login') }}" class="{{ active_page|default('') == 'login' ? 'active' : '' }}">Connexion</a></li>
            <li><a href="{{ path('app_register') }}" class="{{ active_page|default('') == 'register' ? 'active' : '' }}">Inscription</a></li>
          {% endif %}
        </ul>
        <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
      </nav>
    </div>
  </div>
</header>
