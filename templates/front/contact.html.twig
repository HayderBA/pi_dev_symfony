{% extends 'base.html.twig' %}

{% block body %}

<!-- ================= HEADER ================= -->

  <header id="header" class="header fixed-top">

    <div class="branding d-flex align-items-cente">

      <div class="container position-relative d-flex align-items-center justify-content-between">
        <a href="index.html" class="logo d-flex align-items-center">
          <!-- Uncomment the line below if you also wish to use an image logo -->
          <!--<img src="{{asset('assets/img/logoGrowmind.png')}}" alt="">-->
          <h1 class="sitename">GrowMind</h1>
        </a>

        <nav id="navmenu" class="navmenu">
          
        <ul>
          <li><a href="{{ path('app_home') }}">Accueil</a></li>
          <li><a href="{{ path('app_doctors') }}">Medecin</a></li>
          <li><a href="#" >Evenement</a></li>

          <li class="dropdown">
            <a href="#">
              <span>Plus</span>
              <i class="bi bi-chevron-down toggle-dropdown"></i>
            </a>
            <ul>
              <li><a href="#">Cabinet</a></li>
              <li><a href="#">Rendez-vous</a></li>
              <li><a href="#">Santé & bien-être</a></li>
              <li><a href="#">Forum</a></li>
              <li><a href="#">Ressources et bibliotheque</a></li>
            </ul>
          </li>

          <li><a href="{{ path('app_contact') }}">Contact</a></li>
           <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
        </nav>
        {# ── Utilisateur connecté ou boutons login/register ── #}
            {% if app.user %}
<li style="position:relative; list-style:none;">

  <a href="#" onclick="toggleMenu(event)" 
     style="display:flex; align-items:center; gap:8px; text-decoration:none; color:#1e293b; font-weight:500;">

    <span style="
      width:30px; height:30px; border-radius:50%;
      background: linear-gradient(135deg, #16c784, #1e88e5);
      color:#fff; font-weight:700; font-size:12px;
      display:inline-flex; align-items:center; justify-content:center;
    ">
      {{ app.user.name|first|upper }}{{ app.user.secondName|first|upper }}
    </span>

    <span>{{ app.user.name }}</span>
  </a>

  <!-- DROPDOWN -->
  <ul id="userMenu"
      style="
        display:none;
        position:absolute;
        top:120%;
        right:0;
        background:#fff;
        border-radius:10px;
        min-width:180px;
        padding:8px 0;
        box-shadow:0 10px 25px rgba(0,0,0,0.1);
        z-index:999;
      ">

    <li style="padding:8px 16px; font-size:12px; color:#64748b;">
      {{ app.user.email }}
    </li>

    <li><a href="{{path('app_profile')}}" style="display:block; padding:10px 16px; text-decoration:none;">Mon Profil</a></li>
    <li>
  <a href="
  {% if 'ROLE_ADMIN ' in app.user.roles %}
      {{ path('app_admin_dashboard') }}
  {% elseif 'ROLE_DOCTOR ' in app.user.roles %}
      {{ path('app_doctor_dash') }}
  {% else %}
      {{ path('app_home') }}
  {% endif %}
  "
  style="display:block; padding:10px 16px; text-decoration:none;">
    Tableau de bord
  </a>
</li>

    <li>
      <a href="{{ path('app_logout') }}" style="display:block; padding:10px 16px; color:red;">
        Déconnexion
      </a>
    </li>

  </ul>

</li>
{% endif %}
          </ul>
          <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
        </nav>

      </div>

    </div>

  </header>
<!-- ================= MAIN ================= -->
<main class="main">

  <!-- Page Title -->
  <div class="page-title text-center">
    <h1>Contact</h1>
    <p>Contact us for more information</p>
  </div>

  <!-- Contact Section -->
  <section class="contact section">

    <div class="container">
      <div class="row g-5">

        <!-- INFO -->
        <div class="col-lg-5">
          <h3>Our Address</h3>
          <p>1842 Maple Avenue</p>

          <h3>Email</h3>
          <p>contact@example.com</p>

          <h3>Hours</h3>
          <p>Mon-Fri: 9 AM - 6 PM</p>
        </div>

        <!-- FORM -->
        <div class="col-lg-7">

          <h2>Send Message</h2>

          <form>
            <div class="row g-3">

              <div class="col-md-6">
                <input type="text" class="form-control" placeholder="Name">
              </div>

              <div class="col-md-6">
                <input type="email" class="form-control" placeholder="Email">
              </div>

              <div class="col-12">
                <input type="text" class="form-control" placeholder="Subject">
              </div>

              <div class="col-12">
                <textarea class="form-control" rows="5" placeholder="Message"></textarea>
              </div>

              <div class="col-12">
                <button class="btn btn-primary">Send</button>
              </div>

            </div>
          </form>

        </div>

      </div>
    </div>

  </section>

  <!-- MAP -->
  <div class="container-fluid">
    <iframe src="https://www.google.com/maps?q=paris&output=embed"
            width="100%" height="400" style="border:0;"></iframe>
  </div>

</main>

<!-- ================= FOOTER ================= -->
<footer class="text-center p-4">
  <p>© Clinic - All rights reserved</p>
</footer>

<script src="assets/js/main.js"></script>
  <script>
function toggleMenu(event) {
  event.preventDefault();

  let menu = document.getElementById("userMenu");

  if (menu.style.display === "block") {
    menu.style.display = "none";
  } else {
    menu.style.display = "block";
  }
}

/* fermer si clic ailleurs */
document.addEventListener("click", function(e) {
  let menu = document.getElementById("userMenu");

  if (!e.target.closest("li")) {
    if (menu) menu.style.display = "none";
  }
});
</script>
{% endblock %}