{% extends 'front/front_layout.html.twig' %}

{% block front_html_title %}Nouveau cabinet{% endblock %}
{% block front_heading %}Ajouter un cabinet{% endblock %}
{% block front_subheading %}Renseignez les informations du cabinet.{% endblock %}

{% block front_content %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="front-panel-card">
            <div class="card-header-theme">
                <h2 class="h5 mb-0"><i class="bi bi-building-add me-2"></i>Formulaire</h2>
            </div>
            <div class="card-body">
                {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
                {{ form_errors(form) }}
                {% for child in form %}
                    {{ form_row(child) }}
                {% endfor %}
                <div class="mt-4 d-flex flex-wrap gap-2">
                    <button class="btn btn-primary" type="submit"><i class="bi bi-check2 me-1"></i> Enregistrer</button>
                    <a href="{{ path('front_cabinet_index') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
