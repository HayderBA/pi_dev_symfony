{% extends 'base.html.twig' %}

{% block title %}{{ ressource.title }}{% endblock %}

{% block body %}
<style>
    .resource-show-page {
        background: linear-gradient(180deg, #f8fbf9 0%, #ffffff 100%);
        min-height: 100vh;
        padding: 60px 0;
    }

    .show-card {
        background: #ffffff;
        border-radius: 24px;
        padding: 32px;
        box-shadow: 0 12px 35px rgba(0, 0, 0, 0.07);
        border: 1px solid #eef2ef;
    }

    .show-badge {
        display: inline-block;
        background: #d8f3dc;
        color: #2d6a4f;
        padding: 8px 14px;
        border-radius: 999px;
        font-weight: 700;
        font-size: 13px;
        margin-bottom: 16px;
    }

    .show-title {

    php bin/console debug:router
        font-size: 38px;
        font-weight: 800;
        color: #1f513c;
        margin-bottom: 20px;
    }

    .show-meta {
        font-size: 17px;
        color: #4b5563;
        margin-bottom: 14px;
    }

    .show-meta strong {
        color: #111827;
    }

    .btn-back {
        display: inline-block;
        margin-top: 24px;
        background: #2d6a4f;
        color: #ffffff;
        padding: 12px 22px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
    }

    .btn-back:hover {
        color: #ffffff;
        opacity: 0.92;
    }
</style>

<div class="resource-show-page">
    <div class="container">
        <div class="show-card">
            <span class="show-badge">{{ ressource.type }}</span>
            <h1 class="show-title">{{ ressource.title }}</h1>

            <div class="show-meta">
                <strong>Catégorie :</strong> {{ ressource.category }}
            </div>

            <div class="show-meta">
                <strong>Auteur :</strong> {{ ressource.author }}
            </div>

            <div class="show-meta">
                <strong>Statut :</strong> {{ ressource.status }}
            </div>

            <a href="{{ path('front_resources') }}" class="btn-back">← Retour aux ressources</a>
        </div>
    </div>
</div>
{% endblock %}