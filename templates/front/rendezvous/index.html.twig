{% extends 'base.html.twig' %}

{% block title %}Mes Rendez-vous{% endblock %}

{% block body %}
{% include 'front/_main_nav.html.twig' with { active_page: 'cabinet' } %}
<main class="main" style="padding-top: 120px;">
  <section class="section">
    <div class="container">
      <div class="section-title text-center mb-5">
        <h1>Rendez-vous</h1>
        <p>Historique et suivi des demandes de consultation.</p>
      </div>

      {% for message in app.flashes('success') %}<div class="alert alert-success">{{ message }}</div>{% endfor %}
      {% for message in app.flashes('error') %}<div class="alert alert-danger">{{ message }}</div>{% endfor %}

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
          <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4"><label class="form-label">Recherche</label><input type="text" name="q" value="{{ filters.q }}" class="form-control" placeholder="Patient, email, cabinet, psy"></div>
            <div class="col-md-2"><label class="form-label">Statut</label><select name="statut" class="form-select"><option value="">Tous</option><option value="en_attente" {{ filters.statut == 'en_attente' ? 'selected' }}>En attente</option><option value="confirme" {{ filters.statut == 'confirme' ? 'selected' }}>Confirme</option><option value="annule" {{ filters.statut == 'annule' ? 'selected' }}>Annule</option></select></div>
            <div class="col-md-2"><label class="form-label">Du</label><input type="date" name="date_from" value="{{ filters.date_from }}" class="form-control"></div>
            <div class="col-md-2"><label class="form-label">Au</label><input type="date" name="date_to" value="{{ filters.date_to }}" class="form-control"></div>
            <div class="col-md-2 d-flex gap-2"><button class="btn btn-primary w-100">Filtrer</button></div>
          </form>
        </div>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="card border-0 shadow-sm p-3 text-center"><div class="small text-muted">Total</div><div class="fs-4 fw-bold">{{ stats.total }}</div></div></div>
        <div class="col-md-3"><div class="card border-0 shadow-sm p-3 text-center"><div class="small text-muted">A venir</div><div class="fs-4 fw-bold">{{ stats.a_venir }}</div></div></div>
        <div class="col-md-3"><div class="card border-0 shadow-sm p-3 text-center"><div class="small text-muted">Aujourd hui</div><div class="fs-4 fw-bold">{{ stats.aujourdhui }}</div></div></div>
        <div class="col-md-3"><div class="card border-0 shadow-sm p-3 text-center"><div class="small text-muted">Confirmes</div><div class="fs-4 fw-bold">{{ stats.by_statut.confirme|default(0) }}</div></div></div>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-lg-8">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Workflow de rappel</h5>
                <a href="{{ path('front_rendezvous_new') }}" class="btn btn-primary btn-sm">Nouveau rendez-vous</a>
              </div>
              <p class="text-muted mb-2">Le module expose deja l'API attendue par n8n pour les rappels J-1.</p>
              <div class="d-flex flex-wrap gap-2 mb-3">
                <span class="badge bg-primary">GET {{ workflow.api_url }}</span>
                <span class="badge bg-success">{{ workflow.pending_tomorrow }} rappel(s) a envoyer demain</span>
              </div>
              <div class="small text-muted">Prochaines consultations</div>
              <div class="mt-2">
                {% for next in workflow.next_rendezvous %}
                  <div class="d-flex justify-content-between border rounded-3 px-3 py-2 mb-2">
                    <span>{{ next.prenomPatient }} {{ next.nomPatient }} avec {{ next.psychologue.displayName }}</span>
                    <strong>{{ next.dateRdv|date('d/m') }} {{ next.heure|date('H:i') }}</strong>
                  </div>
                {% else %}
                  <div class="text-muted">Aucun prochain rendez-vous.</div>
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
              <h5 class="mb-3">Paiement et suivi</h5>
              <p class="text-muted">Les rendez-vous confirmes peuvent maintenant afficher un paiement Stripe quand les cles d'environnement sont renseignees.</p>
              <ul class="small text-muted mb-0">
                <li>mail automatique a la creation</li>
                <li>mail lors de la confirmation ou annulation</li>
                <li>rappel J-1 par workflow ou depuis le back</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="table-responsive">
            <table class="table align-middle">
              <thead><tr><th>Patient</th><th>Psychologue</th><th>Date</th><th>Statut</th><th>Paiement</th><th></th></tr></thead>
              <tbody>
                {% for rdv in rendezvous %}
                  <tr>
                    <td>{{ rdv.prenomPatient }} {{ rdv.nomPatient }}<br><small class="text-muted">{{ rdv.emailPatient }}</small></td>
                    <td>{{ rdv.psychologue.displayName }}<br><small class="text-muted">{{ rdv.psychologue.cabinet ? rdv.psychologue.cabinet.nomcabinet : '-' }}</small></td>
                    <td>{{ rdv.dateRdv ? rdv.dateRdv|date('d/m/Y') : '-' }}<br><small class="text-muted">{{ rdv.heure ? rdv.heure|date('H:i') : '-' }}</small></td>
                    <td><span class="badge {{ rdv.statut == 'confirme' ? 'bg-success' : (rdv.statut == 'annule' ? 'bg-danger' : 'bg-warning text-dark') }}">{{ rdv.statut }}</span></td>
                    <td>
                      <span class="badge {{ rdv.estPaye ? 'bg-primary' : 'bg-secondary' }}">{{ rdv.estPaye ? 'Paye' : 'Non paye' }}</span>
                      <br><small class="text-muted">{{ rdv.tarifConsultation ?: rdv.psychologue.tarif }} TND</small>
                    </td>
                    <td class="d-flex gap-1 flex-wrap">
                      <a href="{{ path('front_rendezvous_show', {id: rdv.idRdv}) }}" class="btn btn-outline-primary btn-sm">Voir</a>
                      {% if rdv.statut == 'confirme' and not rdv.estPaye %}
                        <a href="{{ path('paiement_index', {id: rdv.idRdv}) }}" class="btn btn-success btn-sm">Payer</a>
                      {% endif %}
                    </td>
                  </tr>
                {% else %}
                  <tr><td colspan="6" class="text-muted">Aucun rendez-vous trouve.</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% if rendezvous.paginationData is defined %}
            <div class="mt-3">{{ knp_pagination_render(rendezvous) }}</div>
          {% endif %}
        </div>
      </div>
    </div>
  </section>
</main>
{% endblock %}
