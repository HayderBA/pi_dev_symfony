{% extends 'base.html.twig' %}

{% block title %}Prendre rendez-vous{% endblock %}

{% block body %}
{% include 'front/_main_nav.html.twig' with { active_page: 'cabinet' } %}
<main class="main" style="padding-top: 120px;">
  <section class="section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-xl-9">
          <div class="card border-0 shadow-lg">
            <div class="card-body p-4 p-md-5">
              <div class="text-center mb-4">
                <h1>Prendre rendez-vous</h1>
                <p class="text-muted">Choisissez un cabinet, puis un psychologue relie ou non a un medecin existant dans users.</p>
              </div>
              {{ form_start(form) }}
                <div class="row g-3">
                  <div class="col-md-6">{{ form_row(form.cabinet_id) }}</div>
                  <div class="col-md-6">{{ form_row(form.psychologue_id) }}</div>
                  <div class="col-md-4">{{ form_row(form.dateRdv) }}</div>
                  <div class="col-md-4">{{ form_row(form.heure) }}</div>
                  <div class="col-md-4">{{ form_row(form.typeCons) }}</div>
                  <div class="col-md-6">{{ form_row(form.nomPatient) }}</div>
                  <div class="col-md-6">{{ form_row(form.prenomPatient) }}</div>
                  <div class="col-md-6">{{ form_row(form.emailPatient) }}</div>
                  <div class="col-md-6">{{ form_row(form.telephonePatient) }}</div>
                </div>
                <div class="d-flex gap-2 mt-4">
                  <button class="btn btn-primary">Confirmer la demande</button>
                  <a href="{{ path('front_cabinet_index') }}" class="btn btn-outline-secondary">Voir les cabinets</a>
                </div>
              {{ form_end(form) }}
            </div>
          </div>
        </div>
        <div class="col-xl-3 mt-4 mt-xl-0">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
              <h5 class="mb-3">Ce qui est actif</h5>
              <ul class="small text-muted mb-0">
                <li>liaison cabinets / psychologues / medecins users</li>
                <li>mail automatique apres creation</li>
                <li>rappel compatible workflow n8n</li>
                <li>paiement Stripe quand les cles sont configurees</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>
{% endblock %}
