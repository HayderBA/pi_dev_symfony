{% extends 'base.html.twig' %}

{% block title %}Rendez-vous #{{ rdv.idRdv }}{% endblock %}

{% block body %}
{% include 'front/_main_nav.html.twig' with { active_page: 'cabinet' } %}
<main class="main" style="padding-top: 120px;">
  <section class="section">
    <div class="container">
      {% for message in app.flashes('success') %}<div class="alert alert-success">{{ message }}</div>{% endfor %}
      {% for message in app.flashes('error') %}<div class="alert alert-danger">{{ message }}</div>{% endfor %}
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
              <h1>Rendez-vous #{{ rdv.idRdv }}</h1>
              <p class="text-muted mb-0">{{ rdv.prenomPatient }} {{ rdv.nomPatient }}</p>
            </div>
            <span class="badge {{ rdv.statut == 'confirme' ? 'bg-success' : (rdv.statut == 'annule' ? 'bg-danger' : 'bg-warning text-dark') }}">{{ rdv.statut }}</span>
          </div>

          <div class="row g-4">
            <div class="col-md-6">
              <h5>Patient</h5>
              <p><strong>Email:</strong> {{ rdv.emailPatient }}</p>
              <p><strong>Telephone:</strong> {{ rdv.telephonePatient }}</p>
              <p><strong>Rappel envoye:</strong> {{ rdv.rappelEnvoye ? 'Oui' : 'Non' }}</p>
              <p><strong>Date rappel:</strong> {{ rdv.dateRappel ? rdv.dateRappel|date('d/m/Y H:i') : '-' }}</p>
            </div>
            <div class="col-md-6">
              <h5>Consultation</h5>
              <p><strong>Psychologue:</strong> {{ rdv.psychologue.displayName }}</p>
              <p><strong>Cabinet:</strong> {{ rdv.psychologue.cabinet ? rdv.psychologue.cabinet.nomcabinet : '-' }}</p>
              <p><strong>Date:</strong> {{ rdv.dateRdv ? rdv.dateRdv|date('d/m/Y') : '-' }} a {{ rdv.heure ? rdv.heure|date('H:i') : '-' }}</p>
              <p><strong>Type:</strong> {{ rdv.typeCons }}</p>
              <p><strong>Tarif:</strong> {{ rdv.tarifConsultation ?: rdv.psychologue.tarif }} TND</p>
              <p><strong>Paiement:</strong> {{ rdv.estPaye ? 'Confirme' : 'En attente' }}</p>
            </div>
          </div>
          <div class="d-flex gap-2 flex-wrap mt-4">
            <a href="{{ path('front_rendezvous_index') }}" class="btn btn-outline-secondary">Retour</a>
            {% if rdv.statut == 'confirme' and not rdv.estPaye %}
              <a href="{{ path('paiement_index', {id: rdv.idRdv}) }}" class="btn btn-success {{ not stripe_ready ? 'disabled' }}">Payer maintenant</a>
            {% endif %}
          </div>
          {% if not stripe_ready and rdv.statut == 'confirme' and not rdv.estPaye %}
            <div class="alert alert-warning mt-3 mb-0">Stripe n'est pas configure dans l'environnement actuel. Ajoute les cles pour activer le paiement en ligne.</div>
          {% endif %}
        </div>
      </div>
    </div>
  </section>
</main>
{% endblock %}
