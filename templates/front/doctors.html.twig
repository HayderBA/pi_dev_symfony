{% extends 'base.html.twig' %}

{% block body %}

<!-- ================= HEADER ================= -->

  <header id="header" class="header fixed-top">

    <div class="branding d-flex align-items-cente">

      <div class="container position-relative d-flex align-items-center justify-content-between">
        <a href="index.html" class="logo d-flex align-items-center">
          <!-- Uncomment the line below if you also wish to use an image logo -->
          <!--<img src="{{asset('assets/img/logoGrowmind.png')}}" alt="">-->
          <h1 class="sitename">GrowMind</h1>
        </a>

        <nav id="navmenu" class="navmenu">
          
        <ul>
          <li><a href="{{ path('app_home') }}">Accueil</a></li>
          <li><a href="{{ path('app_doctors') }}">Medecin</a></li>
          <li><a href="#" >Evenement</a></li>

          <li class="dropdown">
            <a href="#">
              <span>Plus</span>
              <i class="bi bi-chevron-down toggle-dropdown"></i>
            </a>
            <ul>
              <li><a href="#">Cabinet</a></li>
              <li><a href="#">Rendez-vous</a></li>
              <li><a href="#">Santé & bien-être</a></li>
              <li><a href="#">Forum</a></li>
              <li><a href="#">Ressources et bibliotheque</a></li>
            </ul>
          </li>

          <li><a href="{{ path('app_contact') }}">Contact</a></li>
           <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
        </nav>
        {# ── Utilisateur connecté ou boutons login/register ── #}
            {% if app.user %}
<li style="position:relative; list-style:none;">

  <a href="#" onclick="toggleMenu(event)" 
     style="display:flex; align-items:center; gap:8px; text-decoration:none; color:#1e293b; font-weight:500;">

    <span style="
      width:30px; height:30px; border-radius:50%;
      background: linear-gradient(135deg, #16c784, #1e88e5);
      color:#fff; font-weight:700; font-size:12px;
      display:inline-flex; align-items:center; justify-content:center;
    ">
      {{ app.user.name|first|upper }}{{ app.user.secondName|first|upper }}
    </span>

    <span>{{ app.user.name }}</span>
  </a>

  <!-- DROPDOWN -->
  <ul id="userMenu"
      style="
        display:none;
        position:absolute;
        top:120%;
        right:0;
        background:#fff;
        border-radius:10px;
        min-width:180px;
        padding:8px 0;
        box-shadow:0 10px 25px rgba(0,0,0,0.1);
        z-index:999;
      ">

    <li style="padding:8px 16px; font-size:12px; color:#64748b;">
      {{ app.user.email }}
    </li>

    <li><a href="{{path('app_profile')}}" style="display:block; padding:10px 16px; text-decoration:none;">Mon Profil</a></li>
    <li>
  <a href="
  {% if 'ROLE_ADMIN ' in app.user.roles %}
      {{ path('app_admin_dashboard') }}
  {% elseif 'ROLE_DOCTOR ' in app.user.roles %}
      {{ path('app_doctor_dash') }}
  {% else %}
      {{ path('app_home') }}
  {% endif %}
  "
  style="display:block; padding:10px 16px; text-decoration:none;">
    Tableau de bord
  </a>
</li>

    <li>
      <a href="{{ path('app_logout') }}" style="display:block; padding:10px 16px; color:red;">
        Déconnexion
      </a>
    </li>

  </ul>

</li>
{% endif %}
          </ul>
          <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
        </nav>

      </div>

    </div>

  </header>

<!-- ================= MAIN ================= -->
<main class="main">

  <!-- Title -->
  <div class="page-title text-center">
    <h1>Doctors</h1>
    <p>Meet our professional team</p>
  </div>

  <!-- Doctors -->
  <section class="doctors section">

    <div class="container">
      
      {# Vérification que la variable doctors existe et n'est pas vide #}
      {% if doctors is defined and doctors is not empty %}

        <div class="row gy-4">

          {% for doctor in doctors %}
            <div class="col-lg-3 col-md-6">
              <div class="doctor-card">
                
                {# Avatar avec initiales #}
                <div class="doctor-avatar">
                  {{ doctor.name|slice(0,1) ~ doctor.second_name|slice(0,1) }}
                </div>
                
                <h4>Dr. {{ doctor.name }} {{ doctor.second_name }}</h4>
                
                {# Spécialité #}
                <span class="specialty">{{ doctor.specialty ?: 'Spécialité non définie' }}</span>
                
                {# Informations supplémentaires #}
                <div class="doctor-info">
                  {% if doctor.experience %}
                    <small><i class="bi bi-briefcase"></i> {{ doctor.experience }} ans d'expérience</small>
                  {% endif %}
                  
                  {% if doctor.diplome %}
                    <small><i class="bi bi-award"></i> {{ doctor.diplome }}</small>
                  {% endif %}
                  
                  {% if doctor.tarifConsultation %}
                    <small class="price"><i class="bi bi-currency-dollar"></i> {{ doctor.tarifConsultation }} TND/séance</small>
                  {% endif %}
                  
                  <small class="status {{ doctor.disponible ? 'available' : 'unavailable' }}">
                    <i class="bi {{ doctor.disponible ? 'bi-check-circle-fill' : 'bi-x-circle-fill' }}"></i>
                    {{ doctor.disponible ? 'Disponible' : 'Indisponible' }}
                  </small>
                </div>
                
                {# Bouton de rendez-vous #}
                <a href="#" class="btn btn-primary mt-3">
                  <i class="bi bi-calendar-plus"></i> Prendre RDV
                </a>
              </div>
            </div>
          {% endfor %}

        </div>
        
      {% else %}
        <div class="alert alert-info text-center">
          <i class="bi bi-info-circle"></i> Aucun médecin n'est disponible pour le moment.
        </div>
      {% endif %}

    </div>

  </section>


</main>

<footer class="text-center p-4">
  <p>© Clinic - All rights reserved</p>
</footer>
<script src="assets/js/main.js"></script>
  <script>
function toggleMenu(event) {
  event.preventDefault();

  let menu = document.getElementById("userMenu");

  if (menu.style.display === "block") {
    menu.style.display = "none";
  } else {
    menu.style.display = "block";
  }
}

/* fermer si clic ailleurs */
document.addEventListener("click", function(e) {
  let menu = document.getElementById("userMenu");

  if (!e.target.closest("li")) {
    if (menu) menu.style.display = "none";
  }
});
</script>
{% endblock %}