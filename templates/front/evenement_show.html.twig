{% extends 'base.html.twig' %}

{% block title %}{{ evenement.titre }} - GrowMind{% endblock %}

{% block body %}
<section class="event-hero">
    <div class="event-hero-bg"></div>
    <div class="container event-hero-content">
        <nav class="event-breadcrumb">
            <a href="{{ path('app_evenement_list') }}"><i class="fas fa-arrow-left"></i> Tous les événements</a>
            <span>/ {{ evenement.titre }}</span>
        </nav>
        <div class="event-header">
            <div class="event-badge {{ evenement.statusColor == 'primary' ? 'badge-upcoming' : (evenement.statusColor == 'success' ? 'badge-today' : 'badge-past') }}">
                <i class="fas fa-{{ evenement.status == 'À venir' ? 'clock' : (evenement.status == 'Aujourd\'hui' ? 'sun' : 'check') }}"></i>
                {{ evenement.status }}
            </div>
            <h1 class="event-title">{{ evenement.titre }}</h1>
            <div class="event-info-grid">
                <div class="info-item">
                    <div class="info-icon"><i class="fas fa-calendar-alt"></i></div>
                    <div class="info-text">
                        <span>Date</span>
                        <strong>{{ evenement.date|date('d/m/Y') }}</strong>
                    </div>
                </div>
                <div class="info-item">
                    <div class="info-icon"><i class="fas fa-clock"></i></div>
                    <div class="info-text">
                        <span>Horaire</span>
                        <strong>{{ evenement.date|date('H:i') }}</strong>
                    </div>
                </div>
                <div class="info-item">
                    <div class="info-icon"><i class="fas fa-map-marker-alt"></i></div>
                    <div class="info-text">
                        <span>Lieu</span>
                        <strong>{{ evenement.localisation }}</strong>
                    </div>
                </div>
                <div class="info-item">
                    <div class="info-icon"><i class="fas fa-tag"></i></div>
                    <div class="info-text">
                        <span>Tarif</span>
                        <strong>{{ evenement.dynamicPrice }} €</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="event-detail-container">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="event-description-card">
                    <h3><i class="fas fa-leaf"></i> À propos de cet atelier</h3>
                    <p>{{ evenement.description }}</p>
                    
                    <div class="event-features">
                        <h4>Au programme :</h4>
                        <div class="features-list">
                            <div class="feature-item"><i class="fas fa-check-circle"></i> Techniques de relaxation guidée</div>
                            <div class="feature-item"><i class="fas fa-check-circle"></i> Exercices de respiration consciente</div>
                            <div class="feature-item"><i class="fas fa-check-circle"></i> Partages d'expériences bienveillants</div>
                            <div class="feature-item"><i class="fas fa-check-circle"></i> Outils pratiques pour le quotidien</div>
                        </div>
                    </div>
                    
                    <div class="event-capacity-detail">
                        <div class="capacity-header">
                            <span><i class="fas fa-users"></i> Places disponibles</span>
                            <strong>{{ evenement.maxCapacity - evenement.currentReservationsCount }} / {{ evenement.maxCapacity }}</strong>
                        </div>
                        <div class="capacity-bar-detail">
                            <div class="capacity-fill-detail" style="width: {{ (evenement.currentReservationsCount / evenement.maxCapacity) * 100 }}%"></div>
                        </div>
                        <p class="capacity-note">
                            {% if evenement.maxCapacity - evenement.currentReservationsCount <= 5 %}
                                <i class="fas fa-exclamation-circle"></i> Plus que {{ evenement.maxCapacity - evenement.currentReservationsCount }} places disponibles !
                            {% endif %}
                        </p>
                    </div>
                </div>

                <!-- Benefits Section -->
                <div class="benefits-section">
                    <h3 class="benefits-title"><i class="fas fa-heart-pulse"></i> Pourquoi participer ?</h3>
                    
                    <div class="benefits-grid">
                        <div class="benefit-card">
                            <div class="benefit-icon wellness">
                                <i class="fas fa-spa"></i>
                            </div>
                            <h4>Relaxation</h4>
                            <p>Laissez-vous porter par une détente profonde et ressourçante</p>
                        </div>

                        <div class="benefit-card">
                            <div class="benefit-icon energy">
                                <i class="fas fa-leaf"></i>
                            </div>
                            <h4>Bien-être</h4>
                            <p>Rééquilibrez votre corps et renforcer votre connection intérieure</p>
                        </div>

                        <div class="benefit-card">
                            <div class="benefit-icon mindful">
                                <i class="fas fa-brain"></i>
                            </div>
                            <h4>Équilibre mental</h4>
                            <p>Cultivez la clarté d'esprit et la sérénité au quotidien</p>
                        </div>

                        <div class="benefit-card">
                            <div class="benefit-icon harmony">
                                <i class="fas fa-heart-hands"></i>
                            </div>
                            <h4>Harmonie émotionnelle</h4>
                            <p>Connectez-vous à votre essence et trouvez votre paix intérieure</p>
                        </div>
                    </div>

                    <div class="highlights-box">
                        <div class="highlight-item">
                            <i class="fas fa-award"></i>
                            <span>Expérience guidée par des professionnels certifiés</span>
                        </div>
                        <div class="highlight-item">
                            <i class="fas fa-people-arrows"></i>
                            <span>Communauté bienveillante et accueillante</span>
                        </div>
                        <div class="highlight-item">
                            <i class="fas fa-lightbulb"></i>
                            <span>Outils pratiques à intégrer dans votre routine</span>
                        </div>
                        <div class="highlight-item">
                            <i class="fas fa-star"></i>
                            <span>Une expérience transformatrice vous attend</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-5">
                <div class="reservation-card">
                    <div class="reservation-header">
                        <i class="fas fa-ticket-alt"></i>
                        <h3>Réservez votre place</h3>
                    </div>
                    
                    <form id="reservationForm" method="post" action="{{ path('app_reservation_new', {'id': evenement.id}) }}">
                        <div class="form-group">
                            <label><i class="fas fa-user"></i> Nom complet *</label>
                            <div class="input-wrapper">
                                <input type="text" id="nom" name="nom" class="form-control-modern" required placeholder="Votre nom et prénom">
                                <div class="error-message">Le nom doit contenir au moins 2 caractères</div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label><i class="fas fa-envelope"></i> Email *</label>
                            <div class="input-wrapper">
                                <input type="email" id="email" name="email" class="form-control-modern" required placeholder="exemple@email.com">
                                <div class="error-message">Email invalide</div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label><i class="fas fa-phone"></i> Téléphone *</label>
                            <div class="input-wrapper">
                                <input type="tel" id="telephone" name="telephone" class="form-control-modern" required placeholder="0612345678">
                                <div class="error-message">Le téléphone doit contenir 10 chiffres</div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label><i class="fas fa-users"></i> Nombre de personnes *</label>
                            <div class="input-wrapper">
                                <input type="number" id="nombre_personnes" name="nombre_personnes" class="form-control-modern" value="1" min="1" max="{{ evenement.maxCapacity - evenement.currentReservationsCount }}">
                                <div class="error-message">Maximum {{ evenement.maxCapacity - evenement.currentReservationsCount }} places disponibles</div>
                            </div>
                        </div>

                        <div class="price-summary">
                            <div class="price-row">
                                <span>Prix unitaire</span>
                                <span>{{ evenement.dynamicPrice }} €</span>
                            </div>
                            <div class="price-row" id="totalRow" style="display: none;">
                                <span>Total</span>
                                <strong id="totalAmount">{{ evenement.dynamicPrice }} €</strong>
                            </div>
                        </div>

                        <input type="hidden" name="_token" value="{{ csrf_token('reservation' ~ evenement.id) }}">

                        <button type="submit" class="reservation-btn">
                            <i class="fas fa-check-circle"></i> Confirmer la réservation
                        </button>
                        <a href="{{ path('app_evenement_list') }}" class="cancel-btn">
                            <i class="fas fa-arrow-left"></i> Retour aux événements
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

