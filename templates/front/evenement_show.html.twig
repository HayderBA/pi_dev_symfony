<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('reservationForm');
    const nbPersonnes = document.getElementById('nombre_personnes');
    const totalRow = document.getElementById('totalRow');
    const totalAmount = document.getElementById('totalAmount');
    const prixUnitaire = {{ evenement.dynamicPrice }};
    
    function updateTotal() {
        const nb = parseInt(nbPersonnes.value) || 1;
        const total = nb * prixUnitaire;
        totalAmount.textContent = total + ' €';
        totalRow.style.display = 'flex';
    }
    
    if (nbPersonnes) {
        nbPersonnes.addEventListener('input', updateTotal);
        updateTotal();
    }
    
    function validateField(field) {
        const wrapper = field.closest('.input-wrapper');
        const errorMsg = wrapper.querySelector('.error-message');
        let isValid = false;
        
        if (field.id === 'nom') {
            isValid = field.value.trim().length >= 2;
        } else if (field.id === 'email') {
            const regex = /^[^\s@]+@([^\s@.,]+\.)+[^\s@.,]{2,}$/;
            isValid = regex.test(field.value.trim());
        } else if (field.id === 'telephone') {
            const digits = field.value.replace(/[^0-9]/g, '');
            isValid = digits.length === 10;
        } else if (field.id === 'nombre_personnes') {
            const max = parseInt(field.getAttribute('max'));
            const val = parseInt(field.value);
            isValid = val >= 1 && val <= max;
        }
        
        if (isValid && field.value.trim() !== '') {
            field.classList.add('valid');
            field.classList.remove('error');
            if (errorMsg) errorMsg.style.display = 'none';
        } else if (field.value.trim() !== '') {
            field.classList.add('error');
            field.classList.remove('valid');
            if (errorMsg) errorMsg.style.display = 'block';
        } else {
            field.classList.remove('valid', 'error');
            if (errorMsg) errorMsg.style.display = 'none';
        }
        return isValid;
    }
    
    ['nom', 'email', 'telephone', 'nombre_personnes'].forEach(fieldId => {
        const field = document.getElementById(fieldId);
        if (field) {
            field.addEventListener('input', () => validateField(field));
            field.addEventListener('blur', () => validateField(field));
        }
    });
    
    if (form) {
        form.addEventListener('submit', (e) => {
            let isValid = true;
            ['nom', 'email', 'telephone', 'nombre_personnes'].forEach(fieldId => {
                const field = document.getElementById(fieldId);
                if (field && !validateField(field)) isValid = false;
            });
            if (!isValid) e.preventDefault();
        });
    }
});
</script>
{% endblock %}