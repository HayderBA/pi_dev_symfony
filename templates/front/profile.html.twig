{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
{% include 'front/_main_nav.html.twig' with { active_page: 'profile' } %}

<div class="container py-5" style="max-width:860px; padding-top: 120px !important;">
  <div class="card border-0 shadow-lg rounded-4 mt-5">
    <div class="card-body p-4 p-md-5">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h1 class="h3 mb-1">Mon profil</h1>
          <p class="text-muted mb-0">{{ user.fullName }} - {{ user.email }}</p>
        </div>
        {% if is_granted('ROLE_ADMIN') %}
          <a href="{{ path('app_admin_dashboard') }}" class="btn btn-outline-secondary rounded-pill">Dashboard</a>
        {% else %}
          <a href="{{ path('app_home') }}" class="btn btn-outline-secondary rounded-pill">Retour accueil</a>
        {% endif %}
      </div>

      {% for label, messages in app.flashes %}
        {% for message in messages %}
          <div class="alert alert-{{ label == 'error' ? 'danger' : label }} rounded-4">{{ message }}</div>
        {% endfor %}
      {% endfor %}

      {{ form_start(profileForm) }}
        <div class="row g-3">
          <div class="col-md-6">{{ form_row(profileForm.name) }}</div>
          <div class="col-md-6">{{ form_row(profileForm.secondName) }}</div>
          <div class="col-md-6">{{ form_row(profileForm.email) }}</div>
          <div class="col-md-3">{{ form_row(profileForm.age) }}</div>
          <div class="col-md-3">{{ form_row(profileForm.gender) }}</div>
          <div class="col-md-6">{{ form_row(profileForm.phoneNumber) }}</div>
          <div class="col-md-6">{{ form_row(profileForm.birthDate) }}</div>
          <div class="col-md-6">{{ form_row(profileForm.adresse) }}</div>
          <div class="col-12">{{ form_row(profileForm.plainPassword) }}</div>
        </div>
        <button class="btn btn-primary rounded-pill px-4 mt-3">Mettre a jour</button>
      {{ form_end(profileForm) }}

      <hr class="my-4">
      <div class="d-flex flex-wrap gap-2">
        {% if user.isPatient %}
          <a href="{{ path('2fa_setup') }}" class="btn btn-outline-success rounded-pill">Configurer 2FA</a>
          <a href="{{ path('mental_health_page') }}" class="btn btn-outline-primary rounded-pill">Check mental health</a>
        {% endif %}
        {% if user.isAdmin %}
          <a href="{{ path('face_page') }}" class="btn btn-outline-dark rounded-pill">Face ID Admin</a>
        {% endif %}
      </div>
    </div>
  </div>
</div>
{% endblock %}
