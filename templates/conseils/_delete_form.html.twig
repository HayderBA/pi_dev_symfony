<form
        class="{{ form_class|default('d-inline-block') }}"
        method="post"
        action="{{ path('app_conseils_delete', {'id': conseil.id}) }}"
        onsubmit="return confirm('{{ confirm_message|default('Supprimer ce conseil ?')|e('js') }}');"
>
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ conseil.id) }}">

    <button class="{{ button_class|default('btn-shell btn-shell-danger') }}">
        <i class="bi bi-{{ button_icon|default('trash') }}"></i>
        {{ button_label|default('Supprimer') }}
    </button>
</form>
