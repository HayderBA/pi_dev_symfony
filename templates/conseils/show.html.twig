{% extends 'wellness/base.html.twig' %}

{% block title %}Détails du conseil{% endblock %}

{% block body %}
    <div class="container py-4">

        <!-- HEADER -->
        <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3 mb-4">
            <div>
                <div class="page-kicker mb-2">Conseils</div>
                <h1 class="h2 mb-1">Conseil #{{ conseil.id }}</h1>
                <p class="text-muted mb-0">Vue détaillée de cette recommandation.</p>
            </div>

            <!-- ACTIONS -->
            <div class="d-flex flex-wrap gap-2">

                <!-- BACK -->
                <a class="btn"
                   style="
                       border:1px solid #6B7280;
                       color:#6B7280;
                       border-radius:10px;
                   "
                   onmouseover="this.style.background='#6B7280'; this.style.color='white';"
                   onmouseout="this.style.background='transparent'; this.style.color='#6B7280';"
                   href="{{ path('app_conseils_index') }}">
                    <i class="bi bi-arrow-left me-1"></i>Retour à la liste
                </a>

                <!-- EDIT -->
                <a class="btn"
                   style="
                       background:#4CAF8E;
                       color:white;
                       border-radius:10px;
                   "
                   onmouseover="this.style.background='#2F7D6D';"
                   onmouseout="this.style.background='#4CAF8E';"
                   href="{{ path('app_conseils_edit', {'id': conseil.id}) }}">
                    <i class="bi bi-pencil-square me-1"></i>Modifier
                </a>

                <!-- DELETE -->
                {{ include('conseils/_delete_form.html.twig', {
                    conseil: conseil,
                    button_class: 'btn',
                    button_label: 'Supprimer',
                    form_class: 'd-inline-block',
                    confirm_message: 'Supprimer ce conseil ?'
                }) }}

            </div>
        </div>

        <!-- DETAIL CARD -->
        <div class="card content-card">
            <div class="card-body p-0">

                <div class="table-responsive">
                    <table class="table detail-table align-middle mb-0">

                        <tbody>

                        <tr>
                            <th>Id</th>
                            <td>{{ conseil.id }}</td>
                        </tr>

                        <tr>
                            <th>Type</th>
                            <td>{{ conseil.typeEtat }}</td>
                        </tr>

                        <tr>
                            <th>Niveau</th>
                            <td>
                                    <span style="
                                        background: rgba(76,175,142,0.15);
                                        color:#2F7D6D;
                                        padding:4px 10px;
                                        border-radius:8px;
                                    ">
                                        {{ conseil.niveau ?? '--' }}
                                    </span>
                            </td>
                        </tr>

                        <tr>
                            <th>Conseil</th>
                            <td class="text-break">
                                <div style="
                                        background:#F5F7F6;
                                        padding:12px;
                                        border-radius:10px;
                                    ">
                                    {{ conseil.conseil }}
                                </div>
                            </td>
                        </tr>

                        <tr>
                            <th>Catégorie</th>
                            <td>{{ conseil.categorie ?? '--' }}</td>
                        </tr>

                        </tbody>

                    </table>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
