{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body { background: linear-gradient(135deg, #f4f9fc 0%, #e6f0f5 100%); }
        .decor-bubble {
            position: fixed;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(102,126,234,0.12) 0%, rgba(102,126,234,0) 70%);
            pointer-events: none;
            z-index: 0;
        }
        .bubble-1 { top: 10%; left: -5%; width: 40%; height: 40%; }
        .bubble-2 { bottom: 5%; right: -5%; width: 45%; height: 45%; background: radial-gradient(circle, rgba(22,199,132,0.08) 0%, rgba(0,0,0,0) 70%); }
        .specialty-card { transition: transform 0.2s, box-shadow 0.2s; }
        .specialty-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.08); }
        .search-input-group { position: relative; }
        .search-input-group i { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #aaa; z-index: 10; }
        .search-input-group input { padding-left: 40px; border-radius: 50px; border: 1px solid #e0e3ef; height: 46px; background-color: #fff; }
        .search-input-group input:focus { border-color: #2c7a7d; box-shadow: 0 0 0 3px rgba(44,122,125,.2); outline: none; }
        .stat-item { background: white; padding: 1rem; border-radius: 0.75rem; box-shadow: 0 2px 8px rgba(0,0,0,0.05); transition: transform 0.2s; }
        .stat-item:hover { transform: translateY(-4px); box-shadow: 0 8px 20px rgba(0,0,0,0.1); }
        .stat-category-card { transition: transform 0.2s, box-shadow 0.2s; cursor: default; }
        .stat-category-card:hover { transform: translateY(-5px); box-shadow: 0 12px 24px rgba(0,0,0,0.15); }
        .btn-teal { background: linear-gradient(135deg, #2c7a7d, #319795); border: none; color: white; }
        .btn-teal:hover { background: linear-gradient(135deg, #236b6d, #2a7e7c); color: white; }
        .btn-outline-teal { border: 1px solid #2c7a7d; color: #2c7a7d; background: transparent; }
        .btn-outline-teal:hover { background: #2c7a7d; color: white; }
        .logo-text { font-size: 1.5rem; font-weight: 700; background: linear-gradient(135deg, #2c7a7d, #319795); -webkit-background-clip: text; background-clip: text; color: transparent; letter-spacing: -0.5px; text-decoration: none; }
    </style>
{% endblock %}

{% block body %}
<div class="decor-bubble bubble-1"></div>
<div class="decor-bubble bubble-2"></div>

<header id="header" class="header fixed-top">
    <div class="branding d-flex align-items-center">
        <div class="container position-relative d-flex align-items-center justify-content-between">
            <a href="{{ path('app_home') }}" class="logo d-flex align-items-center">
                <span class="logo-text">GROWMIND</span>
            </a>
            <nav id="navmenu" class="navmenu">
                <ul>
                    <li><a href="{{ path('app_home') }}">Accueil</a></li>
                    <li><a href="{{ path('app_doctors') }}">Medecin</a></li>
                    <li><a href="{{ path('app_appointment') }}">Evenement</a></li>
                    <li class="dropdown">
                        <a href="#"><span>Plus</span><i class="bi bi-chevron-down toggle-dropdown"></i></a>
                        <ul>
                            <li><a href="#">Cabinet</a></li>
                            <li><a href="{{ path('app_appointment') }}">Rendez-vous</a></li>
                            <li><a href="#">Santé & bien-être</a></li>
                            <li><a href="{{ path('forum_index') }}">Forum</a></li>
                            <li><a href="#">Ressources</a></li>
                        </ul>
                    </li>
                    <li><a href="{{ path('app_contact') }}">Contact</a></li>
                </ul>
                <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
            </nav>
        </div>
    </div>
</header>

<main class="main">
    <div class="page-title text-center">
        <h1>Forum des discussions</h1>
        <p>Un espace bienveillant pour partager, s'écouter et progresser ensemble.</p>
    </div>

    <section class="section">
        <div class="container">
            {# Barre d'outils #}
            <div class="row justify-content-center mb-4">
                <div class="col-lg-8">
                    <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between">
                        <div class="flex-grow-1">
                            <div class="search-input-group">
                                <i class="bi bi-search"></i>
                                <input type="text" id="searchForum" class="form-control" placeholder="Rechercher une discussion…">
                            </div>
                        </div>
                        <a href="{{ path('forum_new') }}" class="btn btn-teal rounded-pill">
                            <i class="bi bi-plus-lg me-1"></i>Nouvelle discussion
                        </a>
                    </div>
                </div>
            </div>

            {# Filtres par catégorie #}
            <div class="row justify-content-center mb-5">
                <div class="col-lg-8">
                    <div class="d-flex flex-wrap justify-content-center gap-2">
                        {% if not currentCategorie %}
                            <a href="{{ path('forum_index') }}" class="btn btn-sm btn-teal rounded-pill">Toutes</a>
                        {% else %}
                            <a href="{{ path('forum_index') }}" class="btn btn-sm btn-outline-teal rounded-pill">Toutes</a>
                        {% endif %}
                        {% for cat in ['Anxiété','Stress','Dépression','Méditation','Sommeil','Estime de soi'] %}
                            {% if currentCategorie == cat %}
                                <a href="{{ path('forum_categorie', {'categorie': cat}) }}" class="btn btn-sm btn-teal rounded-pill">{{ cat }}</a>
                            {% else %}
                                <a href="{{ path('forum_categorie', {'categorie': cat}) }}" class="btn btn-sm btn-outline-teal rounded-pill">{{ cat }}</a>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            </div>

            {# Statistiques générales #}
            <div class="row text-center mb-5 g-4 justify-content-center">
                <div class="col-md-3 col-6"><div class="stat-item"><h3 class="fw-bold" style="color:#2c7a7d;">{{ totalPosts|default(0) }}</h3><p class="text-muted mb-0">Discussions</p></div></div>
                <div class="col-md-3 col-6"><div class="stat-item"><h3 class="fw-bold text-danger">{{ urgentPosts|default(0) }}</h3><p class="text-muted mb-0">Urgentes</p></div></div>
                <div class="col-md-3 col-6"><div class="stat-item"><h3 class="fw-bold" style="color:#2c7a7d;">24/7</h3><p class="text-muted mb-0">Soutien</p></div></div>
            </div>

            {# Statistiques par catégorie (couleurs dégradées) #}
            {% set categoriesStats = {} %}
            {% for post in posts %}
                {% set cat = post.categorie|replace({'😢': '', '😟': '', '🧠': '', '💬': '', '🧘': '', '💤': '', '💪': ''})|trim %}
                {% set categoriesStats = categoriesStats|merge({ (cat): (categoriesStats[cat]|default(0) + 1) }) %}
            {% endfor %}

            {% set categorieColors = {
                'Méditation': 'linear-gradient(135deg, #a5d6a5, #4caf50)',
                'Sommeil': 'linear-gradient(135deg, #90caf9, #2196f3)',
                'Estime de soi': 'linear-gradient(135deg, #ffb74d, #ff9800)',
                'Stress': 'linear-gradient(135deg, #ffa270, #f57c00)',
                'Anxiété': 'linear-gradient(135deg, #ff8a7a, #e64a19)',
                'Dépression': 'linear-gradient(135deg, #e57373, #d32f2f)',
                'Général': 'linear-gradient(135deg, #b0bec5, #78909c)'
            } %}

            {% if categoriesStats|length > 0 %}
                <div class="row mt-5"><div class="col-12"><h4 class="text-center mb-4">Discussions par catégorie</h4></div></div>
                <div class="row g-4 justify-content-center">
                    {% for cat, count in categoriesStats %}
                        <div class="col-md-3 col-sm-6">
                            <div class="stat-category-card text-center p-3 rounded-4 shadow-sm" style="background: {{ categorieColors[cat]|default('linear-gradient(135deg, #b0bec5, #78909c)') }}; color: white;">
                                <h5 class="fw-bold mb-2">{{ cat }}</h5>
                                <div class="display-4 fw-bold">{{ count }}</div>
                                <p class="mb-0 small">discussion(s)</p>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            {# Liste des discussions #}
            {% if posts is empty %}
                <div class="text-center py-5">
                    <i class="bi bi-chat-dots fs-1 text-muted"></i>
                    <p class="mt-3">Aucune discussion pour le moment.</p>
                    <a href="{{ path('forum_new') }}" class="btn btn-teal rounded-pill">Lancer la première discussion</a>
                </div>
            {% else %}
                <div class="row g-4 mt-3">
                    {% for post in posts %}
                        {% set categoriePropre = post.categorie|replace({'😢': '', '😟': '', '🧠': '', '💬': '', '🧘': '', '💤': '', '💪': ''})|trim %}
                        <div class="col-12" data-search="{{ post.nom|lower }} {{ categoriePropre|lower }} {{ post.contenu|lower }}">
                            <div class="specialty-card bg-white rounded-3 shadow-sm overflow-hidden">
                                <div class="specialty-content p-4">
                                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                                        <div>
                                            <h3 class="h5 fw-bold"><a href="{{ path('forum_show', {'id': post.id}) }}" class="text-decoration-none">{{ post.nom }}</a></h3>
                                            <div class="mb-2 d-flex flex-wrap gap-2 align-items-center">
                                                <span class="badge bg-secondary rounded-pill px-3 py-2">{{ categoriePropre }}</span>
                                                <span class="text-muted small"><i class="bi bi-person-circle me-1"></i>{{ post.nom }} <i class="bi bi-calendar3 ms-2 me-1"></i>{{ post.dateCreation|date('d/m/Y') }} <i class="bi bi-eye ms-2 me-1"></i>{{ post.vues }} vues</span>
                                            </div>
                                            <p class="card-text text-muted">{{ post.contenu|slice(0,150) }}{% if post.contenu|length > 150 %}…{% endif %}</p>
                                        </div>
                                        <div class="d-flex gap-2 flex-wrap">
                                            <a href="{{ path('forum_show', {'id': post.id}) }}" class="btn btn-sm rounded-pill" style="color:#7c3aed; border:1px solid #7c3aed; background:transparent;"><i class="bi bi-eye"></i> Voir</a>
                                            <a href="{{ path('forum_edit', {'id': post.id}) }}" class="btn btn-sm rounded-pill" style="color:#b45309; border:1px solid #b45309; background:transparent;"><i class="bi bi-pencil"></i> Modifier</a>
                                            <form action="{{ path('forum_delete', {'id': post.id}) }}" method="POST" onsubmit="return confirm('Supprimer cette discussion ?')">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
                                                <button type="submit" class="btn btn-sm rounded-pill" style="color:#991b1b; border:1px solid #991b1b; background:transparent;"><i class="bi bi-trash"></i> Supprimer</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            {# Carte d'aide d'urgence #}
            <div class="row mt-5 justify-content-center">
                <div class="col-lg-6">
                    <div class="text-white rounded-4 p-4 text-center shadow-lg" style="background: linear-gradient(135deg, #2c7a7d, #319795);">
                        <i class="bi bi-telephone-fill fs-2 mb-2"></i>
                        <h2 class="display-4 fw-bold">3114</h2>
                        <p class="mb-0">Numéro national de prévention du suicide – 24h/24, gratuit et confidentiel.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<footer class="text-center p-4"><p>© GrowMind - Tous droits réservés</p></footer>

<script>
    document.getElementById('searchForum').addEventListener('input', function() {
        let q = this.value.toLowerCase().trim();
        document.querySelectorAll('[data-search]').forEach(card => {
            let text = card.getAttribute('data-search') || '';
            card.style.display = text.includes(q) ? '' : 'none';
        });
    });
</script>
{% endblock %}