<div id="chat-sidebar" class="chat-sidebar">
  <div class="chat-header" onclick="toggleChat()">
    <div class="d-flex align-items-center gap-2">
      <div class="ia-avatar">IA</div>
      <div>
        <strong>Assistant GrowMind</strong>
        <div class="small text-success">En ligne 24/7</div>
      </div>
    </div>
    <i class="bi bi-chevron-down" id="chat-toggle-icon"></i>
  </div>

  <div id="chat-messages" class="chat-messages" style="display: none;">
    <div class="messages-container" id="messages-container">
      <div class="ia-message">
        <div class="message-bubble">
          Bonjour. Je suis votre assistant GrowMind. Comment vous sentez-vous aujourd'hui ?
        </div>
        <div class="message-time">maintenant</div>
      </div>
    </div>

    <div class="chat-input">
      <form id="chat-form" onsubmit="return false;">
        <input type="text" id="chat-input-field" placeholder="Ecrivez votre message..." autocomplete="off">
        <button type="submit" id="chat-send-btn">
          <i class="bi bi-send"></i>
        </button>
      </form>
    </div>
  </div>
</div>

<style>
.chat-sidebar {
  width: 100%;
  background: white;
  border-radius: 16px;
  box-shadow: 0 8px 25px rgba(0,0,0,0.08);
  overflow: hidden;
}
.chat-header {
  background: linear-gradient(135deg, #1a7f7a, #2c9c96);
  color: white;
  padding: 12px 16px;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.ia-avatar {
  width: 40px;
  height: 40px;
  background: white;
  color: #1a7f7a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}
.chat-messages {
  height: 450px;
  display: flex;
  flex-direction: column;
}
.messages-container {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
  background: #f8fafc;
}
.user-message { text-align: right; margin-bottom: 16px; }
.user-message .message-bubble {
  background: linear-gradient(135deg, #1a7f7a, #2c9c96);
  color: white;
  display: inline-block;
  padding: 10px 14px;
  border-radius: 18px;
  max-width: 85%;
  text-align: left;
}
.ia-message { text-align: left; margin-bottom: 16px; }
.ia-message .message-bubble {
  background: white;
  color: #1a2a3a;
  display: inline-block;
  padding: 10px 14px;
  border-radius: 18px;
  max-width: 85%;
  box-shadow: 0 1px 2px rgba(0,0,0,0.05);
}
.message-time {
  font-size: 10px;
  color: #94a3b8;
  margin-top: 4px;
  padding-left: 12px;
}
.chat-input {
  padding: 12px;
  background: white;
  border-top: 1px solid #e2e8f0;
}
.chat-input form { display: flex; gap: 8px; }
.chat-input input {
  flex: 1;
  padding: 10px 14px;
  border: 1px solid #e2e8f0;
  border-radius: 50px;
  outline: none;
}
.chat-input button {
  background: #1a7f7a;
  border: none;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  color: white;
  cursor: pointer;
}
</style>

<script>
function toggleChat() {
  const messages = document.getElementById('chat-messages');
  const icon = document.getElementById('chat-toggle-icon');
  if (messages.style.display === 'none') {
    messages.style.display = 'flex';
    icon.classList.remove('bi-chevron-down');
    icon.classList.add('bi-chevron-up');
  } else {
    messages.style.display = 'none';
    icon.classList.remove('bi-chevron-up');
    icon.classList.add('bi-chevron-down');
  }
}

document.addEventListener('DOMContentLoaded', function () {
  const form = document.getElementById('chat-form');
  if (!form) {
    return;
  }

  form.addEventListener('submit', async function (e) {
    e.preventDefault();
    const input = document.getElementById('chat-input-field');
    const message = input.value.trim();
    if (!message) return;

    const container = document.getElementById('messages-container');
    const userDiv = document.createElement('div');
    userDiv.className = 'user-message';
    userDiv.innerHTML = `<div class="message-bubble">${escapeHtml(message)}</div><div class="message-time">maintenant</div>`;
    container.appendChild(userDiv);
    input.value = '';
    container.scrollTop = container.scrollHeight;

    const typingDiv = document.createElement('div');
    typingDiv.className = 'ia-message';
    typingDiv.id = 'typing-indicator';
    typingDiv.innerHTML = '<div class="message-bubble">Assistant en cours...</div>';
    container.appendChild(typingDiv);
    container.scrollTop = container.scrollHeight;

    try {
      const response = await fetch('/chat/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: message })
      });

      const data = await response.json();
      document.getElementById('typing-indicator')?.remove();

      if (data.success) {
        const iaDiv = document.createElement('div');
        iaDiv.className = 'ia-message';
        iaDiv.innerHTML = `<div class="message-bubble">${escapeHtml(data.reponse)}</div><div class="message-time">maintenant</div>`;
        container.appendChild(iaDiv);
        container.scrollTop = container.scrollHeight;

        if (data.isUrgent) {
          alert('Message urgent detecte. Utilisez aussi le bouton SOS si necessaire.');
        }
      }
    } catch (error) {
      document.getElementById('typing-indicator')?.remove();
    }
  });
});

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}
</script>
