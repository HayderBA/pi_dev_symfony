{{ form_start(form) }}
  <div class="row g-3">
    <div class="col-md-6">
      {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
      {{ form_widget(form.nom) }}
      <div class="text-danger small mt-1">{{ form_errors(form.nom) }}</div>
    </div>
    <div class="col-md-6">
      {{ form_label(form.role, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
      {{ form_widget(form.role) }}
      <div class="text-danger small mt-1">{{ form_errors(form.role) }}</div>
    </div>
    <div class="col-12">
      {{ form_label(form.categorie, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
      {{ form_widget(form.categorie) }}
      <div class="text-danger small mt-1">{{ form_errors(form.categorie) }}</div>
    </div>
    <div class="col-12">
      {{ form_label(form.contenu, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
      {{ form_widget(form.contenu) }}
      <div class="text-danger small mt-1">{{ form_errors(form.contenu) }}</div>
    </div>
  </div>

  <div class="d-flex gap-2 mt-4">
    <button class="btn btn-success px-4">{{ button_label|default('Enregistrer') }}</button>
    <a href="{{ path('app_forum_index') }}" class="btn btn-outline-secondary">Retour au forum</a>
  </div>
{{ form_end(form) }}
