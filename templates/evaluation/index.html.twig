{% extends 'back/base_back.html.twig' %}

{% block title %}Gestion des Évaluations{% endblock %}

{% block admin_content %}
<div class="page-header mb-4">
  <div class="page-header-content">
    <h1>Gestion des Évaluations</h1>
    <p>Consulter, filtrer et gérer les évaluations utilisateur.</p>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-12">
    <div class="gm-card">
      <div class="gm-card-header mb-3">
        <span class="gm-card-title">Liste des Évaluations</span>
        <div class="d-flex gap-2 align-items-center">
          <select id="filterNote" style="padding:7px;border-radius:9px;border:1px solid var(--border);font-size:12.5px;outline:none;background:var(--body-bg);">
            <option value="">Toutes les Notes</option>
            <option value="5">⭐⭐⭐⭐⭐</option>
            <option value="4">⭐⭐⭐⭐</option>
            <option value="3">⭐⭐⭐</option>
            <option value="2">⭐⭐</option>
            <option value="1">⭐</option>
          </select>
          <input type="text" id="searchInputEval" placeholder="Chercher ressource, avis..." style="padding:7px 14px;border-radius:9px;border:1px solid var(--border);font-size:12.5px;outline:none;background:var(--body-bg);width: 250px;">
        </div>
      </div>
      <div class="gm-card-body p-0" style="padding:0!important;">
        <div style="overflow-x:auto;">
          <table class="gm-table">
            <thead>
              <tr>
                <th>Ressource</th>
                <th>Note</th>
                <th>Date d'évaluation</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="tableBodyEval">
                {{ include('evaluation/_list.html.twig') }}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-md-8 mx-auto">
    <div class="gm-card">
       <div class="gm-card-header border-bottom pb-2 mb-3">
          <span class="gm-card-title" style="font-size: 14px;"><i class="bi bi-star-fill me-2" style="color: #f59e0b;"></i>Répartition des Notes ({{ stats.total }} avis)</span>
       </div>
       <div style="height: 250px;">
          <canvas id="notesChart"></canvas>
       </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // 1. Bar Chart Notes
    new Chart(document.getElementById('notesChart'), {
        type: 'bar',
        data: {
            labels: {{ stats.chartNoteLabels|json_encode|raw }},
            datasets: [{
                label: 'Nombre d\'avis',
                data: {{ stats.chartNoteData|json_encode|raw }},
                backgroundColor: '#1e88e5',
                borderRadius: 6
            }]
        },
        options: {
            maintainAspectRatio: false,
            scales: {
                y: { beginAtZero: true, grid: { display: false } },
                x: { grid: { display: false } }
            },
            plugins: {
                legend: { display: false }
            }
        }
    });

    // 2. AJAX Search & Filters
    const searchInput = document.getElementById('searchInputEval');
    const filterNote = document.getElementById('filterNote');
    const tableBody = document.getElementById('tableBodyEval');

    function updateTable() {
        const query = searchInput.value;
        const note = filterNote.value;

        const url = new URL('{{ path('app_evaluation_index') }}', window.location.origin);
        url.searchParams.set('q', query);
        url.searchParams.set('note', note);

        fetch(url, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => response.text())
        .then(html => {
            tableBody.innerHTML = html;
        });
    }

    if (searchInput) {
        searchInput.addEventListener('input', updateTable);
        filterNote.addEventListener('change', updateTable);
    }
});
</script>
{% endblock %}
