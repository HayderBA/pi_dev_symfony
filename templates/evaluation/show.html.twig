{% extends 'back/base_back.html.twig' %}

{% block title %}Détails de l'Évaluation{% endblock %}

{% block admin_content %}
<div class="container mt-5">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-info text-white rounded-top-4">
            <h2 class="mb-0"><i class="bi bi-file-text"></i> Détails de l'évaluation</h2>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped m-0">
                <tbody>
                    <tr>
                        <th class="ps-4 w-25">Ressource</th>
                        <td>{{ evaluation.ressource ? evaluation.ressource.title : '' }}</td>
                    </tr>
                    <tr>
                        <th class="ps-4">Note</th>
                        <td>
                            {% for i in 1..5 %}
                                {% if i <= evaluation.note %}
                                    <i class="bi bi-star-fill text-warning"></i>
                                {% else %}
                                    <i class="bi bi-star text-muted"></i>
                                {% endif %}
                            {% endfor %}
                            ({{ evaluation.note }}/5)
                        </td>
                    </tr>
                    <tr>
                        <th class="ps-4">Commentaire</th>
                        <td>{{ evaluation.commentaire | nl2br }}</td>
                    </tr>
                    <tr>
                        <th class="ps-4 border-0">Date d'évaluation</th>
                        <td class="border-0">{{ evaluation.dateEvaluation ? evaluation.dateEvaluation|date('d/m/Y') : '' }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-light p-3">
            <a href="{{ path('app_evaluation_index') }}" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Retour à la liste</a>
        </div>
    </div>
</div>
{% endblock %}

