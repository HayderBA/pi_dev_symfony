{% extends 'base.html.twig' %}

{% block title %}Réservation confirmée{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8 text-center">
        <div class="card-modern p-5">
            <div class="mb-4">
                <i class="fas fa-check-circle fa-4x" style="color: #2ecc71"></i>
            </div>
            <h1 class="display-5 fw-bold mb-3">Réservation confirmée !</h1>
            <p class="lead mb-4">Votre place a été réservée avec succès. Un email de confirmation vous a été envoyé.</p>
            <div class="d-flex gap-3 justify-content-center">
                <a href="{{ path('app_evenement_list') }}" class="btn btn-primary-custom">
                    <i class="fas fa-calendar-alt me-2"></i>Voir tous les événements
                </a>
                <a href="{{ path('app_evenement_admin') }}" class="btn btn-outline-modern">
                    <i class="fas fa-user-shield me-2"></i>Espace Admin
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}