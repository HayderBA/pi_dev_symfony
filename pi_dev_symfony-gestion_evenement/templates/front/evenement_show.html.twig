{% extends 'base.html.twig' %}

{% block title %}{{ evenement.titre }} - GrowMind{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('assets/css/event-experience.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/venue-map.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/voice-assistant.css') }}">
{% endblock %}

{% block body %}
<section
    class="event-hero"
    data-event-detail
    data-event-id="{{ evenement.id }}"
    data-event-title="{{ evenement.titre }}"
    data-event-date="{{ evenement.date|date('d/m/Y') }}"
    data-event-location="{{ evenement.localisation }}"
    data-event-price="{{ evenement.dynamicPrice|number_format(2, ',', ' ') }} EUR"
    data-event-url="{{ path('app_evenement_show', {'id': evenement.id}) }}"
    data-event-description="{{ evenement.description ? evenement.description|slice(0, 120) : 'Evenement GrowMind a venir.' }}"
>
    <div class="container event-hero-content">
        <a class="event-back" href="{{ path('app_evenement_list') }}">
            <i class="fas fa-arrow-left"></i> Retour aux evenements
        </a>

        <div class="hero-topline">
            <span class="event-badge {{ evenement.statusColor == 'primary' ? 'badge-upcoming' : (evenement.statusColor == 'success' ? 'badge-today' : 'badge-past') }}">
                {{ evenement.status }}
            </span>
            {% if popularityBadge %}
                <span class="hero-pill hero-pill-hot">{{ popularityBadge }}</span>
            {% endif %}
            {% if evenement.isDynamicPriceActive %}
                <span class="hero-pill hero-pill-dynamic">Prix dynamique actif</span>
            {% endif %}
        </div>

        <h1 class="event-title">{{ evenement.titre }}</h1>
        <div class="gm-event-actions">
            <button type="button" class="gm-event-action gm-favorite-btn" data-favorite-toggle data-event-id="{{ evenement.id }}">
                <span data-favorite-icon>♡</span>
                <span data-favorite-text>Favori</span>
            </button>
            <button type="button" id="gmCopyEventLink" class="gm-event-action">
                <span>🔗</span>
                <span data-copy-label>Copier le lien</span>
            </button>
            <button type="button" id="gmShareEvent" class="gm-event-action">
                <span>↗</span>
                <span>Partager</span>
            </button>
        </div>
        <section class="gm-voice-box" data-voice-detail style="margin-top:18px;">
            <div class="gm-voice-top">
                <div>
                    <h3>Commande vocale</h3>
                    <p>Parlez pour aller a la reservation, copier le lien ou ouvrir l agenda.</p>
                </div>
                <button type="button" class="gm-voice-toggle" data-voice-toggle aria-pressed="false" title="Activer la voix">🎤</button>
            </div>
            <p class="gm-voice-status" data-voice-status>Cliquez sur le micro puis parlez. Plusieurs commandes intelligentes sont deja actives.</p>
        </section>
        <div class="event-info-grid">
            <div class="info-item">
                <span>Date</span>
                <strong>{{ evenement.date|date('d/m/Y') }}</strong>
            </div>
            <div class="info-item">
                <span>Heure</span>
                <strong>{{ evenement.date|date('H:i') }}</strong>
            </div>
            <div class="info-item">
                <span>Lieu</span>
                <strong>{{ evenement.localisation }}</strong>
            </div>
            <div class="info-item">
                <span>Prix de base</span>
                <strong>{{ evenement.dynamicPrice|number_format(2, ',', ' ') }} EUR</strong>
            </div>
        </div>

        <div class="gm-smart-panel">
            <div class="gm-smart-panel-top">
                <div>
                    <span class="gm-smart-kicker">Experience moderne</span>
                    <h3>Compte a rebours et rappel intelligent</h3>
                    <p>Suivez le temps restant, activez un rappel navigateur et ajoutez l evenement a votre agenda.</p>
                </div>
                <span class="gm-smart-badge">{{ evenement.getPlacesRestantes() }} places restantes</span>
            </div>

            <div class="gm-countdown" id="gmCountdown" data-event-date="{{ evenement.date|date('Y-m-d') }}">
                <div class="gm-countdown-box">
                    <strong id="gmCountdownDays">--</strong>
                    <span>Jours</span>
                </div>
                <div class="gm-countdown-box">
                    <strong id="gmCountdownHours">--</strong>
                    <span>Heures</span>
                </div>
                <div class="gm-countdown-box">
                    <strong id="gmCountdownMinutes">--</strong>
                    <span>Minutes</span>
                </div>
            </div>

            <div class="gm-smart-insights">
                <div class="gm-smart-insight">
                    <span class="gm-smart-label">Disponibilite</span>
                    <strong>{{ evenement.isComplet() ? 'Complet' : evenement.getPlacesRestantes() ~ ' places libres' }}</strong>
                </div>
                <div class="gm-smart-insight">
                    <span class="gm-smart-label">Conseil</span>
                    <strong>
                        {% if evenement.isDynamicPriceActive %}
                            Reservez tot, le prix dynamique est actif
                        {% elseif evenement.getPlacesRestantes() < 15 %}
                            Priorite a la reservation, il reste peu de places
                        {% else %}
                            Bonne disponibilite pour reserver sereinement
                        {% endif %}
                    </strong>
                </div>
            </div>

            <div class="gm-smart-actions">
                <button type="button" id="gmNotifyEvent" class="gm-event-action">
                    <span>🔔</span>
                    <span id="gmNotifyLabel">Activer un rappel</span>
                </button>
                <a href="{{ evenement.googleCalendarLink }}" target="_blank" rel="noopener noreferrer" class="gm-event-action">
                    <span>📅</span>
                    <span>Google Calendar</span>
                </a>
                <a href="{{ path('app_evenement_ical', {'id': evenement.id}) }}" class="gm-event-action">
                    <span>⬇</span>
                    <span>Fichier .ics</span>
                </a>
            </div>
        </div>
    </div>
</section>

<section class="event-body">
    <div class="container">
        <div class="content-grid">
            <div class="content-main">
                <div class="content-card">
                    <h3>A propos de cet evenement</h3>
                    <p>{{ evenement.description ?: 'Description a venir.' }}</p>

                    <div class="capacity-box">
                        <div class="capacity-header">
                            <span>Occupation actuelle</span>
                            <strong>{{ occupancyRate }}%</strong>
                        </div>
                        <div class="capacity-bar">
                            <div class="capacity-fill" style="width: {{ occupancyRate }}%"></div>
                        </div>
                        <p>{{ evenement.currentReservationsCount }} reservation(s) sur {{ evenement.maxCapacity }} places.</p>
                    </div>
                </div>

                <div class="gm-location-panel">
                    <div class="gm-location-panel-head">
                        <div>
                            <div class="gm-location-kicker">
                                <i class="fas fa-location-dot"></i>
                                Carte du lieu
                            </div>
                            <h4 id="gmVenueFocusTitle">{{ evenement.titre }}</h4>
                            <p>{{ evenement.localisation }}</p>
                        </div>
                        <div class="gm-location-chip">Zoom, glisser, repere actif</div>
                    </div>

                    <div class="gm-location-map-shell">
                        <iframe
                            id="gmEventShowFrame"
                            class="gm-location-frame"
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade"
                            src="https://www.google.com/maps?q={{ evenement.localisation|url_encode }}&output=embed"
                            title="Carte du lieu"
                        ></iframe>
                    </div>
                    <div id="gmEventShowStatus" class="gm-location-status is-muted">Chargement de la carte...</div>

                    <div class="gm-location-actions">
                        <a id="gmEventDirectionsLink" href="https://www.google.com/maps/search/?api=1&query={{ evenement.localisation|url_encode }}" target="_blank" rel="noopener noreferrer" class="gm-location-link gm-location-link-primary">
                            Ouvrir l itineraire
                        </a>
                        <a href="{{ path('app_evenement_list') }}" class="gm-location-link gm-location-link-secondary">
                            Voir les autres lieux
                        </a>
                    </div>
                </div>

                <div class="content-card">
                    <div class="seating-header">
                        <div>
                            <h3>Plan de salle interactif</h3>
                            <p>Survolez une rangee pour voir son prix, puis cliquez sur un siege libre.</p>
                        </div>
                        <div class="screen-badge">SCENE</div>
                    </div>

                    <div class="row-price-banner" id="rowPriceBanner">
                        Survolez une rangee pour afficher son tarif
                    </div>

                    <div class="seats-grid" id="seatsGrid">
                        <div class="grid-loading">Chargement du plan...</div>
                    </div>

                    <div class="selected-seat-info" id="selectedSeatInfo" style="display:none;">
                        Siege selectionne : <strong id="selectedSeatLabel"></strong>
                        <span id="selectedSeatCategory"></span>
                        <span id="selectedSeatPrice"></span>
                    </div>

                    <div class="seat-legend">
                        <div><span class="legend-box legend-vip"></span> VIP (rangees A-B) +20 EUR</div>
                        <div><span class="legend-box legend-standard"></span> Standard (rangees C-F) prix normal</div>
                        <div><span class="legend-box legend-reduit"></span> Reduit (rangees G-H) -10 EUR</div>
                        <div><span class="legend-box legend-reserved"></span> Reserve</div>
                        <div><span class="legend-box legend-selected"></span> Selectionne</div>
                    </div>
                </div>
            </div>

            <aside class="content-side">
                <div class="reservation-card">
                    <h3>Reserver votre place</h3>
                    <form id="reservationForm" method="post" action="{{ path('app_reservation_new', {'id': evenement.id}) }}">
                        <input type="hidden" name="selected_seat" id="selectedSeatInput" value="">
                        <input type="hidden" name="_token" value="{{ csrf_token('reservation' ~ evenement.id) }}">

                        <div class="form-group">
                            <label for="nom">Nom complet</label>
                            <input type="text" id="nom" name="nom" class="form-control-modern" required>
                        </div>

                        <div class="form-group">
                            <label for="email">Email</label>
                            <input type="email" id="email" name="email" class="form-control-modern" required>
                        </div>

                        <div class="form-group">
                            <label for="telephone">Telephone</label>
                            <input type="tel" id="telephone" name="telephone" class="form-control-modern" required>
                        </div>

                        <div class="form-group">
                            <label for="nombre_personnes">Nombre de personnes</label>
                            <input type="number" id="nombre_personnes" name="nombre_personnes" class="form-control-modern" value="1" min="1" max="{{ evenement.placesRestantes }}">
                        </div>

                        <div class="price-summary">
                            <div class="price-row">
                                <span>Prix unitaire</span>
                                <strong id="unitPrice">{{ evenement.dynamicPrice|number_format(2, ',', ' ') }} EUR</strong>
                            </div>
                            <div class="price-row">
                                <span>Categorie</span>
                                <strong id="seatCategoryLabel">Standard</strong>
                            </div>
                            <div class="price-row total-row">
                                <span>Total</span>
                                <strong id="totalAmount">{{ evenement.dynamicPrice|number_format(2, ',', ' ') }} EUR</strong>
                            </div>
                            {% if evenement.isDynamicPriceActive %}
                                <div class="dynamic-price-note">Prix dynamique actif sur cette reservation</div>
                            {% endif %}
                        </div>

                        <button type="submit" class="reservation-btn">Confirmer la reservation</button>
                    </form>
                </div>
            </aside>
        </div>
    </div>
</section>

{% if recommendations %}
<section class="recommendations-section">
    <div class="container">
        <h2>Vous aimerez aussi :</h2>
        <div class="recommendations-grid">
            {% for item in recommendations %}
                <article class="recommendation-card">
                    <span class="recommendation-badge">{{ item.reason }}</span>
                    <h3>{{ item.event.titre }}</h3>
                    <p>{{ item.event.localisation }} - {{ item.event.date|date('d/m/Y') }}</p>
                    <p>{{ item.event.description ? item.event.description|slice(0, 95) ~ '...' : 'Evenement similaire GrowMind.' }}</p>
                    <a href="{{ path('app_evenement_show', {id: item.event.id}) }}">Voir l evenement</a>
                </article>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

<style>
    :root {
        --gm-blue: #1E5BA8;
        --gm-green: #6BBF59;
        --gm-gold: #D4AF37;
        --gm-soft-green: #cfeec6;
        --gm-soft-blue: #d9ecff;
    }

    .event-hero {
        background: linear-gradient(135deg, var(--gm-blue), #2b82b6, var(--gm-green));
        padding: 70px 0 90px;
        color: #fff;
    }

    .event-back {
        color: rgba(255,255,255,.9);
        text-decoration: none;
        display: inline-flex;
        gap: 8px;
        margin-bottom: 24px;
    }

    .hero-topline {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 16px;
    }

    .event-badge,
    .hero-pill {
        padding: 9px 14px;
        border-radius: 999px;
        font-weight: 700;
        font-size: 13px;
    }

    .badge-upcoming { background: rgba(255,255,255,.18); }
    .badge-today { background: rgba(111, 255, 188, .24); }
    .badge-past { background: rgba(255,255,255,.14); }
    .hero-pill-hot { background: linear-gradient(135deg, #ff7b2f, #d9480f); }
    .hero-pill-dynamic { background: linear-gradient(135deg, #f59f00, #f08c00); }

    .event-title { font-size: 3rem; font-weight: 800; margin-bottom: 24px; }

    .event-info-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        background: rgba(255,255,255,.12);
        border-radius: 24px;
        padding: 20px;
        backdrop-filter: blur(10px);
    }

    .info-item span { display: block; font-size: 12px; opacity: .8; margin-bottom: 6px; }
    .info-item strong { font-size: 16px; }

    .event-body { background: #eff7ea; padding: 50px 0 70px; }
    .content-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.4fr) minmax(320px, 420px);
        gap: 28px;
    }

    .content-card,
    .reservation-card,
    .recommendation-card {
        background: #fff;
        border-radius: 26px;
        padding: 24px;
        box-shadow: 0 12px 28px rgba(30, 91, 168, 0.08);
    }

    .content-card + .content-card { margin-top: 24px; }
    .content-card h3,
    .reservation-card h3,
    .recommendations-section h2 { color: #183153; font-weight: 800; }
    .content-card p { color: #566370; }

    .capacity-box {
        margin-top: 20px;
        background: #f5fbf2;
        border-radius: 20px;
        padding: 18px;
    }
    .capacity-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 10px;
        font-weight: 700;
    }
    .capacity-bar {
        height: 8px;
        border-radius: 999px;
        background: #dde7ef;
        overflow: hidden;
        margin-bottom: 10px;
    }
    .capacity-fill {
        height: 100%;
        background: linear-gradient(135deg, var(--gm-green), var(--gm-blue));
    }

    .seating-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
        margin-bottom: 18px;
    }
    .screen-badge {
        background: #183153;
        color: #fff;
        padding: 10px 18px;
        border-radius: 999px;
        font-weight: 700;
    }
    .row-price-banner {
        background: linear-gradient(135deg, #f3fbff, #edf8ea);
        border: 1px solid #dbe8f3;
        border-radius: 18px;
        padding: 14px 18px;
        color: #274b73;
        font-weight: 700;
        margin-bottom: 16px;
    }
    .seats-grid {
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 18px;
        background: #f8fbfd;
        border-radius: 22px;
    }
    .grid-loading { text-align: center; color: #6b7280; }
    .seat-row {
        display: grid;
        grid-template-columns: 62px repeat(10, minmax(28px, 1fr));
        gap: 8px;
        align-items: center;
    }
    .row-label {
        font-weight: 800;
        color: #183153;
        text-align: center;
        padding: 10px 0;
        border-radius: 14px;
        cursor: pointer;
    }
    .seat {
        min-height: 38px;
        border-radius: 12px 12px 16px 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        transition: transform .2s ease, box-shadow .2s ease;
        border: 2px solid transparent;
    }
    .seat:hover { transform: translateY(-2px); box-shadow: 0 8px 14px rgba(30,91,168,.12); }
    .seat-vip { background: #fff2c2; border-color: var(--gm-gold); color: #7a5b06; }
    .seat-standard { background: var(--gm-soft-green); border-color: var(--gm-green); color: #1f5b28; }
    .seat-reduit { background: var(--gm-soft-blue); border-color: #7db7f0; color: #23527c; }
    .seat-reserved { background: #f9d7d7; border-color: #df6b6b; color: #a12323; cursor: not-allowed; opacity: .7; }
    .seat-selected { background: var(--gm-blue); border-color: var(--gm-blue); color: #fff; box-shadow: 0 0 0 3px rgba(30,91,168,.18); }

    .selected-seat-info {
        margin-top: 16px;
        background: #edf8ea;
        border: 1px solid #d0e8c6;
        border-radius: 16px;
        padding: 14px 18px;
        font-weight: 700;
        color: #1f5b28;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .seat-legend {
        margin-top: 18px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
        gap: 10px;
        color: #4f5f6f;
        font-size: 14px;
    }
    .legend-box {
        display: inline-block;
        width: 16px;
        height: 16px;
        border-radius: 5px;
        margin-right: 8px;
        vertical-align: middle;
    }
    .legend-vip { background: #fff2c2; border: 1px solid var(--gm-gold); }
    .legend-standard { background: var(--gm-soft-green); border: 1px solid var(--gm-green); }
    .legend-reduit { background: var(--gm-soft-blue); border: 1px solid #7db7f0; }
    .legend-reserved { background: #f9d7d7; border: 1px solid #df6b6b; }
    .legend-selected { background: var(--gm-blue); border: 1px solid var(--gm-blue); }

    .reservation-card {
        position: sticky;
        top: 90px;
    }
    .form-group { margin-bottom: 16px; }
    .form-group label {
        display: block;
        font-weight: 700;
        color: #274b73;
        margin-bottom: 8px;
    }
    .form-control-modern {
        width: 100%;
        border: 2px solid #dbe8f3;
        border-radius: 16px;
        padding: 13px 15px;
        outline: none;
    }
    .form-control-modern:focus {
        border-color: var(--gm-green);
        box-shadow: 0 0 0 3px rgba(107,191,89,.12);
    }
    .price-summary {
        background: #f5fbf2;
        border-radius: 18px;
        padding: 16px;
        margin: 20px 0;
    }
    .price-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 8px 0;
    }
    .total-row {
        border-top: 1px solid #dbe8f3;
        margin-top: 8px;
        padding-top: 12px;
    }
    .dynamic-price-note {
        margin-top: 10px;
        background: #fff4d7;
        color: #b26a00;
        border-radius: 12px;
        padding: 10px 12px;
        font-size: 13px;
        font-weight: 700;
    }
    .reservation-btn {
        width: 100%;
        border: none;
        border-radius: 16px;
        padding: 14px 18px;
        background: linear-gradient(135deg, var(--gm-blue), var(--gm-green));
        color: #fff;
        font-weight: 800;
    }

    .recommendations-section { background: #f7fbff; padding: 60px 0 80px; }
    .recommendations-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 20px;
        margin-top: 24px;
    }
    .recommendation-card { position: relative; }
    .recommendation-badge {
        position: absolute;
        top: 18px;
        right: 18px;
        background: linear-gradient(135deg, var(--gm-blue), var(--gm-green));
        color: #fff;
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }
    .recommendation-card a {
        display: inline-flex;
        margin-top: 8px;
        text-decoration: none;
        color: var(--gm-blue);
        font-weight: 800;
    }

    @media (max-width: 992px) {
        .content-grid { grid-template-columns: 1fr; }
        .reservation-card { position: static; }
        .event-info-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
        .event-title { font-size: 2.1rem; }
        .event-info-grid { grid-template-columns: 1fr; }
        .seat-row { grid-template-columns: 46px repeat(10, minmax(24px, 1fr)); gap: 6px; }
        .seat { min-height: 32px; font-size: 10px; }
    }
</style>

<script src="{{ asset('assets/js/venue-map.js') }}"></script>
<script src="{{ asset('assets/js/event-experience.js') }}"></script>
<script src="{{ asset('assets/js/voice-assistant.js') }}"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    if (window.GrowMindVenueMaps) {
        window.GrowMindVenueMaps.initShowcase({
            frameId: 'gmEventShowFrame',
            statusId: 'gmEventShowStatus',
            titleId: 'gmVenueFocusTitle',
            directionsId: 'gmEventDirectionsLink',
            currentAddress: {{ evenement.localisation|json_encode|raw }},
            currentLabel: {{ evenement.titre|json_encode|raw }},
            venues: {{ venueCatalogJson|raw }},
        });
    }

    const eventId = {{ evenement.id }};
    const rowPrices = {{ rowPrices|json_encode|raw }};
    const seatsGrid = document.getElementById('seatsGrid');
    const rowPriceBanner = document.getElementById('rowPriceBanner');
    const selectedSeatInput = document.getElementById('selectedSeatInput');
    const selectedSeatInfo = document.getElementById('selectedSeatInfo');
    const selectedSeatLabel = document.getElementById('selectedSeatLabel');
    const selectedSeatCategory = document.getElementById('selectedSeatCategory');
    const selectedSeatPrice = document.getElementById('selectedSeatPrice');
    const unitPrice = document.getElementById('unitPrice');
    const totalAmount = document.getElementById('totalAmount');
    const seatCategoryLabel = document.getElementById('seatCategoryLabel');
    const quantityInput = document.getElementById('nombre_personnes');
    let selectedSeat = null;
    let selectedUnitPrice = {{ evenement.dynamicPrice }};

    function formatPrice(value) {
        return Number(value).toFixed(2).replace('.', ',') + ' EUR';
    }

    function categoryClass(category) {
        if (category === 'VIP') return 'seat-vip';
        if (category === 'Reduit') return 'seat-reduit';
        return 'seat-standard';
    }

    function updateSummary(category, price) {
        selectedUnitPrice = price;
        unitPrice.textContent = formatPrice(price);
        totalAmount.textContent = formatPrice((parseInt(quantityInput.value || '1', 10) || 1) * price);
        seatCategoryLabel.textContent = category === 'Reduit' ? 'Reduit' : category;
    }

    function setRowBanner(rowKey) {
        const rowData = rowPrices[rowKey];
        if (!rowData) {
            rowPriceBanner.textContent = 'Survolez une rangee pour afficher son tarif';
            return;
        }

        rowPriceBanner.textContent = 'Rangee ' + rowKey + ' - ' + rowData.label + ' - ' + formatPrice(rowData.price);
        rowPriceBanner.style.borderColor = rowData.color;
    }

    function renderSeats(grid) {
        seatsGrid.innerHTML = '';

        Object.entries(grid).forEach(([row, seats]) => {
            const rowDiv = document.createElement('div');
            rowDiv.className = 'seat-row';
            rowDiv.dataset.row = row;

            const rowLabel = document.createElement('div');
            rowLabel.className = 'row-label';
            rowLabel.textContent = row;
            rowLabel.style.background = rowPrices[row] ? rowPrices[row].color : '#eef2f7';
            rowLabel.addEventListener('mouseenter', () => setRowBanner(row));
            rowDiv.appendChild(rowLabel);

            Object.values(seats).forEach((seat) => {
                const seatDiv = document.createElement('div');
                seatDiv.className = 'seat ' + categoryClass(seat.category);
                seatDiv.textContent = seat.number;
                seatDiv.title = seat.category + ' - ' + formatPrice(seat.price);
                seatDiv.dataset.number = seat.number;
                seatDiv.dataset.category = seat.category;
                seatDiv.dataset.price = seat.price;

                if (seat.isReserved) {
                    seatDiv.className = 'seat seat-reserved';
                } else {
                    seatDiv.addEventListener('click', () => {
                        selectedSeat = seat.number;
                        selectedSeatInput.value = seat.number;
                        selectedSeatLabel.textContent = seat.number;
                        selectedSeatCategory.textContent = '- ' + (seat.category === 'Reduit' ? 'Reduit' : seat.category);
                        selectedSeatPrice.textContent = '- ' + formatPrice(seat.price);
                        selectedSeatInfo.style.display = 'flex';
                        updateSummary(seat.category, Number(seat.price));
                        loadSeats();
                    });
                }

                if (selectedSeat === seat.number) {
                    seatDiv.classList.add('seat-selected');
                }

                seatDiv.addEventListener('mouseenter', () => setRowBanner(row));
                rowDiv.appendChild(seatDiv);
            });

            rowDiv.addEventListener('mouseenter', () => setRowBanner(row));
            seatsGrid.appendChild(rowDiv);
        });
    }

    function loadSeats() {
        fetch('/reservation/seats/' + eventId)
            .then((response) => response.json())
            .then((data) => {
                if (data.error) {
                    seatsGrid.innerHTML = '<div class="grid-loading">Erreur de chargement</div>';
                    return;
                }
                renderSeats(data.grid);
            })
            .catch(() => {
                seatsGrid.innerHTML = '<div class="grid-loading">Impossible de charger le plan</div>';
            });
    }

    quantityInput.addEventListener('input', () => {
        totalAmount.textContent = formatPrice((parseInt(quantityInput.value || '1', 10) || 1) * selectedUnitPrice);
    });

    updateSummary('Standard', {{ evenement.dynamicPrice }});
    loadSeats();
});
</script>
{% endblock %}
