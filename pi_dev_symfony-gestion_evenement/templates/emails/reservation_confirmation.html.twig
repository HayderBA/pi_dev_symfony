{# 🔥 NOUVEAU CODE - Template email avec QR code pour le billet #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Confirmation de réservation</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background: linear-gradient(135deg, #1E5BA8, #6BBF59); color: white; padding: 30px; text-align: center; border-radius: 20px 20px 0 0; }
        .content { background: #f9f9f9; padding: 30px; border-radius: 0 0 20px 20px; }
        .qr-code { text-align: center; margin: 20px 0; padding: 20px; background: white; border-radius: 15px; }
        .qr-code img { max-width: 200px; border-radius: 10px; }
        .seat-info { background: #EFF7E6; padding: 15px; border-radius: 10px; text-align: center; margin: 20px 0; }
        .seat-number { font-size: 28px; font-weight: bold; color: #1E5BA8; }
        .footer { text-align: center; margin-top: 30px; font-size: 12px; color: #999; }
        .btn { display: inline-block; background: #6BBF59; color: white; padding: 10px 20px; text-decoration: none; border-radius: 25px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>✨ Réservation confirmée !</h1>
        </div>
        <div class="content">
            <h2>Bonjour {{ reservation.nom }},</h2>
            <p>Votre réservation pour <strong>{{ reservation.evenement.titre }}</strong> a bien été enregistrée.</p>
            
            <div class="seat-info">
                <p>🎯 <strong>Votre siège attribué</strong></p>
                <div class="seat-number">Siège {{ reservation.seatNumber }}</div>
                <p style="margin-top: 10px; font-size: 14px;">Présentez ce QR code à l'entrée</p>
            </div>
            
            <div class="qr-code">
                <img src="{{ reservation.qrCode }}" alt="QR Code d'entrée">
            </div>
            
            <div style="margin: 20px 0;">
                <p><strong>📅 Date :</strong> {{ reservation.evenement.date|date('d/m/Y H:i') }}</p>
                <p><strong>📍 Lieu :</strong> {{ reservation.evenement.localisation }}</p>
                <p><strong>💰 Montant total :</strong> {{ reservation.montantTotal }} €</p>
            </div>
            
            <p style="text-align: center; margin-top: 30px;">
                <a href="{{ url('app_evenement_show', {'id': reservation.evenement.id}) }}" class="btn">Voir l'événement</a>
            </p>
        </div>
        <div class="footer">
            <p>GrowMind - Bien-être & Développement personnel</p>
            <p>Cet email est votre billet d'entrée. Présentez-le à l'accueil (version papier ou numérique).</p>
        </div>
    </div>
</body>
</html>